{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "pageel-crm",
  "pages_build_output_dir": "dist",
  "compatibility_date": "2024-11-01",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "pageel-crm-db",
      "database_id": "00000000-0000-0000-0000-000000000000"
    }
  ]
}
