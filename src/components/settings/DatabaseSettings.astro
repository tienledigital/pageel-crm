---
import { t } from '@/lib/i18n';

interface Props {
  lang: 'vi' | 'en';
  isAdmin: boolean;
  dbStats: Array<{ name: string; count: number }>;
  totalRows: number;
}

const { lang, isAdmin, dbStats, totalRows } = Astro.props;

// Group definitions
const coreTableNames = ['customers', 'invoices', 'payments'];
const adminTableNames = ['users', 'staff', 'config'];
const logTableNames = ['sync_logs', 'audit_logs', 'debug_logs'];

const getFriendlyName = (tableName: string) => {
  const meta: Record<string, { vi: string; en: string }> = {
    customers: { vi: 'Khách hàng', en: 'Customers' },
    invoices: { vi: 'Đơn hàng', en: 'Orders' },
    payments: { vi: 'Giao dịch', en: 'Payments' },
    users: { vi: 'Tài khoản admin', en: 'Admin Accounts' },
    staff: { vi: 'Nhân viên', en: 'Staff Profiles' },
    config: { vi: 'Cấu hình hệ thống', en: 'System Config' },
    sync_logs: { vi: 'Log đồng bộ', en: 'Sync Logs' },
    audit_logs: { vi: 'Log kiểm toán', en: 'Audit Logs' },
    debug_logs: { vi: 'Log gỡ lỗi', en: 'Debug Logs' }
  };
  return meta[tableName]?.[lang] || tableName;
};

const getSegmentLabel = (tableName: string) => {
  if (coreTableNames.includes(tableName)) {
    return {
      label: lang === 'vi' ? 'N nghiệp vụ' : 'Core Data',
      class: 'badge-core'
    };
  }
  if (adminTableNames.includes(tableName)) {
    return {
      label: lang === 'vi' ? 'Quản trị' : 'Admin/Config',
      class: 'badge-admin'
    };
  }
  return {
    label: lang === 'vi' ? 'Nhật ký' : 'System Logs',
    class: 'badge-logs'
  };
};

const getTableIcon = (tableName: string) => {
  const icons: Record<string, string> = {
    customers: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-core"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
    invoices: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-core"><line x1="18" y1="2" x2="22" y2="6"/><path d="M13.4 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8.6L13.4 2z"/><polyline points="14 2 14 8 20 8"/></svg>`,
    payments: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-core"><rect x="2" y="5" width="20" height="14" rx="2" ry="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>`,
    users: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-admin"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    staff: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-admin"><circle cx="12" cy="10" r="3"/><path d="M14.5 21a5.5 5.5 0 0 0-5-5H5a5 5 0 0 0-5 5"/><line x1="19" y1="16" x2="19" y2="22"/><line x1="16" y1="19" x2="22" y2="19"/></svg>`,
    config: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-admin"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>`,
    sync_logs: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-log"><path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.57-8.38l5.67-5.67"/></svg>`,
    audit_logs: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-log"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
    debug_logs: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-log-danger"><path d="M8 2h8M12 2v20M8 5h8M19 17A7 7 0 0 1 5 17M12 9a3 3 0 0 0-3 3M12 9a3 3 0 0 1 3 3"/></svg>`
  };
  return icons[tableName] || `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="9" y1="3" x2="9" y2="21"/></svg>`;
};
---

<section id="database" class="settings-card tab-panel">
  <h2>{t('settings.database', lang)}</h2>
  <div class="card-body">
    <!-- Header Controls (Simplified) -->
    <div class="db-section-header">
      <div class="db-summary-badge">
        <span class="badge-label">{lang === 'vi' ? 'Tổng số dòng:' : 'Total Rows:'}</span>
        <span class="badge-value">{totalRows.toLocaleString()}</span>
      </div>
      <button id="optimizeDbBtn" class="btn-secondary flex-btn">
        <span class="spinner" id="optSpinner"></span>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
        {t('settings.optimize_db', lang)}
      </button>
    </div>

    <!-- Simplified Compact Table -->
    <div class="db-table-wrapper">
      <table class="db-compact-table">
        <thead>
          <tr>
            <th>{lang === 'vi' ? 'Bảng dữ liệu' : 'Data Table'}</th>
            <th>{lang === 'vi' ? 'Phân loại' : 'Segment'}</th>
            <th class="text-right">{lang === 'vi' ? 'Số dòng' : 'Rows'}</th>
            <th>{lang === 'vi' ? 'Tỉ lệ' : 'Ratio'}</th>
            <th class="text-center">{lang === 'vi' ? 'Thao tác' : 'Actions'}</th>
          </tr>
        </thead>
        <tbody>
          {dbStats.map(stat => {
            const percentage = totalRows > 0 ? (stat.count / totalRows) * 100 : 0;
            const isLogTable = logTableNames.includes(stat.name);
            const segment = getSegmentLabel(stat.name);
            
            return (
              <tr>
                <td class="td-table-info">
                  <span class="table-row-icon" set:html={getTableIcon(stat.name)} />
                  <div class="table-name-column">
                    <span class="table-friendly-name">{getFriendlyName(stat.name)}</span>
                    <span class="table-raw-name">{stat.name}</span>
                  </div>
                </td>
                <td>
                  <span class={`segment-badge ${segment.class}`}>{segment.label}</span>
                </td>
                <td class="text-right font-mono font-bold">
                  {stat.count.toLocaleString()}
                </td>
                <td>
                  <div class="ratio-cell">
                    <div class="progress-bar-bg-compact">
                      <div 
                        class={`progress-bar-fill-compact ${
                          coreTableNames.includes(stat.name) ? 'core-fill' : 
                          adminTableNames.includes(stat.name) ? 'admin-fill' : 
                          stat.name === 'debug_logs' ? 'danger-fill' : 'log-fill'
                        }`} 
                        style={`width: ${percentage}%`} 
                      />
                    </div>
                    <span class="ratio-percent-text">{percentage.toFixed(1)}%</span>
                  </div>
                </td>
                <td>
                  <div class="table-action-cell">
                    {isLogTable ? (
                      <div class="action-buttons-row">
                        <a 
                          href={`/api/settings/db-download-table?tableName=${stat.name}`} 
                          class="btn-icon-action btn-download" 
                          title={lang === 'vi' ? 'Tải xuống log (JSON)' : 'Download logs (JSON)'}
                          download
                        >
                          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                        </a>
                        <button 
                          class="btn-icon-action btn-clean btn-clear-table" 
                          data-table={stat.name}
                          data-count={stat.count}
                          disabled={stat.count <= 100}
                          title={lang === 'vi' ? 'Dọn dẹp logs (giữ lại 100 dòng mới nhất)' : 'Clean logs (keep 100 latest)'}
                        >
                          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
                        </button>
                      </div>
                    ) : (
                      <span class="compact-protected-tag">
                        <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                        {lang === 'vi' ? 'Bảo vệ' : 'Locked'}
                      </span>
                    )}
                  </div>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>

    <!-- Visual Database Relationship Schema -->
    <div class="db-relation-section">
      <h3>{lang === 'vi' ? 'Sơ đồ mối quan hệ dữ liệu' : 'Database Relationship Schema'}</h3>
      <p class="section-desc">{lang === 'vi' ? 'Mô tả cấu trúc liên kết nghiệp vụ cốt lõi trong hệ thống CRM' : 'Visual blueprint of CRM business entities and connections'}</p>
      
      <div class="erd-diagram-wrapper">
        <svg viewBox="0 0 800 240" class="erd-svg">
          <defs>
            <marker id="arrow" viewBox="0 0 10 10" refX="6" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
              <path d="M 0 1.5 L 8 5 L 0 8.5 z" fill="var(--text-muted, #9ca3af)"/>
            </marker>
          </defs>
          
          <!-- Connections -->
          <!-- Users to Staff -->
          <path d="M 170, 70 H 260" fill="none" stroke="var(--border-color, #e5e7eb)" stroke-width="2" stroke-dasharray="4 3" marker-end="url(#arrow)" />
          
          <!-- Staff to Invoices -->
          <path d="M 335, 100 V 135" fill="none" stroke="var(--color-primary, #3b82f6)" stroke-width="2" marker-end="url(#arrow)" />
          
          <!-- Customers to Invoices -->
          <path d="M 170, 180 H 260" fill="none" stroke="var(--color-success, #10b981)" stroke-width="2" marker-end="url(#arrow)" />
          
          <!-- Invoices to Payments -->
          <path d="M 410, 180 H 500" fill="none" stroke="var(--color-success, #10b981)" stroke-width="2" marker-end="url(#arrow)" />
          
          <!-- Nodes -->
          <!-- Node 1: Users (Admin system) -->
          <g transform="translate(40, 40)">
            <rect width="130" height="60" rx="8" class="node-rect node-admin-style" />
            <text x="65" y="26" class="node-title">Users</text>
            <text x="65" y="44" class="node-subtitle">Tài khoản Admin</text>
          </g>

          <!-- Node 2: Staff (Operational) -->
          <g transform="translate(270, 40)">
            <rect width="130" height="60" rx="8" class="node-rect node-admin-style" />
            <text x="65" y="26" class="node-title">Staff</text>
            <text x="65" y="44" class="node-subtitle">Nhân viên</text>
          </g>

          <!-- Node 3: Customers -->
          <g transform="translate(40, 150)">
            <rect width="130" height="60" rx="8" class="node-rect node-core-style" />
            <text x="65" y="26" class="node-title">Customers</text>
            <text x="65" y="44" class="node-subtitle">Khách hàng</text>
          </g>

          <!-- Node 4: Invoices -->
          <g transform="translate(270, 150)">
            <rect width="130" height="60" rx="8" class="node-rect node-core-style-active" />
            <text x="65" y="26" class="node-title">Orders</text>
            <text x="65" y="44" class="node-subtitle">Đơn hàng</text>
          </g>

          <!-- Node 5: Payments -->
          <g transform="translate(510, 150)">
            <rect width="130" height="60" rx="8" class="node-rect node-core-style" />
            <text x="65" y="26" class="node-title">Payments</text>
            <text x="65" y="44" class="node-subtitle">Thanh toán SePay</text>
          </g>

          <!-- Diagram Legend / Notes -->
          <g transform="translate(660, 40)">
            <rect width="120" height="170" rx="6" class="node-legend-bg" />
            <text x="12" y="25" class="legend-header">{lang === 'vi' ? 'GHI CHÚ' : 'LEGEND'}</text>
            
            <!-- Core badge sample -->
            <circle cx="20" cy="55" r="5" fill="var(--color-success, #10b981)" />
            <text x="32" y="59" class="legend-text">{lang === 'vi' ? 'Nghiệp vụ CRM' : 'Core Business'}</text>
            
            <!-- Admin badge sample -->
            <circle cx="20" cy="85" r="5" fill="var(--color-primary, #3b82f6)" />
            <text x="32" y="89" class="legend-text">{lang === 'vi' ? 'Quản trị hệ thống' : 'Admin & Staff'}</text>

            <!-- Line sample -->
            <line x1="12" y1="120" x2="28" y2="120" stroke="var(--color-success, #10b981)" stroke-width="2" />
            <text x="34" y="124" class="legend-text">1 → N (Has/Owns)</text>

            <!-- Line dash sample -->
            <line x1="12" y1="145" x2="28" y2="145" stroke="var(--text-muted, #9ca3af)" stroke-width="2" stroke-dasharray="3 2" />
            <text x="34" y="149" class="legend-text">{lang === 'vi' ? 'Liên kết tài khoản' : 'Auth Account'}</text>
          </g>
        </svg>
      </div>
    </div>
  </div>
</section>

<!-- DB Clean Modal Confirmation -->
<div id="dbClearModal" class="settings-modal-overlay">
  <div class="settings-modal-card">
    <div class="modal-header">
      <h3 id="modalTitle">Xác nhận dọn dẹp bảng</h3>
      <button class="modal-close-btn" id="closeModalBtn">&times;</button>
    </div>
    <div class="modal-body">
      <div class="alert alert-warning-modal">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="alert-icon"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        <span id="modalDesc">Hành động này sẽ dọn dẹp các dòng log cũ và chỉ giữ lại 100 dòng mới nhất. Bạn có chắc chắn muốn tiếp tục?</span>
      </div>
    </div>
    <div class="modal-footer">
      <button id="cancelClearBtn" class="btn-secondary">Hủy bỏ</button>
      <button id="confirmClearBtn" class="btn-danger flex-btn">
        <span class="spinner" id="clearSpinner"></span>
        Xác nhận dọn dẹp
      </button>
    </div>
  </div>
</div>

<style>
  /* Header section */
  .db-section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-color, #e5e7eb);
    margin-bottom: 1.25rem;
  }
  .db-summary-badge {
    background-color: var(--bg-surface-secondary, #f3f4f6);
    border: 1px solid var(--border-color, #e5e7eb);
    padding: 0.4rem 0.8rem;
    border-radius: 6px;
    font-size: 0.85rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .badge-label {
    color: var(--text-muted, #6b7280);
  }
  .badge-value {
    font-weight: 700;
    color: var(--text-main, #111827);
  }

  /* Compact Table styling */
  .db-table-wrapper {
    overflow-x: auto;
    border: 1px solid var(--border-color, #e5e7eb);
    border-radius: 8px;
    background-color: var(--bg-surface, #ffffff);
    margin-bottom: 1.5rem;
  }
  .db-compact-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.85rem;
    text-align: left;
  }
  .db-compact-table th {
    background-color: var(--bg-surface-secondary, #f9fafb);
    padding: 0.65rem 1rem;
    font-weight: 600;
    color: var(--text-muted, #4b5563);
    border-bottom: 1px solid var(--border-color, #e5e7eb);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .db-compact-table td {
    padding: 0.65rem 1rem;
    border-bottom: 1px solid var(--border-color, #e5e7eb);
    color: var(--text-main, #1f2937);
  }
  .db-compact-table tr:last-child td {
    border-bottom: none;
  }
  .db-compact-table tr:hover td {
    background-color: var(--bg-hover, #f9fafb);
  }

  /* Table Name Column */
  .td-table-info {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .table-row-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 6px;
    background-color: var(--bg-surface-secondary, #f3f4f6);
    flex-shrink: 0;
  }
  .table-name-column {
    display: flex;
    flex-direction: column;
  }
  .table-friendly-name {
    font-weight: 600;
    color: var(--text-main, #111827);
  }
  .table-raw-name {
    font-family: var(--font-mono, monospace);
    font-size: 0.7rem;
    color: var(--text-muted, #9ca3af);
  }

  /* Compact badges */
  .segment-badge {
    display: inline-block;
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-size: 0.72rem;
    font-weight: 600;
  }
  .badge-core {
    background-color: #ecfdf5;
    color: #065f46;
    border: 1px solid #d1fae5;
  }
  .badge-admin {
    background-color: #eff6ff;
    color: #1e40af;
    border: 1px solid #dbeafe;
  }
  .badge-logs {
    background-color: #fffbeb;
    color: #92400e;
    border: 1px solid #fef3c7;
  }

  /* Ratio / Progress bar column */
  .ratio-cell {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    min-width: 140px;
  }
  .progress-bar-bg-compact {
    flex-grow: 1;
    height: 6px;
    background-color: var(--bg-surface-secondary, #e5e7eb);
    border-radius: 3px;
    overflow: hidden;
  }
  .progress-bar-fill-compact {
    height: 100%;
    border-radius: 3px;
    transition: width 0.3s ease;
  }
  .ratio-percent-text {
    font-size: 0.75rem;
    color: var(--text-muted, #6b7280);
    min-width: 32px;
    text-align: right;
    font-family: var(--font-mono, monospace);
  }

  /* Colors fill compact */
  .core-fill { background-color: var(--color-success, #10b981); }
  .admin-fill { background-color: var(--color-primary, #3b82f6); }
  .log-fill { background-color: var(--color-warning, #f59e0b); }
  .danger-fill { background-color: var(--color-danger, #ef4444); }

  /* Table actions */
  .table-action-cell {
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .action-buttons-row {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .btn-icon-action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.15s ease;
    border: 1px solid var(--border-color, #e5e7eb);
    background-color: transparent;
  }
  .btn-download {
