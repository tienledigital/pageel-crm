</style>

<script>
  const layout = document.querySelector('.settings-layout') as HTMLDivElement;
  const i18n = JSON.parse(layout?.getAttribute('data-i18n') || '{}');
  const lang = layout?.getAttribute('data-lang') || 'vi';

  function showToast(message: string, type: 'success' | 'error' = 'success') {
    const event = new CustomEvent('show-toast', { detail: { message, type } });
    window.dispatchEvent(event);
  }

  // Database optimize submit
  const optimizeDbBtn = document.getElementById('optimizeDbBtn') as HTMLButtonElement;
  const optSpinner = document.getElementById('optSpinner') as HTMLSpanElement;

  if (optimizeDbBtn) {
    optimizeDbBtn.addEventListener('click', async () => {
      optimizeDbBtn.disabled = true;
      if (optSpinner) optSpinner.style.display = 'inline-block';

      try {
        const res = await fetch('/api/settings/db-optimize', { method: 'POST' });
        const data = await res.json();
        if (res.ok && data.success) {
          showToast(i18n.dbOptimizeSuccess || 'Database optimized successfully!', 'success');
          setTimeout(() => window.location.reload(), 1200);
        } else {
          showToast(data.error || 'Optimization failed', 'error');
        }
      } catch (err: any) {
        showToast('Network error: ' + err.message, 'error');
      } finally {
        optimizeDbBtn.disabled = false;
        if (optSpinner) optSpinner.style.display = 'none';
      }
    });
  }

  // Database Cleaning Logic
  const dbClearModal = document.getElementById('dbClearModal') as HTMLDivElement;
  const modalTitle = document.getElementById('modalTitle') as HTMLHeadingElement;
  const modalDesc = document.getElementById('modalDesc') as HTMLSpanElement;
  const confirmClearBtn = document.getElementById('confirmClearBtn') as HTMLButtonElement;
  const cancelClearBtn = document.getElementById('cancelClearBtn') as HTMLButtonElement;
  const closeModalBtn = document.getElementById('closeModalBtn') as HTMLButtonElement;
  const clearSpinner = document.getElementById('clearSpinner') as HTMLSpanElement;

  let currentTargetTable = '';

  // Setup click triggers on all clean/clear buttons
  const clearButtons = document.querySelectorAll('.btn-clear-table');
  clearButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      const table = btn.getAttribute('data-table') || '';
      const count = parseInt(btn.getAttribute('data-count') || '0', 10);
      
      if (!table) return;
      currentTargetTable = table;

      // Populate Modal Content
      const confirmTitleTemplate = i18n.dbClearConfirmTitle || 'Xác nhận dọn dẹp bảng';
      
      modalTitle.innerText = `${confirmTitleTemplate}: ${table}`;
      
      // Calculate how many rows will be cleaned up
      const countToClean = count - 100;
      const cleanDescVi = `Hành động này sẽ dọn dẹp các dòng log cũ và chỉ giữ lại 100 dòng mới nhất. Sẽ có khoảng ${countToClean.toLocaleString()} dòng cũ bị xóa vĩnh viễn khỏi bảng "${table}". Bạn có chắc chắn muốn tiếp tục?`;
      const cleanDescEn = `This action will clean up older logs and only keep the 100 latest records. Approximately ${countToClean.toLocaleString()} older rows will be permanently deleted from table "${table}". Are you sure you want to continue?`;
      
      modalDesc.innerText = lang === 'vi' ? cleanDescVi : cleanDescEn;

      // Open Modal
      dbClearModal.classList.add('active');
    });
  });

  function closeModal() {
    dbClearModal.classList.remove('active');
    currentTargetTable = '';
    if (clearSpinner) clearSpinner.style.display = 'none';
    confirmClearBtn.disabled = false;
  }

  if (closeModalBtn) closeModalBtn.addEventListener('click', closeModal);
  if (cancelClearBtn) cancelClearBtn.addEventListener('click', closeModal);

  // Close modal when clicking outside
  if (dbClearModal) {
    dbClearModal.addEventListener('click', (e) => {
      if (e.target === dbClearModal) closeModal();
    });
  }

  // Handle Confirm Click
  if (confirmClearBtn) {
    confirmClearBtn.addEventListener('click', async () => {
      if (!currentTargetTable) return;

      confirmClearBtn.disabled = true;
      if (clearSpinner) clearSpinner.style.display = 'inline-block';

      try {
        const res = await fetch('/api/settings/db-clear-table', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ tableName: currentTargetTable })
        });
        const data = await res.json();
        
        if (res.ok && data.success) {
          const successMessage = (i18n.dbClearSuccess || 'Dọn dẹp dữ liệu bảng {table} thành công!')
            .replace('{table}', currentTargetTable);
          showToast(successMessage, 'success');
          setTimeout(() => window.location.reload(), 1200);
        } else {
          showToast(data.error || 'Failed to clean table', 'error');
          confirmClearBtn.disabled = false;
          if (clearSpinner) clearSpinner.style.display = 'none';
        }
      } catch (err: any) {
        showToast('Network error: ' + err.message, 'error');
        confirmClearBtn.disabled = false;
        if (clearSpinner) clearSpinner.style.display = 'none';
      }
    });
  }
</script>
