---
import { t } from '@/lib/i18n';

interface Props {
  lang: 'vi' | 'en';
  isAdmin: boolean;
  defaultBank: string;
  defaultAccount: string;
  serviceInvoiceContentTemplate: string;
  envStatus: {
    sepay: {
      webhookSecret: boolean;
      apiToken: boolean;
    };
    github: {
      token: boolean;
      owner: boolean;
      repo: boolean;
      branch: boolean;
    };
  };
}

const { lang, isAdmin, defaultBank, defaultAccount, serviceInvoiceContentTemplate, envStatus } = Astro.props;
---

<section id="integrations" class="settings-card tab-panel">
  <h2>{t('settings.integrations', lang)}</h2>
  <div class="card-body">
    <!-- SePay Integrations -->
    <div class="sub-section">
      <h3>{t('settings.sepay_api', lang)}</h3>
      <div class="status-grid">
        <div class="status-tile">
          <span>{t('settings.webhook_secret', lang)}</span>
          <span class={`status-badge ${envStatus.sepay.webhookSecret ? 'success' : 'warning'}`}>
            <span class="pulse-dot"></span>
            {envStatus.sepay.webhookSecret ? 'Configured' : 'Missing'}
          </span>
        </div>
        <div class="status-tile">
          <span>{t('settings.api_token', lang)}</span>
          <span class={`status-badge ${envStatus.sepay.apiToken ? 'success' : 'warning'}`}>
            <span class="pulse-dot"></span>
            {envStatus.sepay.apiToken ? 'Configured' : 'Missing'}
          </span>
        </div>
      </div>

      <div class="form-group mt-1 grid-2">
        <div>
          <label for="defaultBankSelect" class="form-label">{lang === 'vi' ? 'Ngân hàng mặc định' : 'Default Bank'}</label>
          <select id="defaultBankSelect" class="form-input">
            <option value="MB" selected={defaultBank === 'MB'}>MB (MBBank)</option>
            <option value="Techcombank" selected={defaultBank === 'Techcombank'}>Techcombank</option>
            <option value="Vietcombank" selected={defaultBank === 'Vietcombank'}>Vietcombank</option>
            <option value="ACB" selected={defaultBank === 'ACB'}>ACB</option>
            <option value="VPBank" selected={defaultBank === 'VPBank'}>VPBank</option>
            <option value="BIDV" selected={defaultBank === 'BIDV'}>BIDV</option>
            <option value="VietinBank" selected={defaultBank === 'VietinBank'}>VietinBank</option>
            <option value="TPBank" selected={defaultBank === 'TPBank'}>TPBank</option>
            <option value="Sacombank" selected={defaultBank === 'Sacombank'}>Sacombank</option>
            <option value="Agribank" selected={defaultBank === 'Agribank'}>Agribank</option>
            <option value="VIB" selected={defaultBank === 'VIB'}>VIB</option>
          </select>
        </div>
        <div>
          <label for="defaultAccountInput" class="form-label">{lang === 'vi' ? 'Số tài khoản mặc định' : 'Default Account Number'}</label>
          <input type="text" id="defaultAccountInput" class="form-input" value={defaultAccount} placeholder="e.g. 0399999999" />
        </div>
      </div>

      <div class="form-group mt-1">
        <label for="webhookDescTemplateInput" class="form-label">{t('settings.webhook_desc_template', lang)}</label>
        <input type="text" id="webhookDescTemplateInput" class="form-input" value={serviceInvoiceContentTemplate} placeholder="e.g. Auto webhook thanh toan dich vu {service_name}" />
        <small style="font-size: 0.75rem; color: var(--text-secondary); margin-top: 0.25rem; display: block;">
          {t('settings.webhook_desc_template_hint', lang)}
        </small>
      </div>
    </div>

    <div class="action-row border-top">
      <button id="saveIntegrationsBtn" class="btn-primary">
        <span class="spinner" id="integSpinner"></span>
        {t('settings.save', lang)}
      </button>
    </div>
  </div>
</section>

<script>
  const layout = document.querySelector('.settings-layout') as HTMLDivElement;
  const i18n = JSON.parse(layout?.getAttribute('data-i18n') || '{}');

  function showToast(message: string, type: 'success' | 'error' = 'success') {
    const event = new CustomEvent('show-toast', { detail: { message, type } });
    window.dispatchEvent(event);
  }

  // Save integrations submit
  const saveIntegrationsBtn = document.getElementById('saveIntegrationsBtn') as HTMLButtonElement;
  const integSpinner = document.getElementById('integSpinner') as HTMLSpanElement;

  if (saveIntegrationsBtn) {
    saveIntegrationsBtn.addEventListener('click', async () => {
      saveIntegrationsBtn.disabled = true;
      if (integSpinner) integSpinner.style.display = 'inline-block';

      try {
        const bankSelect = document.getElementById('defaultBankSelect') as HTMLSelectElement;
        const accountInput = document.getElementById('defaultAccountInput') as HTMLInputElement;
        const templateInput = document.getElementById('webhookDescTemplateInput') as HTMLInputElement;
        const bankVal = bankSelect ? bankSelect.value : 'MB';
        const accountVal = accountInput ? accountInput.value : '';
        const templateVal = templateInput ? templateInput.value : '';

        // Save defaultBank
        const bankRes = await fetch('/api/crm/config', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ key: 'defaultBank', value: bankVal })
        });
        if (!bankRes.ok) throw new Error('Bank brand configuration failed');

        // Save defaultAccount
        const accountRes = await fetch('/api/crm/config', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ key: 'defaultAccount', value: accountVal })
        });
        if (!accountRes.ok) throw new Error('Bank account number configuration failed');

        // Save serviceInvoiceContentTemplate
        const templateRes = await fetch('/api/crm/config', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ key: 'serviceInvoiceContentTemplate', value: templateVal })
        });
        if (!templateRes.ok) throw new Error('Auto webhook description template configuration failed');

        // Backward compatibility
        await fetch('/api/crm/config', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ key: 'default_bank_account', value: `${bankVal} - ${accountVal}` })
        });

        showToast(i18n.saveBankSuccess || 'Integrations updated successfully!', 'success');
        setTimeout(() => window.location.reload(), 1200);
      } catch (err: any) {
        showToast(err.message, 'error');
        saveIntegrationsBtn.disabled = false;
        if (integSpinner) integSpinner.style.display = 'none';
      }
    });
  }
</script>
