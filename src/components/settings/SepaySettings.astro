---
import { t } from '@/lib/i18n';

interface Props {
  lang: 'vi' | 'en';
  isAdmin: boolean;
  defaultBankAccount: string;
  envStatus: {
    sepay: {
      webhookSecret: boolean;
      apiToken: boolean;
    };
    github: {
      token: boolean;
      owner: boolean;
      repo: boolean;
      branch: boolean;
    };
  };
}

const { lang, isAdmin, defaultBankAccount, envStatus } = Astro.props;
---

<section id="integrations" class="settings-card tab-panel">
  <h2>{t('settings.integrations', lang)}</h2>
  <div class="card-body">
    <!-- SePay Integrations -->
    <div class="sub-section">
      <h3>{t('settings.sepay_api', lang)}</h3>
      <div class="status-grid">
        <div class="status-tile">
          <span>{t('settings.webhook_secret', lang)}</span>
          <span class={`status-badge ${envStatus.sepay.webhookSecret ? 'success' : 'warning'}`}>
            <span class="pulse-dot"></span>
            {envStatus.sepay.webhookSecret ? 'Configured' : 'Missing'}
          </span>
        </div>
        <div class="status-tile">
          <span>{t('settings.api_token', lang)}</span>
          <span class={`status-badge ${envStatus.sepay.apiToken ? 'success' : 'warning'}`}>
            <span class="pulse-dot"></span>
            {envStatus.sepay.apiToken ? 'Configured' : 'Missing'}
          </span>
        </div>
      </div>

      <div class="form-group mt-1">
        <label for="defaultBankInput" class="form-label">{t('settings.default_bank', lang)}</label>
        <input type="text" id="defaultBankInput" class="form-input" value={defaultBankAccount} placeholder="e.g. MB Bank - 123456789" />
      </div>
    </div>

    {isAdmin && (
      <!-- GitHub Backup -->
      <div class="sub-section border-top">
        <h3>{t('settings.github_backup', lang)}</h3>
        <div class="status-grid">
          <div class="status-tile">
            <span>Token</span>
            <span class={`status-badge ${envStatus.github.token ? 'success' : 'warning'}`}>
              <span class="pulse-dot"></span>
              {envStatus.github.token ? 'Configured' : 'Missing'}
            </span>
          </div>
          <div class="status-tile">
            <span>Repo Owner</span>
            <span class={`status-badge ${envStatus.github.owner ? 'success' : 'warning'}`}>
              <span class="pulse-dot"></span>
              {envStatus.github.owner ? 'Configured' : 'Missing'}
            </span>
          </div>
          <div class="status-tile">
            <span>Repository</span>
            <span class={`status-badge ${envStatus.github.repo ? 'success' : 'warning'}`}>
              <span class="pulse-dot"></span>
              {envStatus.github.repo ? 'Configured' : 'Missing'}
            </span>
          </div>
          <div class="status-tile">
            <span>Branch</span>
            <span class={`status-badge ${envStatus.github.branch ? 'success' : 'warning'}`}>
              <span class="pulse-dot"></span>
              {envStatus.github.branch ? 'Configured' : 'Missing'}
            </span>
          </div>
        </div>

        <div class="action-buttons-group">
          <button id="testGithubBtn" class="btn-secondary">
            <span class="spinner" id="testGitSpinner"></span>
            {t('settings.test_connection', lang)}
          </button>
          <button id="triggerBackupBtn" class="btn-accent">
            <span class="spinner" id="backupSpinner"></span>
            {t('settings.trigger_backup', lang)}
          </button>
        </div>
      </div>
    )}

    <div class="action-row border-top">
      <button id="saveIntegrationsBtn" class="btn-primary">
        <span class="spinner" id="integSpinner"></span>
        {t('settings.save', lang)}
      </button>
    </div>
  </div>
</section>

<script>
  const layout = document.querySelector('.settings-layout') as HTMLDivElement;
  const i18n = JSON.parse(layout?.getAttribute('data-i18n') || '{}');

  function showToast(message: string, type: 'success' | 'error' = 'success') {
    const event = new CustomEvent('show-toast', { detail: { message, type } });
    window.dispatchEvent(event);
  }

  // Save integrations submit
  const saveIntegrationsBtn = document.getElementById('saveIntegrationsBtn') as HTMLButtonElement;
  const integSpinner = document.getElementById('integSpinner') as HTMLSpanElement;

  if (saveIntegrationsBtn) {
    saveIntegrationsBtn.addEventListener('click', async () => {
      saveIntegrationsBtn.disabled = true;
      if (integSpinner) integSpinner.style.display = 'inline-block';

      try {
        const bankInput = document.getElementById('defaultBankInput') as HTMLInputElement;
        const bankVal = bankInput ? bankInput.value : '';
        const bankRes = await fetch('/api/crm/config', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ key: 'default_bank_account', value: bankVal })
        });
        if (!bankRes.ok) throw new Error('Bank account configuration failed');

        showToast(i18n.saveBankSuccess || 'Integrations updated successfully!', 'success');
        setTimeout(() => window.location.reload(), 1200);
      } catch (err: any) {
        showToast(err.message, 'error');
        saveIntegrationsBtn.disabled = false;
        if (integSpinner) integSpinner.style.display = 'none';
      }
    });
  }

  // GitHub backup triggers
  const testGithubBtn = document.getElementById('testGithubBtn') as HTMLButtonElement;
  const testGitSpinner = document.getElementById('testGitSpinner') as HTMLSpanElement;
  if (testGithubBtn) {
    testGithubBtn.addEventListener('click', async () => {
      testGithubBtn.disabled = true;
      if (testGitSpinner) testGitSpinner.style.display = 'inline-block';

      try {
        const res = await fetch('/api/backup/test-connection', { method: 'POST' });
        const data = await res.json();
        if (res.ok && data.success) {
          showToast(i18n.githubTestSuccess || 'GitHub connection working!', 'success');
        } else {
          showToast(data.error || 'Connection failed', 'error');
        }
      } catch (err: any) {
        showToast('Network error: ' + err.message, 'error');
      } finally {
        testGithubBtn.disabled = false;
        if (testGitSpinner) testGitSpinner.style.display = 'none';
      }
    });
  }

  const triggerBackupBtn = document.getElementById('triggerBackupBtn') as HTMLButtonElement;
  const backupSpinner = document.getElementById('backupSpinner') as HTMLSpanElement;
  if (triggerBackupBtn) {
    triggerBackupBtn.addEventListener('click', async () => {
      if (!confirm(i18n.githubBackupConfirm || 'Are you sure you want to trigger GitHub backup now?')) return;
      triggerBackupBtn.disabled = true;
      if (backupSpinner) backupSpinner.style.display = 'inline-block';

      try {
        const res = await fetch('/api/backup', { method: 'POST' });
        const data = await res.json();
        if (res.ok && data.success) {
          showToast(i18n.githubBackupSuccess || 'Backup successfully completed!', 'success');
          setTimeout(() => window.location.reload(), 1200);
        } else {
          showToast(data.error || 'Backup failed', 'error');
        }
      } catch (err: any) {
        showToast('Network error: ' + err.message, 'error');
      } finally {
        triggerBackupBtn.disabled = false;
        if (backupSpinner) backupSpinner.style.display = 'none';
      }
    });
  }
</script>
