---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import { env } from 'cloudflare:workers';
import { getDb } from '@/lib/db';
import { orders, customers, staff } from '@/lib/db/schema';
import { desc, eq, like, and, or, sql } from 'drizzle-orm';

const db = getDb(env);
const lang = Astro.locals.lang || 'vi';
const user = Astro.locals.user;

// 1. Parse query parameters
const url = new URL(Astro.request.url);
const search = url.searchParams.get('search') || '';
const statusFilter = url.searchParams.get('status') || ''; // 'paid', 'pending', 'partially_paid', 'cancelled'

// 2. Build where clause
const conditions = [];

if (search) {
  conditions.push(
    or(
      like(orders.orderNumber, `%${search}%`),
      like(orders.content, `%${search}%`),
      like(customers.fullName, `%${search}%`)
    )
  );
}

if (statusFilter) {
  conditions.push(eq(orders.status, statusFilter));
}

const whereClause = conditions.length > 0 ? and(...conditions) : undefined;

// 3. Query orders
const orderList = await db
  .select({
    id: orders.id,
    orderNumber: orders.orderNumber,
    amount: orders.amount,
    content: orders.content,
    status: orders.status,
    createdAt: orders.createdAt,
    paidAt: orders.paidAt,
    customerName: customers.fullName,
    customerId: customers.id,
    staffName: staff.fullName,
  })
  .from(orders)
  .leftJoin(customers, eq(orders.customerId, customers.id))
  .leftJoin(staff, eq(orders.staffId, staff.id))
  .where(whereClause)
  .orderBy(desc(orders.createdAt));

// 4. Calculate Order Metrics
const stats = await db
  .select({
    status: orders.status,
    totalAmount: sql<number>`SUM(${orders.amount})`,
    count: sql<number>`COUNT(${orders.id})`,
  })
  .from(orders)
  .groupBy(orders.status);

let totalInvoiced = 0;
let totalCollected = 0;
let pendingCollected = 0;
let countPaid = 0;
let countPending = 0;
let countPartial = 0;

stats.forEach((stat: any) => {
  const amt = Number(stat.totalAmount || 0);
  const cnt = Number(stat.count || 0);
  totalInvoiced += amt;
  
  if (stat.status === 'paid') {
    totalCollected += amt;
    countPaid = cnt;
  } else if (stat.status === 'pending') {
    pendingCollected += amt;
    countPending = cnt;
  } else if (stat.status === 'partially_paid') {
    pendingCollected += amt;
    countPartial = cnt;
  }
});

function formatVND(amount: number) {
  return new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(amount);
}

function formatDate(timestamp: number | null) {
  if (!timestamp) return 'N/A';
  return new Date(timestamp).toLocaleDateString('vi-VN', {
    timeZone: 'Asia/Ho_Chi_Minh',
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  });
}
---

<DashboardLayout title={lang === 'vi' ? 'Quản lý Đơn hàng' : 'Orders Management'}>
  <style>
    .header-container {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 2rem;
      flex-wrap: wrap;
      gap: 1rem;
    }

    .title-section h1 {
      font-size: 1.75rem;
      font-weight: 700;
      color: var(--text-primary);
    }

    .title-section p {
      font-size: 0.875rem;
      color: var(--text-secondary);
      margin-top: 0.25rem;
    }

    /* Stats Grid */
    .stats-banner {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 1.5rem;
      margin-bottom: 2rem;
    }

    .stat-card {
      background-color: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: 16px;
      padding: 1.5rem;
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .stat-icon {
      width: 48px;
      height: 48px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .stat-icon.invoiced {
      background-color: rgba(99, 102, 241, 0.1);
      color: var(--primary);
    }

    .stat-icon.collected {
      background-color: rgba(16, 185, 129, 0.1);
      color: var(--success);
    }

    .stat-icon.pending {
      background-color: rgba(245, 158, 11, 0.1);
      color: #f59e0b;
    }

    .stat-details {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }

    .stat-label {
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .stat-value {
      font-size: 1.35rem;
      font-weight: 700;
      color: var(--text-primary);
    }

    /* Filter Bar */
    .filter-bar {
      display: flex;
      gap: 1rem;
      margin-bottom: 1.5rem;
      flex-wrap: wrap;
    }

    .search-input {
      flex-grow: 1;
      min-width: 240px;
      background-color: var(--bg-card);
      border: 1px solid var(--border-color);
      color: var(--text-primary);
      padding: 0.65rem 1rem;
      border-radius: 8px;
      font-size: 0.875rem;
      outline: none;
      transition: border-color 0.2s;
    }

    .search-input:focus {
      border-color: var(--primary);
    }

    .select-filter {
      background-color: var(--bg-card);
      border: 1px solid var(--border-color);
      color: var(--text-primary);
      padding: 0.65rem 1rem;
      border-radius: 8px;
      font-size: 0.875rem;
      outline: none;
      cursor: pointer;
    }

    .btn-filter {
      background-color: var(--primary);
      border: 1px solid var(--primary);
      color: #fff;
      padding: 0.65rem 1.25rem;
      border-radius: 8px;
      font-size: 0.875rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
    }

    .btn-filter:hover {
      box-shadow: 0 4px 12px rgba(99, 102, 241, 0.2);
    }

    /* Main Table Panel */
    .card-container {
      background-color: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: 16px;
      padding: 1.5rem;
      overflow: hidden;
    }

    .table-responsive {
      overflow-x: auto;
    }

    .custom-table {
      width: 100%;
      border-collapse: collapse;
      text-align: left;
    }

    .custom-table th {
      padding: 1rem;
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      border-bottom: 1px solid var(--border-color);
    }

    .custom-table td {
      padding: 1.15rem 1rem;
      font-size: 0.875rem;
      border-bottom: 1px solid var(--border-color);
      color: var(--text-primary);
      vertical-align: middle;
    }

    .custom-table tr:last-child td {
      border-bottom: none;
    }

    /* Badges */
    .badge {
      display: inline-flex;
      align-items: center;
      padding: 0.25rem 0.6rem;
      border-radius: 9999px;
      font-size: 0.75rem;
      font-weight: 600;
    }

    .badge-paid {
      background-color: rgba(16, 185, 129, 0.1);
      color: var(--success);
      border: 1px solid rgba(16, 185, 129, 0.2);
    }

    .badge-pending {
      background-color: rgba(239, 68, 68, 0.1);
      color: var(--error);
      border: 1px solid rgba(239, 68, 68, 0.2);
    }

    .badge-partially_paid {
      background-color: rgba(245, 158, 11, 0.1);
      color: #f59e0b;
      border: 1px solid rgba(245, 158, 11, 0.2);
    }

    .badge-cancelled {
      background-color: rgba(107, 114, 128, 0.1);
      color: var(--text-secondary);
      border: 1px solid rgba(107, 114, 128, 0.2);
    }

    .mono {
      font-family: monospace;
      color: var(--text-primary);
    }

    .btn-action {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      padding: 0.45rem 0.75rem;
      background-color: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: 6px;
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--text-primary);
      cursor: pointer;
      transition: all 0.2s;
      text-decoration: none;
    }

    .btn-action:hover {
      background-color: var(--primary);
      border-color: var(--primary);
      color: #fff;
    }

    .btn-reset {
      background-color: transparent;
      border: 1px solid var(--border-color);
      color: var(--text-secondary);
      padding: 0.65rem 1.25rem;
      border-radius: 8px;
      font-size: 0.875rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
      text-decoration: none;
    }

    .btn-reset:hover {
      background-color: var(--bg-hover);
      color: var(--text-primary);
    }

    /* Mobile Card Layout Styles */
    .mobile-card-grid {
      display: none;
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .mobile-card {
      background-color: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.25rem;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      position: relative;
    }

    .mobile-card-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 0.75rem;
    }

    .mobile-card-body {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      font-size: 0.875rem;
      color: var(--text-primary);
    }

    .mobile-card-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .mobile-card-label {
      font-size: 0.75rem;
      color: var(--text-secondary);
      font-weight: 500;
    }

    .mobile-card-value {
      font-weight: 500;
    }

    .mobile-card-footer {
      border-top: 1px solid var(--border-color);
      padding-top: 0.75rem;
      display: flex;
      justify-content: flex-end;
    }

    @media (max-width: 768px) {
      .table-responsive {
        display: none;
      }
      .mobile-card-grid {
        display: grid;
      }
      .card-container {
        padding: 0.75rem;
      }
    }
  </style>

  <div class="header-container">
    <div class="title-section">
      <h1>{lang === 'vi' ? 'Quản lý Đơn hàng' : 'Orders Management'}</h1>
      <p>{lang === 'vi' ? 'Xem danh sách các đơn hàng được tạo tự động bởi hệ thống' : 'View automatic orders generated by system'}</p>
    </div>
  </div>

  <!-- Stats Grid -->
  <div class="stats-banner">
    <!-- Total Invoiced -->
    <div class="stat-card">
      <div class="stat-icon invoiced">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 24px; height: 24px;">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375 3.375 0 11-.75 0 .375 3.375 0 01.75 0zm7.5 0a.375 3.375 0 11-.75 0 .375 3.375 0 01.75 0z" />
        </svg>
      </div>
      <div class="stat-details">
        <span class="stat-label">{lang === 'vi' ? 'Tổng giá trị đơn hàng' : 'Total Order Value'}</span>
        <span class="stat-value">{formatVND(totalInvoiced)}</span>
        <span style="font-size: 0.75rem; color: var(--text-secondary);">{lang === 'vi' ? `Từ ${orderList.length} đơn hàng` : `From ${orderList.length} orders`}</span>
      </div>
    </div>

    <!-- Collected -->
    <div class="stat-card">
      <div class="stat-icon collected">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 24px; height: 24px;">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
      <div class="stat-details">
        <span class="stat-label">{lang === 'vi' ? 'Đã thanh toán' : 'Collected'}</span>
        <span class="stat-value" style="color: var(--success);">{formatVND(totalCollected)}</span>
        <span style="font-size: 0.75rem; color: var(--text-secondary);">{lang === 'vi' ? `${countPaid} đơn hàng hoàn tất` : `${countPaid} completed orders`}</span>
      </div>
    </div>

    <!-- Outstanding (Pending + Partially Paid) -->
    <div class="stat-card">
      <div class="stat-icon pending">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 24px; height: 24px;">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
      <div class="stat-details">
        <span class="stat-label">{lang === 'vi' ? 'Chưa hoàn tất / nợ' : 'Outstanding'}</span>
        <span class="stat-value" style="color: #f59e0b;">{formatVND(pendingCollected)}</span>
        <span style="font-size: 0.75rem; color: var(--text-secondary);">{lang === 'vi' ? `${countPending} chờ thanh toán, ${countPartial} một phần` : `${countPending} pending, ${countPartial} partial`}</span>
      </div>
    </div>
  </div>

  <!-- Filters -->
  <form method="GET" class="filter-bar">
    <input 
      type="text" 
      name="search" 
      placeholder={lang === 'vi' ? 'Tìm kiếm theo mã đơn hàng, nội dung hoặc khách hàng...' : 'Search by order number, content, or customer...'} 
      value={search} 
      class="search-input" 
    />
    <select name="status" class="select-filter">
      <option value="">{lang === 'vi' ? 'Tất cả trạng thái' : 'All Statuses'}</option>
      <option value="paid" selected={statusFilter === 'paid'}>{lang === 'vi' ? 'Đã thanh toán (Paid)' : 'Paid'}</option>
      <option value="partially_paid" selected={statusFilter === 'partially_paid'}>{lang === 'vi' ? 'Thanh toán một phần (Partial)' : 'Partially Paid'}</option>
      <option value="pending" selected={statusFilter === 'pending'}>{lang === 'vi' ? 'Chưa thanh toán (Pending)' : 'Pending'}</option>
      <option value="cancelled" selected={statusFilter === 'cancelled'}>{lang === 'vi' ? 'Đã hủy (Cancelled)' : 'Cancelled'}</option>
    </select>
    <button type="submit" class="btn-filter">{lang === 'vi' ? 'Lọc đơn hàng' : 'Apply Filters'}</button>
    {(search || statusFilter) && (
      <a href="/crm/orders" class="btn-reset">{lang === 'vi' ? 'Đặt lại' : 'Reset'}</a>
    )}
  </form>

  <!-- Table -->
  <div class="card-container">
    <!-- Desktop Table View -->
    <div class="table-responsive table-scroll-container">
      <table class="custom-table">
        <thead>
          <tr>
            <th>{lang === 'vi' ? 'Mã đơn hàng' : 'Order Number'}</th>
            <th>{lang === 'vi' ? 'Khách hàng' : 'Customer'}</th>
            <th>{lang === 'vi' ? 'Mô tả / Nội dung' : 'Description'}</th>
            <th>{lang === 'vi' ? 'Số tiền' : 'Amount'}</th>
            <th>{lang === 'vi' ? 'Trạng thái' : 'Status'}</th>
            <th>{lang === 'vi' ? 'Ngày phát hành' : 'Issued Date'}</th>
            <th>{lang === 'vi' ? 'Thao tác' : 'Actions'}</th>
          </tr>
        </thead>
        <tbody>
          {orderList.length === 0 ? (
            <tr>
              <td colspan="7" style="text-align: center; padding: 3rem; color: var(--text-secondary);">
                {lang === 'vi' ? 'Không có đơn hàng nào khớp với điều kiện tìm kiếm.' : 'No orders matching the criteria.'}
              </td>
            </tr>
          ) : (
            orderList.map((order: any) => (
              <tr>
                <td>
                  <span class="mono" style="font-weight: 600;">{order.orderNumber}</span>
                </td>
                <td>
                  {order.customerName ? (
                    <a href={`/crm/customers?search=${order.customerName}`} style="color: var(--primary); font-weight: 500; text-decoration: none;">
                      {order.customerName}
                    </a>
                  ) : (
                    <span style="color: var(--text-secondary);">N/A</span>
                  )}
                </td>
                <td>
                  <div>
                    <span>{order.content}</span>
                    <div style="font-size: 0.75rem; color: var(--text-secondary); margin-top: 0.15rem;">
                      {lang === 'vi' ? 'Nhân sự' : 'Staff'}: {order.staffName || (lang === 'vi' ? 'Hệ thống' : 'System')}
                    </div>
                  </div>
                </td>
                <td>
                  <span style="font-weight: 600; color: var(--text-primary);">{formatVND(order.amount)}</span>
                </td>
                <td>
                  <span class={`badge badge-${order.status}`}>
                    {order.status === 'paid' && (lang === 'vi' ? 'Đã thanh toán' : 'Paid')}
                    {order.status === 'partially_paid' && (lang === 'vi' ? 'Thanh toán một phần' : 'Partially Paid')}
                    {order.status === 'pending' && (lang === 'vi' ? 'Chưa thanh toán' : 'Pending')}
                    {order.status === 'cancelled' && (lang === 'vi' ? 'Đã hủy' : 'Cancelled')}
                  </span>
                </td>
                <td>
                  <span>{formatDate(order.createdAt)}</span>
                </td>
                <td>
                  <a href={`/crm/qr-tool?orderId=${order.id}`} class="btn-action">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 14px; height: 14px;">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5A1.125 1.125 0 013.75 9.375v-4.5zM3.75 14.625c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5a1.125 1.125 0 01-1.125-1.125v-4.5zM13.5 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5A1.125 1.125 0 0113.5 9.375v-4.5zM6.75 6.75h.75v.75h-.75v-.75zM6.75 16.5h.75v.75h-.75v-.75zM16.5 6.75h.75v.75h-.75v-.75zM13.5 13.5h.75v.75h-.75v-.75zM16.5 16.5h.75v.75h-.75v-.75zM13.5 16.5h.75v.75h-.75v-.75zM16.5 13.5h.75v.75h-.75v-.75z" />
                    </svg>
                    {lang === 'vi' ? 'Thanh toán QR' : 'Pay QR'}
                  </a>
                </td>
              </tr>
            ))
          )}
        </tbody>
      </table>
    </div>

    <!-- Mobile Card View -->
    <div class="mobile-card-grid">
      {orderList.length === 0 ? (
        <div style="text-align: center; padding: 2rem; color: var(--text-secondary);">
          {lang === 'vi' ? 'Không có đơn hàng nào khớp với điều kiện tìm kiếm.' : 'No orders matching the criteria.'}
        </div>
      ) : (
        orderList.map((order: any) => (
          <div class="mobile-card">
            <div class="mobile-card-header">
              <div style="display: flex; flex-direction: column; gap: 0.25rem;">
                <span class="mono" style="font-weight: 600; color: var(--text-primary);">{order.orderNumber}</span>
                {order.customerName ? (
                  <a href={`/crm/customers?search=${order.customerName}`} style="color: var(--primary); font-weight: 500; font-size: 0.875rem; text-decoration: none;">
                    {order.customerName}
                  </a>
                ) : (
                  <span style="color: var(--text-secondary); font-size: 0.875rem;">N/A</span>
                )}
              </div>
              <span class={`badge badge-${order.status}`}>
                {order.status === 'paid' && (lang === 'vi' ? 'Đã thanh toán' : 'Paid')}
                {order.status === 'partially_paid' && (lang === 'vi' ? 'Thanh toán một phần' : 'Partially Paid')}
                {order.status === 'pending' && (lang === 'vi' ? 'Chưa thanh toán' : 'Pending')}
                {order.status === 'cancelled' && (lang === 'vi' ? 'Đã hủy' : 'Cancelled')}
              </span>
            </div>
            
            <div class="mobile-card-body">
              <div class="mobile-card-row">
                <span class="mobile-card-label">{lang === 'vi' ? 'Mô tả / Nội dung' : 'Description'}</span>
                <span class="mobile-card-value" style="text-align: right;">{order.content}</span>
              </div>
              <div class="mobile-card-row">
                <span class="mobile-card-label">{lang === 'vi' ? 'Số tiền' : 'Amount'}</span>
                <span class="mobile-card-value" style="font-weight: 600; color: var(--text-primary);">{formatVND(order.amount)}</span>
              </div>
              <div class="mobile-card-row">
                <span class="mobile-card-label">{lang === 'vi' ? 'Ngày phát hành' : 'Issued Date'}</span>
                <span class="mobile-card-value">{formatDate(order.createdAt)}</span>
              </div>
              <div class="mobile-card-row">
                <span class="mobile-card-label">{lang === 'vi' ? 'Nhân sự' : 'Staff'}</span>
                <span class="mobile-card-value" style="font-size: 0.75rem; color: var(--text-secondary);">{order.staffName || (lang === 'vi' ? 'Hệ thống' : 'System')}</span>
              </div>
            </div>

            <div class="mobile-card-footer" style="width: 100%;">
              <a href={`/crm/qr-tool?orderId=${order.id}`} class="btn-action" style="width: 100%; justify-content: center;">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 14px; height: 14px;">
