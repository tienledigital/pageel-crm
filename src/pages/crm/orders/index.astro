---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import { env } from 'cloudflare:workers';
import { getDb } from '@/lib/db';
import { orders, customers, staff, services } from '@/lib/db/schema';
import { desc, eq, like, and, or, sql } from 'drizzle-orm';

const db = getDb(env);
const lang = Astro.locals.lang || 'vi';
const user = Astro.locals.user;

// Fetch list of customers and services for quick create order modal
const customersList = await db.select({
  id: customers.id,
  fullName: customers.fullName,
  phone: customers.phone,
}).from(customers).all();

const servicesList = await db.select({
  id: services.id,
  name: services.name,
  price: services.price,
  prefix: services.prefix,
  billingCycle: services.billingCycle,
}).from(services).where(eq(services.status, 'active')).all();

// 1. Parse query parameters
const url = new URL(Astro.request.url);
const search = url.searchParams.get('search') || '';
const statusFilter = url.searchParams.get('status') || ''; // 'paid', 'pending', 'partially_paid', 'cancelled'

// 2. Build where clause
const conditions = [];

if (search) {
  conditions.push(
    or(
      like(orders.orderNumber, `%${search}%`),
      like(orders.content, `%${search}%`),
      like(customers.fullName, `%${search}%`)
    )
  );
}

if (statusFilter) {
  conditions.push(eq(orders.status, statusFilter));
}

const whereClause = conditions.length > 0 ? and(...conditions) : undefined;

// 3. Query orders
const orderList = await db
  .select({
    id: orders.id,
    orderNumber: orders.orderNumber,
    amount: orders.amount,
    content: orders.content,
    status: orders.status,
    createdAt: orders.createdAt,
    paidAt: orders.paidAt,
    customerName: customers.fullName,
    customerId: customers.id,
    staffName: staff.fullName,
    serviceId: orders.serviceId,
    startDate: orders.startDate,
    expiredAt: orders.expiredAt,
  })
  .from(orders)
  .leftJoin(customers, eq(orders.customerId, customers.id))
  .leftJoin(staff, eq(orders.staffId, staff.id))
  .where(whereClause)
  .orderBy(desc(orders.createdAt));

// 4. Calculate Order Metrics
const stats = await db
  .select({
    status: orders.status,
    totalAmount: sql<number>`SUM(${orders.amount})`,
    count: sql<number>`COUNT(${orders.id})`,
  })
  .from(orders)
  .groupBy(orders.status);

let totalInvoiced = 0;
let totalCollected = 0;
let pendingCollected = 0;
let countPaid = 0;
let countPending = 0;
let countPartial = 0;

stats.forEach((stat: any) => {
  const amt = Number(stat.totalAmount || 0);
  const cnt = Number(stat.count || 0);
  totalInvoiced += amt;
  
  if (stat.status === 'paid') {
    totalCollected += amt;
    countPaid = cnt;
  } else if (stat.status === 'pending') {
    pendingCollected += amt;
    countPending = cnt;
  } else if (stat.status === 'partially_paid') {
    pendingCollected += amt;
    countPartial = cnt;
  }
});

function formatVND(amount: number) {
  return new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(amount);
}

function formatDate(timestamp: number | null) {
  if (!timestamp) return 'N/A';
  return new Date(timestamp).toLocaleDateString('vi-VN', {
    timeZone: 'Asia/Ho_Chi_Minh',
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  });
}
---

<DashboardLayout title={lang === 'vi' ? 'Quản lý Đơn hàng' : 'Orders Management'}>
  <style>
    .header-container {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 2rem;
      flex-wrap: wrap;
      gap: 1rem;
    }

    .title-section h1 {
      font-size: 1.75rem;
      font-weight: 700;
      color: var(--text-primary);
    }

    .title-section p {
      font-size: 0.875rem;
      color: var(--text-secondary);
      margin-top: 0.25rem;
    }

    /* Stats Grid */
    .stats-banner {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 1.5rem;
      margin-bottom: 2rem;
    }

    .stat-card {
      background-color: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: 16px;
      padding: 1.5rem;
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .stat-icon {
      width: 48px;
      height: 48px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .stat-icon.invoiced {
      background-color: rgba(99, 102, 241, 0.1);
      color: var(--primary);
    }

    .stat-icon.collected {
      background-color: rgba(16, 185, 129, 0.1);
      color: var(--success);
    }

    .stat-icon.pending {
      background-color: rgba(245, 158, 11, 0.1);
      color: #f59e0b;
    }

    .stat-details {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }

    .stat-label {
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .stat-value {
      font-size: 1.35rem;
      font-weight: 700;
      color: var(--text-primary);
    }

    /* Filter Bar */
    .filter-bar {
      display: flex;
      gap: 1rem;
      margin-bottom: 1.5rem;
      flex-wrap: wrap;
    }

    .search-input {
      flex-grow: 1;
      min-width: 240px;
      background-color: var(--bg-card);
      border: 1px solid var(--border-color);
      color: var(--text-primary);
      padding: 0.65rem 1rem;
      border-radius: 8px;
      font-size: 0.875rem;
      outline: none;
      transition: border-color 0.2s;
    }

    .search-input:focus {
      border-color: var(--primary);
    }

    .select-filter {
      background-color: var(--bg-card);
      border: 1px solid var(--border-color);
      color: var(--text-primary);
      padding: 0.65rem 1rem;
      border-radius: 8px;
      font-size: 0.875rem;
      outline: none;
      cursor: pointer;
    }

    .btn-filter {
      background-color: var(--primary);
      border: 1px solid var(--primary);
      color: #fff;
      padding: 0.65rem 1.25rem;
      border-radius: 8px;
      font-size: 0.875rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
    }

    .btn-filter:hover {
      box-shadow: 0 4px 12px rgba(99, 102, 241, 0.2);
    }

    /* Main Table Panel */
    .card-container {
      background-color: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: 16px;
      padding: 1.5rem;
      overflow: hidden;
    }

    .table-responsive {
      overflow-x: auto;
    }

    .custom-table {
      width: 100%;
      border-collapse: collapse;
      text-align: left;
    }

    .custom-table th {
      padding: 1rem;
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      border-bottom: 1px solid var(--border-color);
    }

    .custom-table td {
      padding: 1.15rem 1rem;
      font-size: 0.875rem;
      border-bottom: 1px solid var(--border-color);
      color: var(--text-primary);
      vertical-align: middle;
    }

    .custom-table tr:last-child td {
      border-bottom: none;
    }

    /* Badges */
    .badge {
      display: inline-flex;
      align-items: center;
      padding: 0.25rem 0.6rem;
      border-radius: 9999px;
      font-size: 0.75rem;
      font-weight: 600;
    }

    .badge-paid {
      background-color: rgba(16, 185, 129, 0.1);
      color: var(--success);
      border: 1px solid rgba(16, 185, 129, 0.2);
    }

    .badge-pending {
      background-color: rgba(239, 68, 68, 0.1);
      color: var(--error);
      border: 1px solid rgba(239, 68, 68, 0.2);
    }

    .badge-partially_paid {
      background-color: rgba(245, 158, 11, 0.1);
      color: #f59e0b;
      border: 1px solid rgba(245, 158, 11, 0.2);
    }

    .badge-cancelled {
      background-color: rgba(107, 114, 128, 0.1);
      color: var(--text-secondary);
      border: 1px solid rgba(107, 114, 128, 0.2);
    }

    .mono {
      font-family: monospace;
      color: var(--text-primary);
    }

    .btn-action {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      padding: 0.45rem 0.75rem;
      background-color: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: 6px;
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--text-primary);
      cursor: pointer;
      transition: all 0.2s;
      text-decoration: none;
    }

    .btn-action:hover {
      background-color: var(--primary);
      border-color: var(--primary);
      color: #fff;
    }

    .btn-reset {
      background-color: transparent;
      border: 1px solid var(--border-color);
      color: var(--text-secondary);
      padding: 0.65rem 1.25rem;
      border-radius: 8px;
      font-size: 0.875rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
      text-decoration: none;
    }

    .btn-reset:hover {
      background-color: var(--bg-hover);
      color: var(--text-primary);
    }

    /* Mobile Card Layout Styles */
    .mobile-card-grid {
      display: none;
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .mobile-card {
      background-color: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.25rem;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      position: relative;
    }

    .mobile-card-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 0.75rem;
    }

    .mobile-card-body {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      font-size: 0.875rem;
      color: var(--text-primary);
    }

    .mobile-card-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .mobile-card-label {
      font-size: 0.75rem;
      color: var(--text-secondary);
      font-weight: 500;
    }

    .mobile-card-value {
      font-weight: 500;
    }

    .mobile-card-footer {
      border-top: 1px solid var(--border-color);
      padding-top: 0.75rem;
      display: flex;
      justify-content: flex-end;
    }

    @media (max-width: 768px) {
      .table-responsive {
        display: none;
      }
      .mobile-card-grid {
        display: grid;
      }
      .card-container {
        padding: 0.75rem;
      }
    }

    /* Modal Styles */
    .modal-backdrop {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background-color: rgba(0, 0, 0, 0.6);
      backdrop-filter: blur(4px);
      z-index: 1000;
      justify-content: center;
      align-items: center;
    }

    .modal-content {
      background-color: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: 16px;
      padding: 2rem;
      width: 100%;
      max-width: 500px;
      box-shadow: 0 10px 25px rgba(0,0,0,0.5);
      animation: scale-up 0.2s ease-out;
    }

    @keyframes scale-up {
      from { transform: scale(0.95); opacity: 0; }
      to { transform: scale(1); opacity: 1; }
    }

    .modal-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1.5rem;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 0.75rem;
    }

    .modal-header h3 {
      font-size: 1.25rem;
      font-weight: 700;
      color: var(--text-primary);
      margin: 0;
    }

    .modal-close {
      background: none;
      border: none;
      color: var(--text-secondary);
      font-size: 1.5rem;
      cursor: pointer;
      padding: 0;
      line-height: 1;
    }

    .modal-close:hover {
      color: var(--text-primary);
    }

    .form-group {
      margin-bottom: 1.25rem;
    }

    .form-group label {
      display: block;
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--text-secondary);
      text-transform: uppercase;
      margin-bottom: 0.5rem;
      letter-spacing: 0.5px;
    }

    .form-select, .form-input {
      width: 100%;
      background-color: var(--bg-hover);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      color: var(--text-primary);
      padding: 0.65rem 0.85rem;
      font-size: 0.875rem;
      outline: none;
      transition: border-color 0.2s;
    }

    .form-select:focus, .form-input:focus {
      border-color: var(--primary);
    }

    .modal-footer {
      display: flex;
      justify-content: flex-end;
      gap: 1rem;
      margin-top: 2rem;
    }

    .btn-cancel {
      background-color: transparent;
      border: 1px solid var(--border-color);
      color: var(--text-secondary);
      padding: 0.65rem 1.25rem;
      border-radius: 8px;
      font-size: 0.875rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
    }

    .btn-cancel:hover {
      background-color: var(--bg-hover);
      color: var(--text-primary);
    }
  </style>

  <div class="header-container">
    <div class="title-section">
      <h1>{lang === 'vi' ? 'Quản lý Đơn hàng' : 'Orders Management'}</h1>
      <p>{lang === 'vi' ? 'Xem danh sách các đơn hàng được tạo tự động bởi hệ thống' : 'View automatic orders generated by system'}</p>
    </div>
    {(user?.role === 'admin' || user?.role === 'accountant') && (
      <button id="openQuickOrderModalBtn" class="btn-filter" style="display: inline-flex; align-items: center; gap: 0.5rem;">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 18px; height: 18px;">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
        </svg>
        {lang === 'vi' ? 'Tạo nhanh đơn hàng' : 'Quick Create Order'}
      </button>
    )}
  </div>

  <!-- Stats Grid -->
  <div class="stats-banner">
    <!-- Total Invoiced -->
    <div class="stat-card">
      <div class="stat-icon invoiced">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 24px; height: 24px;">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375 3.375 0 11-.75 0 .375 3.375 0 01.75 0zm7.5 0a.375 3.375 0 11-.75 0 .375 3.375 0 01.75 0z" />
        </svg>
      </div>
      <div class="stat-details">
        <span class="stat-label">{lang === 'vi' ? 'Tổng giá trị đơn hàng' : 'Total Order Value'}</span>
        <span class="stat-value">{formatVND(totalInvoiced)}</span>
        <span style="font-size: 0.75rem; color: var(--text-secondary);">{lang === 'vi' ? `Từ ${orderList.length} đơn hàng` : `From ${orderList.length} orders`}</span>
      </div>
    </div>

    <!-- Collected -->
    <div class="stat-card">
      <div class="stat-icon collected">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 24px; height: 24px;">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
      <div class="stat-details">
        <span class="stat-label">{lang === 'vi' ? 'Đã thanh toán' : 'Collected'}</span>
        <span class="stat-value" style="color: var(--success);">{formatVND(totalCollected)}</span>
        <span style="font-size: 0.75rem; color: var(--text-secondary);">{lang === 'vi' ? `${countPaid} đơn hàng hoàn tất` : `${countPaid} completed orders`}</span>
      </div>
    </div>

    <!-- Outstanding (Pending + Partially Paid) -->
    <div class="stat-card">
      <div class="stat-icon pending">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 24px; height: 24px;">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
      <div class="stat-details">
        <span class="stat-label">{lang === 'vi' ? 'Chưa hoàn tất / nợ' : 'Outstanding'}</span>
        <span class="stat-value" style="color: #f59e0b;">{formatVND(pendingCollected)}</span>
        <span style="font-size: 0.75rem; color: var(--text-secondary);">{lang === 'vi' ? `${countPending} chờ thanh toán, ${countPartial} một phần` : `${countPending} pending, ${countPartial} partial`}</span>
      </div>
    </div>
  </div>

  <!-- Filters -->
  <form method="GET" class="filter-bar">
    <input 
      type="text" 
      name="search" 
      placeholder={lang === 'vi' ? 'Tìm kiếm theo mã đơn hàng, nội dung hoặc khách hàng...' : 'Search by order number, content, or customer...'} 
      value={search} 
      class="search-input" 
    />
    <select name="status" class="select-filter">
      <option value="">{lang === 'vi' ? 'Tất cả trạng thái' : 'All Statuses'}</option>
      <option value="paid" selected={statusFilter === 'paid'}>{lang === 'vi' ? 'Đã thanh toán (Paid)' : 'Paid'}</option>
      <option value="partially_paid" selected={statusFilter === 'partially_paid'}>{lang === 'vi' ? 'Thanh toán một phần (Partial)' : 'Partially Paid'}</option>
      <option value="pending" selected={statusFilter === 'pending'}>{lang === 'vi' ? 'Chưa thanh toán (Pending)' : 'Pending'}</option>
      <option value="cancelled" selected={statusFilter === 'cancelled'}>{lang === 'vi' ? 'Đã hủy (Cancelled)' : 'Cancelled'}</option>
    </select>
    <button type="submit" class="btn-filter">{lang === 'vi' ? 'Lọc đơn hàng' : 'Apply Filters'}</button>
    {(search || statusFilter) && (
      <a href="/crm/orders" class="btn-reset">{lang === 'vi' ? 'Đặt lại' : 'Reset'}</a>
    )}
  </form>

  <!-- Table -->
  <div class="card-container">
    <!-- Desktop Table View -->
    <div class="table-responsive table-scroll-container">
      <table class="custom-table">
        <thead>
          <tr>
            <th>{lang === 'vi' ? 'Mã đơn hàng' : 'Order Number'}</th>
            <th>{lang === 'vi' ? 'Khách hàng' : 'Customer'}</th>
            <th>{lang === 'vi' ? 'Mô tả / Nội dung' : 'Description'}</th>
            <th>{lang === 'vi' ? 'Số tiền' : 'Amount'}</th>
            <th>{lang === 'vi' ? 'Trạng thái' : 'Status'}</th>
            <th>{lang === 'vi' ? 'Ngày phát hành' : 'Issued Date'}</th>
            <th>{lang === 'vi' ? 'Thao tác' : 'Actions'}</th>
          </tr>
        </thead>
        <tbody>
          {orderList.length === 0 ? (
            <tr>
              <td colspan="7" style="text-align: center; padding: 3rem; color: var(--text-secondary);">
                {lang === 'vi' ? 'Không có đơn hàng nào khớp với điều kiện tìm kiếm.' : 'No orders matching the criteria.'}
              </td>
            </tr>
          ) : (
            orderList.map((order: any) => (
              <tr>
                <td>
                  <span class="mono" style="font-weight: 600;">{order.orderNumber}</span>
                </td>
                <td>
                  {order.customerName ? (
                    <a href={`/crm/customers?search=${order.customerName}`} style="color: var(--primary); font-weight: 500; text-decoration: none;">
                      {order.customerName}
                    </a>
                  ) : (
                    <span style="color: var(--text-secondary);">N/A</span>
                  )}
                </td>
                <td>
                  <div>
                    <span>{order.content}</span>
                    <div style="font-size: 0.75rem; color: var(--text-secondary); margin-top: 0.15rem;">
                      {lang === 'vi' ? 'Nhân sự' : 'Staff'}: {order.staffName || (lang === 'vi' ? 'Hệ thống' : 'System')}
                    </div>
                    {order.startDate && order.expiredAt && (
                      <div style="font-size: 0.75rem; color: var(--text-secondary); margin-top: 0.15rem;">
                        📅 {lang === 'vi' ? 'Thời hạn' : 'Duration'}: <span class="mono">{formatDate(order.startDate)}</span> - <span class="mono">{formatDate(order.expiredAt)}</span>
                      </div>
                    )}
                  </div>
                </td>
                <td>
                  <span style="font-weight: 600; color: var(--text-primary);">{formatVND(order.amount)}</span>
                </td>
                <td>
                  <span class={`badge badge-${order.status}`}>
                    {order.status === 'paid' && (lang === 'vi' ? 'Đã thanh toán' : 'Paid')}
                    {order.status === 'partially_paid' && (lang === 'vi' ? 'Thanh toán một phần' : 'Partially Paid')}
                    {order.status === 'pending' && (lang === 'vi' ? 'Chưa thanh toán' : 'Pending')}
                    {order.status === 'cancelled' && (lang === 'vi' ? 'Đã hủy' : 'Cancelled')}
                  </span>
                </td>
                <td>
                  <span>{formatDate(order.createdAt)}</span>
                </td>
                <td style="display: flex; gap: 0.25rem; align-items: center;">
                  <a href={`/crm/qr-tool?orderId=${order.id}`} class="btn-action">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 14px; height: 14px;">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5A1.125 1.125 0 013.75 9.375v-4.5zM3.75 14.625c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5a1.125 1.125 0 01-1.125-1.125v-4.5zM13.5 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5A1.125 1.125 0 0113.5 9.375v-4.5zM6.75 6.75h.75v.75h-.75v-.75zM6.75 16.5h.75v.75h-.75v-.75zM16.5 6.75h.75v.75h-.75v-.75zM13.5 13.5h.75v.75h-.75v-.75zM16.5 16.5h.75v.75h-.75v-.75zM13.5 16.5h.75v.75h-.75v-.75zM16.5 13.5h.75v.75h-.75v-.75z" />
                    </svg>
                    {lang === 'vi' ? 'Thanh toán QR' : 'Pay QR'}
                  </a>
                  {(user?.role === 'admin' || user?.role === 'accountant') && (
                    <button 
                      type="button" 
                      class="btn-action btn-edit-order" 
                      data-id={order.id}
                      data-service-id={order.serviceId || ''}
                      data-amount={order.amount}
                      data-start-date={order.startDate || ''}
                      data-expired-at={order.expiredAt || ''}
                      data-number={order.orderNumber}
                    >
                      ✏️ {lang === 'vi' ? 'Sửa' : 'Edit'}
                    </button>
                  )}
                </td>
              </tr>
            ))
          )}
        </tbody>
      </table>
    </div>

    <!-- Mobile Card View -->
    <div class="mobile-card-grid">
      {orderList.length === 0 ? (
        <div style="text-align: center; padding: 2rem; color: var(--text-secondary);">
          {lang === 'vi' ? 'Không có đơn hàng nào khớp với điều kiện tìm kiếm.' : 'No orders matching the criteria.'}
        </div>
      ) : (
        orderList.map((order: any) => (
          <div class="mobile-card">
            <div class="mobile-card-header">
              <div style="display: flex; flex-direction: column; gap: 0.25rem;">
                <span class="mono" style="font-weight: 600; color: var(--text-primary);">{order.orderNumber}</span>
                {order.customerName ? (
                  <a href={`/crm/customers?search=${order.customerName}`} style="color: var(--primary); font-weight: 500; font-size: 0.875rem; text-decoration: none;">
                    {order.customerName}
                  </a>
                ) : (
                  <span style="color: var(--text-secondary); font-size: 0.875rem;">N/A</span>
                )}
              </div>
              <span class={`badge badge-${order.status}`}>
                {order.status === 'paid' && (lang === 'vi' ? 'Đã thanh toán' : 'Paid')}
                {order.status === 'partially_paid' && (lang === 'vi' ? 'Thanh toán một phần' : 'Partially Paid')}
                {order.status === 'pending' && (lang === 'vi' ? 'Chưa thanh toán' : 'Pending')}
                {order.status === 'cancelled' && (lang === 'vi' ? 'Đã hủy' : 'Cancelled')}
              </span>
            </div>
            
            <div class="mobile-card-body">
              <div class="mobile-card-row">
                <span class="mobile-card-label">{lang === 'vi' ? 'Mô tả / Nội dung' : 'Description'}</span>
                <span class="mobile-card-value" style="text-align: right;">{order.content}</span>
              </div>
              <div class="mobile-card-row">
                <span class="mobile-card-label">{lang === 'vi' ? 'Số tiền' : 'Amount'}</span>
                <span class="mobile-card-value" style="font-weight: 600; color: var(--text-primary);">{formatVND(order.amount)}</span>
              </div>
              <div class="mobile-card-row">
                <span class="mobile-card-label">{lang === 'vi' ? 'Ngày phát hành' : 'Issued Date'}</span>
                <span class="mobile-card-value">{formatDate(order.createdAt)}</span>
              </div>
              {order.startDate && order.expiredAt && (
                <div class="mobile-card-row">
                  <span class="mobile-card-label">{lang === 'vi' ? 'Thời hạn' : 'Duration'}</span>
                  <span class="mobile-card-value mono">{formatDate(order.startDate)} - {formatDate(order.expiredAt)}</span>
                </div>
              )}
              <div class="mobile-card-row">
                <span class="mobile-card-label">{lang === 'vi' ? 'Nhân sự' : 'Staff'}</span>
                <span class="mobile-card-value" style="font-size: 0.75rem; color: var(--text-secondary);">{order.staffName || (lang === 'vi' ? 'Hệ thống' : 'System')}</span>
              </div>
            </div>

            <div class="mobile-card-footer" style="width: 100%; display: flex; gap: 0.5rem;">
              <a href={`/crm/qr-tool?orderId=${order.id}`} class="btn-action" style="flex: 1; justify-content: center;">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 14px; height: 14px;">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5A1.125 1.125 0 013.75 9.375v-4.5zM3.75 14.625c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5a1.125 1.125 0 01-1.125-1.125v-4.5zM13.5 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5A1.125 1.125 0 0113.5 9.375v-4.5zM6.75 6.75h.75v.75h-.75v-.75zM6.75 16.5h.75v.75h-.75v-.75zM16.5 6.75h.75v.75h-.75v-.75zM13.5 13.5h.75v.75h-.75v-.75zM16.5 16.5h.75v.75h-.75v-.75zM13.5 16.5h.75v.75h-.75v-.75zM16.5 13.5h.75v.75h-.75v-.75z" />
                </svg>
                {lang === 'vi' ? 'Thanh toán' : 'Pay'}
              </a>
              {(user?.role === 'admin' || user?.role === 'accountant') && (
                <button 
                  type="button" 
                  class="btn-action btn-edit-order" 
                  data-id={order.id}
                  data-service-id={order.serviceId || ''}
                  data-amount={order.amount}
                  data-start-date={order.startDate || ''}
                  data-expired-at={order.expiredAt || ''}
                  data-number={order.orderNumber}
                  style="flex: 1; justify-content: center;"
                >
                  ✏️ {lang === 'vi' ? 'Sửa' : 'Edit'}
                </button>
              )}
            </div>
          </div>
        ))
      )}
    </div>
  </div>

  <!-- Quick Create Paid Order Modal -->
  <div class="modal-backdrop" id="quickOrderModal">
    <div class="modal-content" style="max-width: 550px;">
      <div class="modal-header">
        <h3>{lang === 'vi' ? 'Tạo nhanh đơn hàng đã thanh toán' : 'Quick Create Paid Order'}</h3>
        <button class="modal-close" id="quickOrderModalCloseBtn">&times;</button>
      </div>
      <form id="quickOrderForm" style="display: flex; flex-direction: column;">
        <div class="form-group">
          <label for="quickOrderCustomer">{lang === 'vi' ? 'Khách hàng' : 'Customer'}</label>
          <select id="quickOrderCustomer" name="customerId" class="form-select" required>
            <option value="">{lang === 'vi' ? '-- Chọn khách hàng --' : '-- Select Customer --'}</option>
            {customersList.map((cust: any) => (
              <option value={cust.id} data-name={cust.fullName}>{cust.fullName} ({cust.phone})</option>
            ))}
          </select>
        </div>

        <div class="form-group">
          <label for="quickOrderService">{lang === 'vi' ? 'Dịch vụ gia hạn' : 'Extension Service'}</label>
          <select id="quickOrderService" name="serviceId" class="form-select" required>
            <option value="">{lang === 'vi' ? '-- Chọn dịch vụ --' : '-- Select Service --'}</option>
            {servicesList.map((srv: any) => (
              <option value={srv.id} data-price={srv.price} data-name={srv.name} data-prefix={srv.prefix}>{srv.name} ({formatVND(srv.price)})</option>
            ))}
          </select>
        </div>

        <div class="form-group">
          <label for="quickOrderAmount">{lang === 'vi' ? 'Số tiền thanh toán (VND)' : 'Amount (VND)'}</label>
          <input type="number" id="quickOrderAmount" name="amount" class="form-input" required min="0" placeholder="0" />
        </div>

        <div class="form-group">
          <label for="quickOrderContent">{lang === 'vi' ? 'Nội dung thanh toán' : 'Payment Content'}</label>
          <input type="text" id="quickOrderContent" name="content" class="form-input" required placeholder={lang === 'vi' ? 'Ví dụ: Nguyễn Văn A thanh toán dịch vụ' : 'e.g. John Doe payment'} />
        </div>

        <div class="form-group">
          <label for="quickOrderPaidAt">{lang === 'vi' ? 'Ngày giờ thanh toán' : 'Payment Date/Time'}</label>
          <input type="datetime-local" id="quickOrderPaidAt" name="paidAt" class="form-input" required />
        </div>

        <div class="form-group">
          <label for="quickOrderMethod">{lang === 'vi' ? 'Phương thức thanh toán' : 'Payment Method'}</label>
          <select id="quickOrderMethod" name="paymentMethod" class="form-select" required>
            <option value="bank_transfer" selected>{lang === 'vi' ? 'Chuyển khoản ngân hàng' : 'Bank Transfer'}</option>
            <option value="cash">{lang === 'vi' ? 'Tiền mặt' : 'Cash'}</option>
          </select>
        </div>

        <div class="form-group" style="display: flex; align-items: center; gap: 0.5rem; margin-top: 1rem;">
          <input type="checkbox" id="quickOrderStartDateFlag" name="startDateFromPayment" style="width: 16px; height: 16px; cursor: pointer;" />
          <label for="quickOrderStartDateFlag" style="margin-bottom: 0; cursor: pointer; text-transform: none; font-weight: 500;">
            {lang === 'vi' ? 'Tính ngày bắt đầu từ ngày thanh toán (Nối chu kỳ mới từ hôm nay thay vì chu kỳ cũ)' : 'Start date from payment time (Overlap instead of sequence)'}
          </label>
        </div>

        <div class="modal-footer" style="margin-top: 1.5rem;">
          <button type="button" class="btn-cancel" id="quickOrderModalCancelBtn">{lang === 'vi' ? 'Hủy bỏ' : 'Cancel'}</button>
          <button type="submit" class="btn-filter" id="quickOrderSubmitBtn" style="padding: 0.65rem 1.25rem;">{lang === 'vi' ? 'Tạo đơn hàng' : 'Create Order'}</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Edit Order Modal -->
  <div class="modal-backdrop" id="editOrderModal">
    <div class="modal-content" style="max-width: 500px;">
      <div class="modal-header">
        <h3>{lang === 'vi' ? 'Chỉnh sửa đơn hàng' : 'Edit Order'} <span id="editOrderNumber" class="mono"></span></h3>
        <button class="modal-close" id="editOrderModalCloseBtn">&times;</button>
      </div>
      <form id="editOrderForm" style="display: flex; flex-direction: column;">
        <input type="hidden" id="editOrderId" />
        
        <div class="form-group">
          <label for="editOrderService">{lang === 'vi' ? 'Dịch vụ' : 'Service'}</label>
          <select id="editOrderService" class="form-select" required>
            {servicesList.map((srv: any) => (
              <option value={srv.id} data-price={srv.price} data-cycle={srv.billingCycle}>{srv.name}</option>
            ))}
          </select>
        </div>

        <div class="form-group">
          <label for="editOrderAmount">{lang === 'vi' ? 'Số tiền (VND)' : 'Amount (VND)'}</label>
          <input type="number" id="editOrderAmount" class="form-input" required min="0" />
        </div>

        <div class="grid-2" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.25rem;">
          <div class="form-group">
            <label for="editOrderStartDate">{lang === 'vi' ? 'Ngày bắt đầu' : 'Start Date'}</label>
            <input type="date" id="editOrderStartDate" class="form-input" required />
          </div>
          <div class="form-group">
            <label for="editOrderExpiredAt">{lang === 'vi' ? 'Ngày hết hạn' : 'End Date'}</label>
            <input type="date" id="editOrderExpiredAt" class="form-input" required />
          </div>
        </div>

        <div class="modal-footer" style="margin-top: 1.5rem;">
          <button type="button" class="btn-cancel" id="editOrderModalCancelBtn">{lang === 'vi' ? 'Hủy bỏ' : 'Cancel'}</button>
          <button type="submit" class="btn-filter" id="editOrderSubmitBtn" style="padding: 0.65rem 1.25rem;">{lang === 'vi' ? 'Cập nhật' : 'Update'}</button>
        </div>
      </form>
    </div>
  </div>

  <script is:inline>
    // Quick Create Order Modal Logic
    const openBtn = document.getElementById('openQuickOrderModalBtn');
    const modal = document.getElementById('quickOrderModal');
    const closeBtn = document.getElementById('quickOrderModalCloseBtn');
    const cancelBtn = document.getElementById('quickOrderModalCancelBtn');
    const form = document.getElementById('quickOrderForm');
    const submitBtn = document.getElementById('quickOrderSubmitBtn');

    const customerSelect = document.getElementById('quickOrderCustomer');
    const serviceSelect = document.getElementById('quickOrderService');
    const amountInput = document.getElementById('quickOrderAmount');
    const contentInput = document.getElementById('quickOrderContent');
    const paidAtInput = document.getElementById('quickOrderPaidAt');

    if (openBtn && modal) {
      openBtn.addEventListener('click', () => {
        // Set default date to current local time in ISO format compatible with datetime-local input
        const now = new Date();
        const offset = now.getTimezoneOffset() * 60000;
        const localISOTime = (new Date(now - offset)).toISOString().slice(0, 16);
        
        form.reset();
        paidAtInput.value = localISOTime;
        modal.style.display = 'flex';
      });
    }

    const closeModal = () => {
      if (modal) modal.style.display = 'none';
    };

    if (closeBtn) closeBtn.addEventListener('click', closeModal);
    if (cancelBtn) cancelBtn.addEventListener('click', closeModal);

    // Close when clicking outside content
    window.addEventListener('click', (e) => {
      if (e.target === modal) {
        closeModal();
      }
    });

    // Smart Auto-fill when Service / Customer is changed
    const updateContentProposal = () => {
      const selectedCustOption = customerSelect.options[customerSelect.selectedIndex];
      const selectedSrvOption = serviceSelect.options[serviceSelect.selectedIndex];

      const customerName = selectedCustOption && selectedCustOption.value ? selectedCustOption.getAttribute('data-name') : '';
      const servicePrefix = selectedSrvOption && selectedSrvOption.value ? selectedSrvOption.getAttribute('data-prefix') : '';

      if (customerName && servicePrefix) {
        // Remove accents and convert to uppercase for Vietnamese names (standard banking content style)
        const normalizedName = customerName
          .normalize('NFD')
          .replace(/[\u0300-\u036f]/g, '')
          .replace(/đ/g, 'd')
          .replace(/Đ/g, 'D')
          .toUpperCase();
        contentInput.value = `${normalizedName} THANH TOAN DV ${servicePrefix.toUpperCase()}`;
      }
    };

    if (customerSelect) customerSelect.addEventListener('change', updateContentProposal);

    if (serviceSelect) {
      serviceSelect.addEventListener('change', () => {
        const selectedOption = serviceSelect.options[serviceSelect.selectedIndex];
        if (selectedOption && selectedOption.value) {
          const price = selectedOption.getAttribute('data-price');
          amountInput.value = price;
        } else {
          amountInput.value = '';
        }
        updateContentProposal();
      });
    }

    // Submit form logic
    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const customerId = customerSelect.value;
        const serviceId = serviceSelect.value;
        const amount = Number(amountInput.value);
        const content = contentInput.value;
        const paidAt = new Date(paidAtInput.value).getTime();
        const paymentMethod = document.getElementById('quickOrderMethod').value;
        const startDateFromPayment = document.getElementById('quickOrderStartDateFlag').checked;

        if (!customerId || !serviceId || !amount || !content || !paidAt || !paymentMethod) {
          alert('Vui lòng nhập đầy đủ thông tin!');
          return;
        }

        submitBtn.disabled = true;
        const originalText = submitBtn.textContent;
        submitBtn.textContent = 'Đang xử lý...';

        try {
          const response = await fetch('/api/crm/orders', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({
              customerId,
              serviceId,
              amount,
              content,
              paidAt,
              startDateFromPayment,
              paymentMethod,
            }),
          });

          const resData = await response.json();
          if (response.ok && resData.success) {
            alert('Tạo đơn hàng và gia hạn dịch vụ thành công!');
            window.location.reload();
          } else {
            alert('Lỗi: ' + (resData.error || 'Không xác định'));
            submitBtn.disabled = false;
            submitBtn.textContent = originalText;
          }
        } catch (error) {
          console.error(error);
          alert('Có lỗi xảy ra trong quá trình gửi yêu cầu!');
          submitBtn.disabled = false;
          submitBtn.textContent = originalText;
        }
      });
    }

    // Edit Order Modal Logic
    const editModal = document.getElementById('editOrderModal');
    const editCloseBtn = document.getElementById('editOrderModalCloseBtn');
    const editCancelBtn = document.getElementById('editOrderModalCancelBtn');
    const editForm = document.getElementById('editOrderForm');
    const editSubmitBtn = document.getElementById('editOrderSubmitBtn');

    const editOrderIdInput = document.getElementById('editOrderId');
    const editOrderNumberSpan = document.getElementById('editOrderNumber');
    const editServiceSelect = document.getElementById('editOrderService');
    const editAmountInput = document.getElementById('editOrderAmount');
    const editStartDateInput = document.getElementById('editOrderStartDate');
    const editExpiredAtInput = document.getElementById('editOrderExpiredAt');

    // Format dates from timestamp to YYYY-MM-DD
    const formatDateInput = (timestamp) => {
      if (!timestamp) return '';
      const d = new Date(Number(timestamp));
      const year = d.getFullYear();
      const month = String(d.getMonth() + 1).padStart(2, '0');
      const day = String(d.getDate()).padStart(2, '0');
      return `${year}-${month}-${day}`;
    };

    document.querySelectorAll('.btn-edit-order').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = btn.getAttribute('data-id');
        const serviceId = btn.getAttribute('data-service-id');
        const amount = btn.getAttribute('data-amount');
        const startDate = btn.getAttribute('data-start-date');
        const expiredAt = btn.getAttribute('data-expired-at');
        const number = btn.getAttribute('data-number');

        editOrderIdInput.value = id;
        editOrderNumberSpan.textContent = `(${number})`;
        editServiceSelect.value = serviceId;
        editAmountInput.value = amount;
        editStartDateInput.value = formatDateInput(startDate);
        editExpiredAtInput.value = formatDateInput(expiredAt);

        if (editModal) editModal.style.display = 'flex';
      });
    });

    const closeEditModal = () => {
      if (editModal) editModal.style.display = 'none';
    };

    if (editCloseBtn) editCloseBtn.addEventListener('click', closeEditModal);
    if (editCancelBtn) editCancelBtn.addEventListener('click', closeEditModal);

    window.addEventListener('click', (e) => {
      if (e.target === editModal) closeEditModal();
    });

    // Service change auto-recalculates End Date and price
    if (editServiceSelect) {
      editServiceSelect.addEventListener('change', () => {
        const selectedOption = editServiceSelect.options[editServiceSelect.selectedIndex];
        if (selectedOption && selectedOption.value) {
          const price = selectedOption.getAttribute('data-price');
          editAmountInput.value = price;
          const cycleDays = parseInt(selectedOption.getAttribute('data-cycle') || '30', 10);
          calculateEditEndDate(cycleDays);
        }
      });
    }

    // Start Date change auto-recalculates End Date
    if (editStartDateInput) {
      editStartDateInput.addEventListener('change', () => {
        const selectedOption = editServiceSelect.options[editServiceSelect.selectedIndex];
        if (selectedOption && selectedOption.value) {
          const cycleDays = parseInt(selectedOption.getAttribute('data-cycle') || '30', 10);
          calculateEditEndDate(cycleDays);
        }
      });
    }

    const calculateEditEndDate = (days) => {
      const startVal = editStartDateInput.value;
      if (!startVal) return;
      const startDate = new Date(startVal);
      startDate.setDate(startDate.getDate() + days);
      editExpiredAtInput.value = startDate.toISOString().split('T')[0];
    };

    // Submit Edit Form
    if (editForm) {
      editForm.addEventListener('submit', async (e) => {
        e.preventDefault();

        const orderId = editOrderIdInput.value;
        const serviceId = editServiceSelect.value;
        const amount = Number(editAmountInput.value);
        // Convert input date string to UTC/Local start/end timestamp (ms)
        const startDate = new Date(editStartDateInput.value).getTime();
        const expiredAt = new Date(editExpiredAtInput.value).getTime();

        if (!orderId || !serviceId || amount === undefined || !startDate || !expiredAt) {
          alert('Vui lòng điền đầy đủ thông tin!');
          return;
        }

        editSubmitBtn.disabled = true;
        const originalText = editSubmitBtn.textContent;
        editSubmitBtn.textContent = 'Đang cập nhật...';

        try {
          const response = await fetch('/api/crm/orders', {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ orderId, serviceId, amount, startDate, expiredAt })
          });

          const resData = await response.json();
          if (response.ok && resData.success) {
            alert('Cập nhật đơn hàng thành công!');
            window.location.reload();
          } else {
            alert('Lỗi: ' + (resData.error || 'Không xác định'));
            editSubmitBtn.disabled = false;
            editSubmitBtn.textContent = originalText;
          }
        } catch (error) {
          console.error(error);
          alert('Có lỗi xảy ra khi cập nhật đơn hàng!');
          editSubmitBtn.disabled = false;
          editSubmitBtn.textContent = originalText;
        }
      });
    }
  </script>
</DashboardLayout>
