</style>

<script>
  function escapeHtml(unsafe: any) {
    if (unsafe === null || unsafe === undefined) return '';
    return String(unsafe)
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#039;");
  }

  // Read attributes from DOM helper
  const layout = document.querySelector('.settings-layout') as HTMLDivElement;
  const isAdmin = layout?.getAttribute('data-is-admin') === 'true';
  const lang = layout?.getAttribute('data-lang') || 'vi';
  const i18n = JSON.parse(layout?.getAttribute('data-i18n') || '{}');

  // Navigation active state highlight on scroll
  const navItems = document.querySelectorAll('.nav-item');
  const sections = document.querySelectorAll('section');

  window.addEventListener('scroll', () => {
    let current = '';
    sections.forEach(section => {
      const sectionTop = section.offsetTop;
      if (pageYOffset >= sectionTop - 120) {
        current = section.getAttribute('id') || '';
      }
    });

    navItems.forEach(item => {
      item.classList.remove('active');
      if (item.getAttribute('href') === `#${current}`) {
        item.classList.add('active');
      }
    });
  });

  // Language selection logic
  let selectedLang = lang;
  const langCards = document.querySelectorAll('.lang-card');
  langCards.forEach(card => {
    card.addEventListener('click', () => {
      langCards.forEach(c => c.classList.remove('active'));
      card.classList.add('active');
      selectedLang = card.getAttribute('data-lang') || 'vi';
    });
  });

  // Toast Notification System helper
  const toast = document.getElementById('toastNotification') as HTMLDivElement;
  const toastText = document.getElementById('toastNotificationText') as HTMLSpanElement;

  function showToast(message: string, type: 'success' | 'error' = 'success') {
    if (!toast) return;
    toastText.textContent = message;
    toast.className = `toast-notification show ${type}`;
    setTimeout(() => {
      toast.classList.remove('show');
    }, 2500);
  }

  // ---------------------------------------------------------
  // SECTION 1: GENERAL settings submit
  // ---------------------------------------------------------
  const saveGeneralBtn = document.getElementById('saveGeneralBtn') as HTMLButtonElement;
  const genSpinner = document.getElementById('genSpinner') as HTMLSpanElement;

  if (saveGeneralBtn) {
    saveGeneralBtn.addEventListener('click', async () => {
      saveGeneralBtn.disabled = true;
      if (genSpinner) genSpinner.style.display = 'inline-block';

      try {
        // 1. Language update if changed
        if (selectedLang !== lang) {
          const langRes = await fetch('/api/settings/lang', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ lang: selectedLang })
          });
          if (!langRes.ok) throw new Error('Language update failed');
        }

        // 2. Org Info updates
        const orgNameVal = (document.getElementById('orgNameInput') as HTMLInputElement).value;
        const orgLogoVal = (document.getElementById('orgLogoInput') as HTMLInputElement).value;

        const orgNameRes = await fetch('/api/crm/config', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ key: 'org_name', value: orgNameVal })
        });
        if (!orgNameRes.ok) throw new Error('Org Name update failed');

        const orgLogoRes = await fetch('/api/crm/config', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ key: 'org_logo', value: orgLogoVal })
        });
        if (!orgLogoRes.ok) throw new Error('Org Logo update failed');

        showToast(i18n.saveGeneralSuccess || 'General settings saved successfully!', 'success');
        setTimeout(() => window.location.reload(), 1200);

      } catch (err: any) {
        console.error(err);
        showToast(err.message, 'error');
        saveGeneralBtn.disabled = false;
        if (genSpinner) genSpinner.style.display = 'none';
      }
    });
  }

  // ---------------------------------------------------------
  // SECTION 2: INTEGRATIONS submit
  // ---------------------------------------------------------
  const saveIntegrationsBtn = document.getElementById('saveIntegrationsBtn') as HTMLButtonElement;
  const integSpinner = document.getElementById('integSpinner') as HTMLSpanElement;

  if (saveIntegrationsBtn) {
    saveIntegrationsBtn.addEventListener('click', async () => {
      saveIntegrationsBtn.disabled = true;
      if (integSpinner) integSpinner.style.display = 'inline-block';

      try {
        const bankVal = (document.getElementById('defaultBankInput') as HTMLInputElement).value;
        const bankRes = await fetch('/api/crm/config', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ key: 'default_bank_account', value: bankVal })
        });
        if (!bankRes.ok) throw new Error('Bank account configuration failed');

        showToast(i18n.saveBankSuccess || 'Integrations updated successfully!', 'success');
        setTimeout(() => window.location.reload(), 1200);
      } catch (err: any) {
        showToast(err.message, 'error');
        saveIntegrationsBtn.disabled = false;
        if (integSpinner) integSpinner.style.display = 'none';
      }
    });
  }

  // GitHub backup triggers
  const testGithubBtn = document.getElementById('testGithubBtn') as HTMLButtonElement;
  const testGitSpinner = document.getElementById('testGitSpinner') as HTMLSpanElement;
  if (testGithubBtn) {
    testGithubBtn.addEventListener('click', async () => {
      testGithubBtn.disabled = true;
      if (testGitSpinner) testGitSpinner.style.display = 'inline-block';

      try {
        const res = await fetch('/api/backup/test-connection', { method: 'POST' });
        const data = await res.json();
        if (res.ok && data.success) {
          showToast(i18n.githubTestSuccess || 'GitHub connection working!', 'success');
        } else {
          showToast(data.error || 'Connection failed', 'error');
        }
      } catch (err: any) {
        showToast('Network error: ' + err.message, 'error');
      } finally {
        testGithubBtn.disabled = false;
        if (testGitSpinner) testGitSpinner.style.display = 'none';
      }
    });
  }

  const triggerBackupBtn = document.getElementById('triggerBackupBtn') as HTMLButtonElement;
  const backupSpinner = document.getElementById('backupSpinner') as HTMLSpanElement;
  if (triggerBackupBtn) {
    triggerBackupBtn.addEventListener('click', async () => {
      if (!confirm(i18n.githubBackupConfirm || 'Are you sure you want to trigger GitHub backup now?')) return;
      triggerBackupBtn.disabled = true;
      if (backupSpinner) backupSpinner.style.display = 'inline-block';

      try {
        const res = await fetch('/api/backup', { method: 'POST' });
        const data = await res.json();
        if (res.ok && data.success) {
          showToast(i18n.githubBackupSuccess || 'Backup successfully completed!', 'success');
          setTimeout(() => window.location.reload(), 1200);
        } else {
          showToast(data.error || 'Backup failed', 'error');
        }
      } catch (err: any) {
        showToast('Network error: ' + err.message, 'error');
      } finally {
        triggerBackupBtn.disabled = false;
        if (backupSpinner) backupSpinner.style.display = 'none';
      }
    });
  }

  // ---------------------------------------------------------
  // SECTION 3: DATABASE actions
  // ---------------------------------------------------------
  const optimizeDbBtn = document.getElementById('optimizeDbBtn') as HTMLButtonElement;
  const optSpinner = document.getElementById('optSpinner') as HTMLSpanElement;
  if (optimizeDbBtn) {
    optimizeDbBtn.addEventListener('click', async () => {
      optimizeDbBtn.disabled = true;
      if (optSpinner) optSpinner.style.display = 'inline-block';

      try {
        const res = await fetch('/api/settings/db-optimize', { method: 'POST' });
        const data = await res.json();
        if (res.ok && data.success) {
          showToast(i18n.dbOptimizeSuccess || 'Database optimized successfully!', 'success');
          setTimeout(() => window.location.reload(), 1200);
        } else {
          showToast(data.error || 'Optimization failed', 'error');
        }
      } catch (err: any) {
        showToast('Network error: ' + err.message, 'error');
      } finally {
        optimizeDbBtn.disabled = false;
        if (optSpinner) optSpinner.style.display = 'none';
      }
    });
  }

  // ---------------------------------------------------------
  // SECTION 4: SECURITY actions (Password change + User CRUD)
  // ---------------------------------------------------------
  const changePasswordForm = document.getElementById('changePasswordForm') as HTMLFormElement;
  const pwdSpinner = document.getElementById('pwdSpinner') as HTMLSpanElement;
  if (changePasswordForm) {
    changePasswordForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const currentPassword = (document.getElementById('currentPassword') as HTMLInputElement).value;
      const newPassword = (document.getElementById('newPassword') as HTMLInputElement).value;
      const confirmPassword = (document.getElementById('confirmPassword') as HTMLInputElement).value;

      if (newPassword !== confirmPassword) {
        showToast(i18n.pwdMismatch || 'Passwords do not match!', 'error');
        return;
      }

      const submitBtn = document.getElementById('changePasswordBtn') as HTMLButtonElement;
      submitBtn.disabled = true;
      if (pwdSpinner) pwdSpinner.style.display = 'inline-block';

      try {
        const res = await fetch('/api/settings/change-password', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ currentPassword, newPassword })
        });
        const data = await res.json();

        if (res.ok && data.success) {
          showToast(i18n.changePwdSuccess || 'Password changed successfully!', 'success');
          changePasswordForm.reset();
        } else {
          showToast(data.error || 'Failed to change password', 'error');
        }
      } catch (err: any) {
        showToast('Network error: ' + err.message, 'error');
      } finally {
        submitBtn.disabled = false;
        if (pwdSpinner) pwdSpinner.style.display = 'none';
      }
    });
  }

  // Admin User CRUD Client side trigger
  if (isAdmin) {
    const userTableBody = document.getElementById('userTableBody') as HTMLTableSectionElement;
    const addUserModal = document.getElementById('addUserModal') as HTMLDivElement;
    const openAddUserModal = document.getElementById('openAddUserModal') as HTMLButtonElement;
    const closeAddUserModal = document.getElementById('closeAddUserModal') as HTMLButtonElement;
    const cancelAddUser = document.getElementById('cancelAddUser') as HTMLButtonElement;
    const addUserForm = document.getElementById('addUserForm') as HTMLFormElement;
    const createUserSpinner = document.getElementById('createUserSpinner') as HTMLSpanElement;

    // Load users
    async function loadUsers() {
      try {
        const res = await fetch('/api/settings/users');
        if (res.status === 501) {
          userTableBody.innerHTML = `<tr><td colspan="4" class="text-center text-secondary">User Management API not implemented yet (Phase 2)</td></tr>`;
          return;
        }
        if (!res.ok) throw new Error('Failed to fetch users');
        const usersList = await res.json();
        
        userTableBody.innerHTML = usersList.map((usr: any) => `
          <tr>
            <td><strong>${escapeHtml(usr.username)}</strong></td>
            <td><span class="badge-action">${escapeHtml(usr.role)}</span></td>
            <td>${escapeHtml(new Date(usr.createdAt).toLocaleString())}</td>
            <td>
              <button class="btn-small-secondary delete-user-btn" data-id="${escapeHtml(usr.id)}">Delete</button>
            </td>
          </tr>
        `).join('');

        // Attach delete events
        document.querySelectorAll('.delete-user-btn').forEach(btn => {
          btn.addEventListener('click', async () => {
            const id = btn.getAttribute('data-id');
            if (!confirm('Are you sure you want to delete this user?')) return;
            try {
              const delRes = await fetch(`/api/settings/users/${id}`, { method: 'DELETE' });
              const data = await delRes.json();
              if (delRes.ok && data.success) {
                showToast('User deleted successfully', 'success');
                loadUsers();
              } else {
                showToast(data.error || 'Failed to delete user', 'error');
              }
            } catch (err: any) {
              showToast(err.message, 'error');
            }
          });
        });
      } catch (err: any) {
        userTableBody.innerHTML = `<tr><td colspan="4" class="text-center text-secondary">Error: ${escapeHtml(err.message)}</td></tr>`;
      }
    }

    loadUsers();

    // Modal control
    if (openAddUserModal) {
      openAddUserModal.addEventListener('click', () => addUserModal.classList.add('open'));
    }
    const closeModal = () => addUserModal.classList.remove('open');
    if (closeAddUserModal) closeAddUserModal.addEventListener('click', closeModal);
    if (cancelAddUser) cancelAddUser.addEventListener('click', closeModal);

    // Create user submit
    if (addUserForm) {
      addUserForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const username = (document.getElementById('newUsername') as HTMLInputElement).value;
        const password = (document.getElementById('newUserPassword') as HTMLInputElement).value;
        const role = (document.getElementById('newUserRole') as HTMLSelectElement).value;

        const submitBtn = addUserForm.querySelector('button[type="submit"]') as HTMLButtonElement;
        submitBtn.disabled = true;
        if (createUserSpinner) createUserSpinner.style.display = 'inline-block';

        try {
          const res = await fetch('/api/settings/users', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ username, password, role })
          });
          const data = await res.json();
          if (res.ok && data.success) {
            showToast('User created successfully', 'success');
            addUserForm.reset();
            closeModal();
            loadUsers();
          } else {
            showToast(data.error || 'Failed to create user', 'error');
          }
        } catch (err: any) {
          showToast(err.message, 'error');
        } finally {
          submitBtn.disabled = false;
          if (createUserSpinner) createUserSpinner.style.display = 'none';
        }
      });
    }
  }

  // ---------------------------------------------------------
  // SECTION 5: AUDIT & DEBUG LOGS viewer actions (Admin Only)
  // ---------------------------------------------------------
  if (isAdmin) {
    const tabBtns = document.querySelectorAll('.tab-btn');
    const tabContents = document.querySelectorAll('.tab-content');

    tabBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        tabBtns.forEach(b => b.classList.remove('active'));
        tabContents.forEach(c => c.classList.remove('active'));

        btn.classList.add('active');
        const tabId = btn.getAttribute('data-tab');
        document.getElementById(`${tabId}Tab`)?.classList.add('active');

        // Automatically fetch initial page when tab is activated
        if (tabId === 'audit' && auditPage === 1) loadAuditLogs();
        if (tabId === 'debug' && debugPage === 1) loadDebugLogs();
      });
    });

    // Pagination variables
    let auditPage = 1;
    let debugPage = 1;
    const limit = 10;

    // Elements
    const auditLogsBody = document.getElementById('auditLogsBody') as HTMLTableSectionElement;
    const debugLogsBody = document.getElementById('debugLogsBody') as HTMLTableSectionElement;

    async function loadAuditLogs() {
      const action = (document.getElementById('auditActionFilter') as HTMLInputElement).value;
      try {
        auditLogsBody.innerHTML = `<tr><td colspan="5" class="text-center">Loading audit logs...</td></tr>`;
        const res = await fetch(`/api/settings/audit-logs?page=${auditPage}&limit=${limit}&action=${encodeURIComponent(action)}`);
        
        if (res.status === 501) {
          auditLogsBody.innerHTML = `<tr><td colspan="5" class="text-center text-secondary">Audit Logs API not implemented yet (Phase 3)</td></tr>`;
          return;
        }
        if (!res.ok) throw new Error('Failed to fetch audit logs');
        const data = await res.json();

        if (data.logs.length === 0) {
          auditLogsBody.innerHTML = `<tr><td colspan="5" class="text-center">No logs matching filter</td></tr>`;
        } else {
          auditLogsBody.innerHTML = data.logs.map((log: any) => `
            <tr>
              <td class="whitespace-nowrap">${escapeHtml(new Date(log.createdAt).toLocaleString())}</td>
              <td>${escapeHtml(log.username) || 'System'}</td>
              <td><span class="badge-action">${escapeHtml(log.action)}</span></td>
              <td>${escapeHtml(log.target) || '-'}</td>
              <td class="text-secondary overflow-ellipsis max-width-300" title="${escapeHtml(log.detail)}">
                ${escapeHtml(log.detail) || '-'}
              </td>
            </tr>
          `).join('');
        }

        // Pager buttons state
        const totalPages = Math.ceil(data.total / limit) || 1;
        (document.getElementById('auditPageInfo') as HTMLSpanElement).textContent = `Page ${auditPage} of ${totalPages}`;
        (document.getElementById('prevAuditPage') as HTMLButtonElement).disabled = auditPage <= 1;
        (document.getElementById('nextAuditPage') as HTMLButtonElement).disabled = auditPage >= totalPages;

      } catch (err: any) {
        auditLogsBody.innerHTML = `<tr><td colspan="5" class="text-center text-secondary">Error: ${escapeHtml(err.message)}</td></tr>`;
      }
    }

    async function loadDebugLogs() {
      const level = (document.getElementById('debugLevelFilter') as HTMLSelectElement).value;
      try {
        debugLogsBody.innerHTML = `<tr><td colspan="5" class="text-center">Loading debug logs...</td></tr>`;
        const res = await fetch(`/api/settings/debug-logs?page=${debugPage}&limit=${limit}&level=${level}`);

        if (res.status === 501) {
          debugLogsBody.innerHTML = `<tr><td colspan="5" class="text-center text-secondary">Debug Logs API not implemented yet (Phase 3)</td></tr>`;
          return;
        }
        if (!res.ok) throw new Error('Failed to fetch debug logs');
        const data = await res.json();

        if (data.logs.length === 0) {
          debugLogsBody.innerHTML = `<tr><td colspan="5" class="text-center">No logs matching filter</td></tr>`;
        } else {
          debugLogsBody.innerHTML = data.logs.map((log: any) => `
            <tr class="debug-row-main" style="cursor: pointer;">
              <td class="whitespace-nowrap">${escapeHtml(new Date(log.createdAt).toLocaleString())}</td>
              <td><span class="badge-action ${escapeHtml(log.level)}">${escapeHtml(log.level)}</span></td>
              <td>${escapeHtml(log.endpoint) || '-'}</td>
              <td>${escapeHtml(log.statusCode) || '-'}</td>
              <td class="text-secondary">${escapeHtml(log.message)}</td>
            </tr>
            <tr class="debug-row-detail" style="display: none; background: #fafafa;">
              <td colspan="5">
                <div style="padding: 0.5rem; font-family: monospace; font-size: 0.8rem; overflow-x: auto; white-space: pre-wrap;">
                  <strong>Request Body:</strong> ${escapeHtml(log.requestBody) || 'None'}<br/><br/>
                  <strong>Stack Trace:</strong><br/>${escapeHtml(log.stack) || 'No stack trace available'}
                </div>
              </td>
            </tr>
          `).join('');

          // Click handler to toggle detail
          const mainRows = document.querySelectorAll('.debug-row-main');
          mainRows.forEach((row) => {
            row.addEventListener('click', () => {
              const detailRow = row.nextElementSibling as HTMLTableRowElement;
              if (detailRow) {
                detailRow.style.display = detailRow.style.display === 'none' ? 'table-row' : 'none';
              }
            });
          });
        }

        const totalPages = Math.ceil(data.total / limit) || 1;
        (document.getElementById('debugPageInfo') as HTMLSpanElement).textContent = `Page ${debugPage} of ${totalPages}`;
        (document.getElementById('prevDebugPage') as HTMLButtonElement).disabled = debugPage <= 1;
        (document.getElementById('nextDebugPage') as HTMLButtonElement).disabled = debugPage >= totalPages;

      } catch (err: any) {
        debugLogsBody.innerHTML = `<tr><td colspan="5" class="text-center text-secondary">Error: ${escapeHtml(err.message)}</td></tr>`;
      }
    }

    // Attach filters
    document.getElementById('applyAuditFilter')?.addEventListener('click', () => {
      auditPage = 1;
      loadAuditLogs();
    });
    document.getElementById('applyDebugFilter')?.addEventListener('click', () => {
      debugPage = 1;
      loadDebugLogs();
    });

    // Attach Pager
    document.getElementById('prevAuditPage')?.addEventListener('click', () => {
      if (auditPage > 1) {
        auditPage--;
        loadAuditLogs();
      }
    });
    document.getElementById('nextAuditPage')?.addEventListener('click', () => {
      auditPage++;
      loadAuditLogs();
    });
    document.getElementById('prevDebugPage')?.addEventListener('click', () => {
      if (debugPage > 1) {
        debugPage--;
        loadDebugLogs();
      }
    });
    document.getElementById('nextDebugPage')?.addEventListener('click', () => {
      debugPage++;
      loadDebugLogs();
    });

    // Initial load
    loadAuditLogs();
  }
</script>
