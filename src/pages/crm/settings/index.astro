    border-bottom: 2px solid transparent;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-secondary);
    cursor: pointer;
    margin-bottom: -2px;
    transition: all 0.15s;
  }

  :global(.tab-btn:hover) {
    color: var(--primary);
  }

  :global(.tab-btn.active) {
    color: var(--primary);
    border-bottom-color: var(--primary);
  }

  :global(.tab-content) {
    display: none;
  }

  :global(.tab-content.active) {
    display: block;
  }

  :global(.log-filters) {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  :global(.pagination-row) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 1rem;
    font-size: 0.8rem;
    color: var(--text-secondary);
  }

  :global(.btn-pager) {
    padding: 0.35rem 0.75rem;
    background: white;
    border: 1px solid var(--border-color);
    font-size: 0.75rem;
