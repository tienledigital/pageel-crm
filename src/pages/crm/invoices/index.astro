---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import { env } from 'cloudflare:workers';
import { getDb } from '@/lib/db';
import { invoices, customers, staff } from '@/lib/db/schema';
import { desc, eq, like, and, or, sql } from 'drizzle-orm';

const db = getDb(env);
const lang = Astro.locals.lang || 'vi';
const user = Astro.locals.user;

// Fetch list of customers for edit modal
const customersList = await db.select({
  id: customers.id,
  fullName: customers.fullName,
  phone: customers.phone,
}).from(customers).all();

// 1. Parse query parameters
const url = new URL(Astro.request.url);
const search = url.searchParams.get('search') || '';
const statusFilter = url.searchParams.get('status') || ''; // 'paid', 'pending', 'cancelled'

// 2. Build where clause
const conditions = [];

if (search) {
  conditions.push(
    or(
      like(invoices.invoiceNumber, `%${search}%`),
      like(invoices.content, `%${search}%`),
      like(customers.fullName, `%${search}%`),
      like(invoices.taxInvoiceNumber, `%${search}%`)
    )
  );
}

if (statusFilter) {
  conditions.push(eq(invoices.status, statusFilter));
}

const whereClause = conditions.length > 0 ? and(...conditions) : undefined;

// 3. Query invoices
const invoiceList = await db
  .select({
    id: invoices.id,
    invoiceNumber: invoices.invoiceNumber,
    amount: invoices.amount,
    content: invoices.content,
    status: invoices.status,
    taxInvoiceNumber: invoices.taxInvoiceNumber,
    createdAt: invoices.createdAt,
    paidAt: invoices.paidAt,
    customerName: customers.fullName,
    customerId: customers.id,
    staffName: staff.fullName,
  })
  .from(invoices)
  .leftJoin(customers, eq(invoices.customerId, customers.id))
  .leftJoin(staff, eq(invoices.staffId, staff.id))
  .where(whereClause)
  .orderBy(desc(invoices.createdAt));

// 4. Calculate Invoice Metrics
const stats = await db
  .select({
    status: invoices.status,
    totalAmount: sql<number>`SUM(${invoices.amount})`,
    count: sql<number>`COUNT(${invoices.id})`,
  })
  .from(invoices)
  .groupBy(invoices.status);

let totalInvoiced = 0;
let totalCollected = 0;
let pendingCollected = 0;
let countPaid = 0;
let countPending = 0;

stats.forEach((stat: any) => {
  const amt = Number(stat.totalAmount || 0);
  const cnt = Number(stat.count || 0);
  totalInvoiced += amt;
  
  if (stat.status === 'paid') {
    totalCollected = amt;
    countPaid = cnt;
  } else if (stat.status === 'pending') {
    pendingCollected = amt;
    countPending = cnt;
  }
});

function formatVND(amount: number) {
  return new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(amount);
}

function formatDate(timestamp: number | null) {
  if (!timestamp) return 'N/A';
  return new Date(timestamp).toLocaleDateString('vi-VN', {
    timeZone: 'Asia/Ho_Chi_Minh',
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  });
}
---

<DashboardLayout title={lang === 'vi' ? 'Quản lý Hóa đơn' : 'Invoices Management'}>
  <style>
    .header-container {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 2rem;
      flex-wrap: wrap;
      gap: 1rem;
    }

    .title-section h1 {
      font-size: 1.75rem;
      font-weight: 700;
      color: var(--text-primary);
    }

    .title-section p {
      font-size: 0.875rem;
      color: var(--text-secondary);
      margin-top: 0.25rem;
    }

    /* Stats Grid */
    .stats-banner {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 1.5rem;
      margin-bottom: 2rem;
    }

    .stat-card {
      background-color: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: 16px;
      padding: 1.5rem;
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .stat-icon {
      width: 48px;
      height: 48px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .stat-icon.invoiced {
      background-color: rgba(99, 102, 241, 0.1);
      color: var(--primary);
    }

    .stat-icon.collected {
      background-color: rgba(16, 185, 129, 0.1);
      color: var(--success);
    }

    .stat-icon.pending {
      background-color: rgba(245, 158, 11, 0.1);
      color: #f59e0b;
    }

    .stat-details {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }

    .stat-label {
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .stat-value {
      font-size: 1.35rem;
      font-weight: 700;
      color: var(--text-primary);
    }

    /* Filter Bar */
    .filter-bar {
      display: flex;
      gap: 1rem;
      margin-bottom: 1.5rem;
      flex-wrap: wrap;
    }

    .search-input {
      flex-grow: 1;
      min-width: 240px;
      background-color: var(--bg-card);
      border: 1px solid var(--border-color);
      color: var(--text-primary);
      padding: 0.65rem 1rem;
      border-radius: 8px;
      font-size: 0.875rem;
      outline: none;
      transition: border-color 0.2s;
    }

    .search-input:focus {
      border-color: var(--primary);
    }

    .select-filter {
      background-color: var(--bg-card);
      border: 1px solid var(--border-color);
      color: var(--text-primary);
      padding: 0.65rem 1rem;
      border-radius: 8px;
      font-size: 0.875rem;
      outline: none;
      cursor: pointer;
    }

    .btn-filter {
      background-color: var(--primary);
      border: 1px solid var(--primary);
      color: #fff;
      padding: 0.65rem 1.25rem;
      border-radius: 8px;
      font-size: 0.875rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
    }

    .btn-filter:hover {
      box-shadow: 0 4px 12px rgba(99, 102, 241, 0.2);
    }

    /* Main Table Panel */
    .card-container {
      background-color: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: 16px;
      padding: 1.5rem;
      overflow: hidden;
    }

    .table-responsive {
      overflow-x: auto;
    }

    .custom-table {
      width: 100%;
      border-collapse: collapse;
      text-align: left;
    }

    .custom-table th {
      padding: 1rem;
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      border-bottom: 1px solid var(--border-color);
    }

    .custom-table td {
      padding: 1.15rem 1rem;
      font-size: 0.875rem;
      border-bottom: 1px solid var(--border-color);
      color: var(--text-primary);
      vertical-align: middle;
    }

    .custom-table tr:last-child td {
      border-bottom: none;
    }

    /* Badges */
    .badge {
      display: inline-flex;
      align-items: center;
      padding: 0.25rem 0.6rem;
      border-radius: 9999px;
      font-size: 0.75rem;
      font-weight: 600;
    }

    .badge-paid {
      background-color: rgba(16, 185, 129, 0.1);
      color: var(--success);
      border: 1px solid rgba(16, 185, 129, 0.2);
    }

    .badge-pending {
      background-color: rgba(245, 158, 11, 0.1);
      color: #f59e0b;
      border: 1px solid rgba(245, 158, 11, 0.2);
    }

    .badge-cancelled {
      background-color: rgba(239, 68, 68, 0.1);
      color: var(--error);
      border: 1px solid rgba(239, 68, 68, 0.2);
    }

    .mono {
      font-family: monospace;
      color: var(--text-primary);
    }

    .btn-action {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      padding: 0.45rem 0.75rem;
      background-color: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: 6px;
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--text-primary);
      cursor: pointer;
      transition: all 0.2s;
      text-decoration: none;
    }

    .btn-action:hover {
      background-color: var(--primary);
      border-color: var(--primary);
      color: #fff;
    }

    .btn-reset {
      background-color: transparent;
      border: 1px solid var(--border-color);
      color: var(--text-secondary);
      padding: 0.65rem 1.25rem;
      border-radius: 8px;
      font-size: 0.875rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
      text-decoration: none;
    }

    .btn-reset:hover {
      background-color: var(--bg-hover);
      color: var(--text-primary);
    }

    /* Mobile Card Layout Styles */
    .mobile-card-grid {
      display: none;
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .mobile-card {
      background-color: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.25rem;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      position: relative;
    }

    .mobile-card-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 0.75rem;
    }

    .mobile-card-body {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      font-size: 0.875rem;
      color: var(--text-primary);
    }

    .mobile-card-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .mobile-card-label {
      font-size: 0.75rem;
      color: var(--text-secondary);
      font-weight: 500;
    }

    .mobile-card-value {
      font-weight: 500;
    }

    .mobile-card-footer {
      border-top: 1px solid var(--border-color);
      padding-top: 0.75rem;
      display: flex;
      justify-content: flex-end;
    }

    /* Modal Styles */
    .modal-backdrop {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background-color: rgba(0, 0, 0, 0.6);
      backdrop-filter: blur(4px);
      z-index: 1000;
      justify-content: center;
      align-items: center;
    }

    .modal-content {
      background-color: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: 16px;
      padding: 2rem;
      width: 100%;
      max-width: 500px;
      box-shadow: 0 10px 25px rgba(0,0,0,0.5);
      animation: scale-up 0.2s ease-out;
    }

    @keyframes scale-up {
      from { transform: scale(0.95); opacity: 0; }
      to { transform: scale(1); opacity: 1; }
    }

    .modal-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1.5rem;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 0.75rem;
    }

    .modal-header h3 {
      font-size: 1.25rem;
      font-weight: 700;
      color: var(--text-primary);
      margin: 0;
    }

    .modal-close {
      background: none;
      border: none;
      color: var(--text-secondary);
      font-size: 1.5rem;
      cursor: pointer;
      padding: 0;
      line-height: 1;
    }

    .form-group {
      margin-bottom: 1.25rem;
    }

    .form-group label {
      display: block;
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--text-secondary);
      text-transform: uppercase;
      margin-bottom: 0.5rem;
      letter-spacing: 0.5px;
    }

    .form-select, .form-input {
      width: 100%;
      background-color: var(--bg-hover);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      color: var(--text-primary);
      padding: 0.65rem 0.85rem;
      font-size: 0.875rem;
      outline: none;
      transition: border-color 0.2s;
    }

    .form-select:focus, .form-input:focus {
      border-color: var(--primary);
    }

    .modal-footer {
      display: flex;
      justify-content: flex-end;
      gap: 1rem;
      margin-top: 2rem;
    }

    .btn-cancel {
      background-color: transparent;
      border: 1px solid var(--border-color);
      color: var(--text-secondary);
      padding: 0.65rem 1.25rem;
      border-radius: 8px;
      font-size: 0.875rem;
      font-weight: 600;
      cursor: pointer;
    }

    .btn-cancel:hover {
      background-color: var(--bg-hover);
      color: var(--text-primary);
    }

    .btn-save {
      background-color: var(--primary);
      border: 1px solid var(--primary);
      color: #fff;
      padding: 0.65rem 1.25rem;
      border-radius: 8px;
      font-size: 0.875rem;
      font-weight: 600;
      cursor: pointer;
    }

    .btn-save:hover {
      box-shadow: 0 4px 12px rgba(255, 93, 1, 0.25);
    }

    @media (max-width: 768px) {
      .table-responsive {
        display: none;
      }
      .mobile-card-grid {
        display: grid;
      }
      .card-container {
        padding: 0.75rem;
      }
    }
  </style>

  <!-- Stats Grid -->
  <div class="stats-banner">
    <!-- Total Invoiced -->
    <div class="stat-card">
      <div class="stat-icon invoiced">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 24px; height: 24px;">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
        </svg>
      </div>
      <div class="stat-details">
        <span class="stat-label">{lang === 'vi' ? 'Tổng giá trị hóa đơn' : 'Total Invoiced'}</span>
        <span class="stat-value">{formatVND(totalInvoiced)}</span>
        <span style="font-size: 0.75rem; color: var(--text-secondary);">{lang === 'vi' ? `Từ ${invoiceList.length} hóa đơn` : `From ${invoiceList.length} invoices`}</span>
      </div>
    </div>

    <!-- Collected -->
    <div class="stat-card">
      <div class="stat-icon collected">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 24px; height: 24px;">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
      <div class="stat-details">
        <span class="stat-label">{lang === 'vi' ? 'Đã thu hồi' : 'Total Collected'}</span>
        <span class="stat-value" style="color: var(--success);">{formatVND(totalCollected)}</span>
        <span style="font-size: 0.75rem; color: var(--text-secondary);">{lang === 'vi' ? `${countPaid} hóa đơn đã thanh toán` : `${countPaid} paid invoices`}</span>
      </div>
    </div>

    <!-- Outstanding (Pending) -->
    <div class="stat-card">
      <div class="stat-icon pending">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 24px; height: 24px;">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
      <div class="stat-details">
        <span class="stat-label">{lang === 'vi' ? 'Chưa thanh toán' : 'Outstanding'}</span>
        <span class="stat-value" style="color: #f59e0b;">{formatVND(pendingCollected)}</span>
        <span style="font-size: 0.75rem; color: var(--text-secondary);">{lang === 'vi' ? `${countPending} hóa đơn chưa thanh toán` : `${countPending} pending invoices`}</span>
      </div>
    </div>
  </div>

  <!-- Filters -->
  <form method="GET" class="filter-bar">
    <input 
      type="text" 
      name="search" 
      placeholder={lang === 'vi' ? 'Tìm kiếm theo mã hóa đơn, nội dung, khách hàng hoặc số HĐ thuế...' : 'Search by invoice number, content, customer, or tax number...'} 
      value={search} 
      class="search-input" 
    />
    <select name="status" class="select-filter">
      <option value="">{lang === 'vi' ? 'Tất cả trạng thái' : 'All Statuses'}</option>
      <option value="paid" selected={statusFilter === 'paid'}>{lang === 'vi' ? 'Đã thanh toán (Paid)' : 'Paid'}</option>
      <option value="pending" selected={statusFilter === 'pending'}>{lang === 'vi' ? 'Chưa thanh toán (Pending)' : 'Pending'}</option>
      <option value="cancelled" selected={statusFilter === 'cancelled'}>{lang === 'vi' ? 'Đã hủy (Cancelled)' : 'Cancelled'}</option>
    </select>
    <button type="submit" class="btn-filter">{lang === 'vi' ? 'Lọc hóa đơn' : 'Apply Filters'}</button>
    {(search || statusFilter) && (
      <a href="/crm/invoices" class="btn-reset">{lang === 'vi' ? 'Đặt lại' : 'Reset'}</a>
    )}
  </form>

  <!-- Table -->
  <div class="card-container">
    <!-- Desktop Table View -->
    <div class="table-responsive table-scroll-container">
      <table class="custom-table">
        <thead>
          <tr>
            <th>{lang === 'vi' ? 'Mã hóa đơn' : 'Invoice Number'}</th>
            <th>{lang === 'vi' ? 'Khách hàng' : 'Customer'}</th>
            <th>{lang === 'vi' ? 'Mô tả / Nội dung' : 'Description'}</th>
            <th>{lang === 'vi' ? 'Số HĐ Thuế' : 'Tax Invoice No'}</th>
            <th>{lang === 'vi' ? 'Số tiền' : 'Amount'}</th>
            <th>{lang === 'vi' ? 'Trạng thái' : 'Status'}</th>
            <th>{lang === 'vi' ? 'Ngày phát hành' : 'Issued Date'}</th>
            <th>{lang === 'vi' ? 'Thao tác' : 'Actions'}</th>
          </tr>
        </thead>
        <tbody>
          {invoiceList.length === 0 ? (
            <tr>
              <td colspan="8" style="text-align: center; padding: 3rem; color: var(--text-secondary);">
                {lang === 'vi' ? 'Không có hóa đơn nào khớp với điều kiện tìm kiếm.' : 'No invoices matching the criteria.'}
              </td>
            </tr>
          ) : (
            invoiceList.map((invoice: any) => (
              <tr>
                <td>
                  <span class="mono" style="font-weight: 600;">{invoice.invoiceNumber}</span>
                </td>
                <td>
                  {invoice.customerName ? (
                    <a href={`/crm/customers?search=${invoice.customerName}`} style="color: var(--primary); font-weight: 500; text-decoration: none;">
                      {invoice.customerName}
                    </a>
                  ) : (
                    <span style="color: var(--text-secondary);">N/A</span>
                  )}
                </td>
                <td>
                  <div>
                    <span>{invoice.content}</span>
                    <div style="font-size: 0.75rem; color: var(--text-secondary); margin-top: 0.15rem;">
                      {lang === 'vi' ? 'Nhân sự' : 'Staff'}: {invoice.staffName || (lang === 'vi' ? 'Chưa phân công' : 'Unassigned')}
                    </div>
                  </div>
                </td>
                <td>
                  <span class="mono" style="font-weight: 500; color: var(--text-primary);">
                    {invoice.taxInvoiceNumber || (lang === 'vi' ? 'Chưa có' : 'None')}
                  </span>
                </td>
                <td>
                  <span style="font-weight: 600; color: var(--text-primary);">{formatVND(invoice.amount)}</span>
                </td>
                <td>
                  <span class={`badge badge-${invoice.status}`}>
                    {invoice.status === 'paid' && (lang === 'vi' ? 'Đã thanh toán' : 'Paid')}
                    {invoice.status === 'pending' && (lang === 'vi' ? 'Chưa thanh toán' : 'Pending')}
                    {invoice.status === 'cancelled' && (lang === 'vi' ? 'Đã hủy' : 'Cancelled')}
                  </span>
                </td>
                <td>
                  <span>{formatDate(invoice.createdAt)}</span>
                </td>
                <td>
                  <div style="display: flex; gap: 0.5rem; align-items: center;">
                    <a href={`/crm/qr-tool?invoiceId=${invoice.id}`} class="btn-action">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 14px; height: 14px;">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5A1.125 1.125 0 013.75 9.375v-4.5zM3.75 14.625c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5a1.125 1.125 0 01-1.125-1.125v-4.5zM13.5 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5A1.125 1.125 0 0113.5 9.375v-4.5zM6.75 6.75h.75v.75h-.75v-.75zM6.75 16.5h.75v.75h-.75v-.75zM16.5 6.75h.75v.75h-.75v-.75zM13.5 13.5h.75v.75h-.75v-.75zM16.5 16.5h.75v.75h-.75v-.75zM13.5 16.5h.75v.75h-.75v-.75zM16.5 13.5h.75v.75h-.75v-.75z" />
                      </svg>
                      {lang === 'vi' ? 'Thanh toán QR' : 'Pay QR'}
                    </a>
                    {user && (user.role === 'admin' || user.role === 'accountant') && (
                      <>
                        <button class="btn-action edit-tax-btn" data-id={invoice.id} data-number={invoice.invoiceNumber} data-tax={invoice.taxInvoiceNumber || ''}>
                          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 14px; height: 14px;">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L6.832 19.82a4.5 4.5 0 01-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 011.13-1.897L16.863 4.487zm0 0L19.5 7.125" />
                          </svg>
                          {lang === 'vi' ? 'HĐ Thuế' : 'Tax HĐ'}
                        </button>
                        <button 
                          class="btn-action edit-invoice-btn" 
                          data-id={invoice.id} 
                          data-number={invoice.invoiceNumber} 
                          data-customer-id={invoice.customerId || ''} 
                          data-amount={invoice.amount} 
                          data-content={invoice.content}
                        >
                          ✏️ {lang === 'vi' ? 'Sửa' : 'Edit'}
                        </button>
                        <button 
                          class="btn-action delete-invoice-btn" 
                          data-id={invoice.id} 
                          data-number={invoice.invoiceNumber} 
                          style="color: var(--error);"
                        >
                          🗑️ {lang === 'vi' ? 'Xóa' : 'Delete'}
                        </button>
                      </>
                    )}
                  </div>
                </td>
              </tr>
            ))
          )}
        </tbody>
      </table>
    </div>

    <!-- Mobile Card View -->
    <div class="mobile-card-grid">
      {invoiceList.length === 0 ? (
        <div style="text-align: center; padding: 2rem; color: var(--text-secondary);">
          {lang === 'vi' ? 'Không có hóa đơn nào khớp với điều kiện tìm kiếm.' : 'No invoices matching the criteria.'}
        </div>
      ) : (
        invoiceList.map((invoice: any) => (
          <div class="mobile-card">
            <div class="mobile-card-header">
              <div style="display: flex; flex-direction: column; gap: 0.25rem;">
                <span class="mono" style="font-weight: 600; color: var(--text-primary);">{invoice.invoiceNumber}</span>
                {invoice.customerName ? (
                  <a href={`/crm/customers?search=${invoice.customerName}`} style="color: var(--primary); font-weight: 500; font-size: 0.875rem; text-decoration: none;">
                    {invoice.customerName}
                  </a>
                ) : (
                  <span style="color: var(--text-secondary); font-size: 0.875rem;">N/A</span>
                )}
              </div>
              <span class={`badge badge-${invoice.status}`}>
                {invoice.status === 'paid' && (lang === 'vi' ? 'Đã thanh toán' : 'Paid')}
                {invoice.status === 'pending' && (lang === 'vi' ? 'Chưa thanh toán' : 'Pending')}
                {invoice.status === 'cancelled' && (lang === 'vi' ? 'Đã hủy' : 'Cancelled')}
              </span>
            </div>
            
            <div class="mobile-card-body">
              <div class="mobile-card-row">
                <span class="mobile-card-label">{lang === 'vi' ? 'Mô tả / Nội dung' : 'Description'}</span>
                <span class="mobile-card-value" style="text-align: right;">{invoice.content}</span>
              </div>
              <div class="mobile-card-row">
                <span class="mobile-card-label">{lang === 'vi' ? 'Số HĐ Thuế' : 'Tax Invoice No'}</span>
                <span class="mobile-card-value mono">{invoice.taxInvoiceNumber || (lang === 'vi' ? 'Chưa có' : 'None')}</span>
              </div>
              <div class="mobile-card-row">
                <span class="mobile-card-label">{lang === 'vi' ? 'Số tiền' : 'Amount'}</span>
                <span class="mobile-card-value" style="font-weight: 600; color: var(--text-primary);">{formatVND(invoice.amount)}</span>
              </div>
              <div class="mobile-card-row">
                <span class="mobile-card-label">{lang === 'vi' ? 'Ngày phát hành' : 'Issued Date'}</span>
                <span class="mobile-card-value">{formatDate(invoice.createdAt)}</span>
              </div>
              <div class="mobile-card-row">
                <span class="mobile-card-label">{lang === 'vi' ? 'Nhân sự' : 'Staff'}</span>
                <span class="mobile-card-value" style="font-size: 0.75rem; color: var(--text-secondary);">{invoice.staffName || (lang === 'vi' ? 'Chưa phân công' : 'Unassigned')}</span>
              </div>
            </div>

            <div class="mobile-card-footer" style="display: flex; gap: 0.5rem; width: 100%;">
              <a href={`/crm/qr-tool?invoiceId=${invoice.id}`} class="btn-action" style="flex: 1; justify-content: center;">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 14px; height: 14px;">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5A1.125 1.125 0 013.75 9.375v-4.5zM3.75 14.625c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5a1.125 1.125 0 01-1.125-1.125v-4.5zM13.5 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5A1.125 1.125 0 0113.5 9.375v-4.5zM6.75 6.75h.75v.75h-.75v-.75zM6.75 16.5h.75v.75h-.75v-.75zM16.5 6.75h.75v.75h-.75v-.75zM13.5 13.5h.75v.75h-.75v-.75zM16.5 16.5h.75v.75h-.75v-.75zM13.5 16.5h.75v.75h-.75v-.75zM16.5 13.5h.75v.75h-.75v-.75z" />
                </svg>
                {lang === 'vi' ? 'Thanh toán' : 'Pay'}
              </a>
              {user && (user.role === 'admin' || user.role === 'accountant') && (
                <button class="btn-action edit-tax-btn" data-id={invoice.id} data-number={invoice.invoiceNumber} data-tax={invoice.taxInvoiceNumber || ''} style="flex: 1; justify-content: center;">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 14px; height: 14px;">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L6.832 19.82a4.5 4.5 0 01-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 011.13-1.897L16.863 4.487zm0 0L19.5 7.125" />
                  </svg>
                  {lang === 'vi' ? 'HĐ Thuế' : 'Tax HĐ'}
                </button>
              )}
            </div>
            {user && (user.role === 'admin' || user.role === 'accountant') && (
              <div style="display: flex; gap: 0.5rem; width: 100%; margin-top: 0.25rem;">
                <button 
                  class="btn-action edit-invoice-btn" 
                  data-id={invoice.id} 
                  data-number={invoice.invoiceNumber} 
                  data-customer-id={invoice.customerId || ''} 
                  data-amount={invoice.amount} 
                  data-content={invoice.content} 
                  style="flex: 1; justify-content: center;"
                >
                  ✏️ {lang === 'vi' ? 'Sửa' : 'Edit'}
                </button>
                <button 
                  class="btn-action delete-invoice-btn" 
                  data-id={invoice.id} 
                  data-number={invoice.invoiceNumber} 
                  style="flex: 1; justify-content: center; color: var(--error);"
                >
                  🗑️ {lang === 'vi' ? 'Xóa' : 'Delete'}
                </button>
              </div>
            )}
          </div>
        ))
      )}
    </div>
  </div>

  <!-- Edit Tax Invoice Modal -->
  <div class="modal-backdrop" id="editTaxModal">
    <div class="modal-content">
      <div class="modal-header">
        <h3>{lang === 'vi' ? 'Cập nhật hóa đơn thuế VAT' : 'Update Tax Invoice Number'}</h3>
        <button class="modal-close" id="taxModalCloseBtn">&times;</button>
      </div>
      <div class="modal-body">
        <form id="editTaxForm">
          <input type="hidden" id="taxInvoiceId" />
          <div class="form-group">
            <label for="taxInvoiceNumberInput" id="taxModalLabel" style="margin-bottom: 0.5rem; display: block; font-weight: 500; font-size: 0.875rem;"></label>
            <input 
              type="text" 
              id="taxInvoiceNumberInput" 
              placeholder={lang === 'vi' ? 'Ví dụ: 0001234...' : 'e.g. 0001234...'} 
              class="form-input"
            />
          </div>

          <div class="modal-footer">
            <button type="button" class="btn-cancel" id="taxModalCancelBtn">{lang === 'vi' ? 'Hủy' : 'Cancel'}</button>
            <button type="submit" class="btn-save">{lang === 'vi' ? 'Cập nhật' : 'Update'}</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Edit Invoice Modal -->
  <div class="modal-backdrop" id="editInvoiceModal">
    <div class="modal-content" style="max-width: 500px;">
      <div class="modal-header">
        <h3>{lang === 'vi' ? 'Chỉnh sửa hóa đơn' : 'Edit Invoice'} <span id="editInvoiceNumber" class="mono"></span></h3>
        <button class="modal-close" id="invoiceModalCloseBtn">&times;</button>
      </div>
      <div class="modal-body">
        <form id="editInvoiceForm" style="display: flex; flex-direction: column;">
          <input type="hidden" id="editInvoiceId" />
          
          <div class="form-group">
            <label for="editInvoiceCustomer">{lang === 'vi' ? 'Khách hàng' : 'Customer'}</label>
            <select id="editInvoiceCustomer" class="form-select" required>
              <option value="">{lang === 'vi' ? '-- Chọn khách hàng --' : '-- Select Customer --'}</option>
              {customersList.map((cust: any) => (
                <option value={cust.id}>{cust.fullName} ({cust.phone})</option>
              ))}
            </select>
          </div>

          <div class="form-group">
            <label for="editInvoiceAmount">{lang === 'vi' ? 'Số tiền (VND)' : 'Amount (VND)'}</label>
            <input type="number" id="editInvoiceAmount" class="form-input" required min="0" />
          </div>

          <div class="form-group">
            <label for="editInvoiceContent">{lang === 'vi' ? 'Mô tả / Nội dung' : 'Description'}</label>
            <input type="text" id="editInvoiceContent" class="form-input" required />
          </div>

          <div class="modal-footer" style="margin-top: 1.5rem;">
            <button type="button" class="btn-cancel" id="invoiceModalCancelBtn">{lang === 'vi' ? 'Hủy bỏ' : 'Cancel'}</button>
            <button type="submit" class="btn-save">{lang === 'vi' ? 'Cập nhật' : 'Update'}</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script define:vars={{ lang }}>
    window.CRM_LANG = lang;
  </script>

  <script is:inline>
    // Modal elements
    const taxModal = document.getElementById('editTaxModal');
    const taxModalCloseBtn = document.getElementById('taxModalCloseBtn');
    const taxModalCancelBtn = document.getElementById('taxModalCancelBtn');
    const editTaxForm = document.getElementById('editTaxForm');
    const taxInvoiceIdInput = document.getElementById('taxInvoiceId');
    const taxInvoiceNumberInput = document.getElementById('taxInvoiceNumberInput');
    const taxModalLabel = document.getElementById('taxModalLabel');

    function closeTaxModal() {
      if (taxModal) taxModal.style.display = 'none';
    }

    if (taxModalCloseBtn) taxModalCloseBtn.addEventListener('click', closeTaxModal);
    if (taxModalCancelBtn) taxModalCancelBtn.addEventListener('click', closeTaxModal);

    window.addEventListener('click', (e) => {
      if (e.target === taxModal) closeTaxModal();
    });

    document.addEventListener('click', (e) => {
      const editBtn = e.target.closest('.edit-tax-btn');
      if (editBtn) {
        const id = editBtn.dataset.id;
        const number = editBtn.dataset.number;
        const tax = editBtn.dataset.tax;

        taxInvoiceIdInput.value = id;
        taxInvoiceNumberInput.value = tax;
        taxModalLabel.textContent = `Số HĐ thuế cho ${number}`;
        taxModal.style.display = 'flex';
      }
    });

    if (editTaxForm) {
      editTaxForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const id = taxInvoiceIdInput.value;
        const taxInvoiceNumber = taxInvoiceNumberInput.value.trim();

        try {
          const res = await fetch(`/api/crm/invoices/${id}/tax-number`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ taxInvoiceNumber })
          });

          if (res.ok) {
            closeTaxModal();
            window.location.reload();
          } else {
            const data = await res.json();
            alert((data.error || 'Failed to update tax invoice number'));
          }
        } catch (err) {
          console.error(err);
          alert('Network error, failed to update tax invoice number');
        }
      });
    }

    // Edit Invoice Modal Logic
    const editInvoiceModal = document.getElementById('editInvoiceModal');
    const invoiceModalCloseBtn = document.getElementById('invoiceModalCloseBtn');
    const invoiceModalCancelBtn = document.getElementById('invoiceModalCancelBtn');
    const editInvoiceForm = document.getElementById('editInvoiceForm');
    const editInvoiceIdInput = document.getElementById('editInvoiceId');
    const editInvoiceNumberSpan = document.getElementById('editInvoiceNumber');
    const editInvoiceCustomerSelect = document.getElementById('editInvoiceCustomer');
    const editInvoiceAmountInput = document.getElementById('editInvoiceAmount');
    const editInvoiceContentInput = document.getElementById('editInvoiceContent');

    function closeInvoiceModal() {
      if (editInvoiceModal) editInvoiceModal.style.display = 'none';
    }

    if (invoiceModalCloseBtn) invoiceModalCloseBtn.addEventListener('click', closeInvoiceModal);
    if (invoiceModalCancelBtn) invoiceModalCancelBtn.addEventListener('click', closeInvoiceModal);

    window.addEventListener('click', (e) => {
      if (e.target === editInvoiceModal) closeInvoiceModal();
    });

    document.addEventListener('click', async (e) => {
      // Handle Edit Invoice Button Click
      const editBtn = e.target.closest('.edit-invoice-btn');
      if (editBtn) {
        const id = editBtn.dataset.id;
        const number = editBtn.dataset.number;
        const customerId = editBtn.dataset.customerId;
        const amount = editBtn.dataset.amount;
        const content = editBtn.dataset.content;

        editInvoiceIdInput.value = id;
        editInvoiceNumberSpan.textContent = `(${number})`;
        editInvoiceCustomerSelect.value = customerId;
        editInvoiceAmountInput.value = amount;
        editInvoiceContentInput.value = content;
        
        editInvoiceModal.style.display = 'flex';
      }

      // Handle Delete Invoice Button Click
      const deleteBtn = e.target.closest('.delete-invoice-btn');
      if (deleteBtn) {
        const id = deleteBtn.dataset.id;
        const number = deleteBtn.dataset.number;
        const clientLang = window.CRM_LANG || 'vi';
        
        const confirmMsg = clientLang === 'vi' 
          ? `Bạn có chắc chắn muốn xóa hóa đơn ${number}? Hành động này không thể hoàn tác.`
          : `Are you sure you want to delete invoice ${number}? This action cannot be undone.`;
          
        if (confirm(confirmMsg)) {
          try {
            const res = await fetch(`/api/crm/invoices/${id}`, {
              method: 'DELETE'
            });
            
            const data = await res.json();
            if (res.ok && data.success) {
              window.location.reload();
            } else {
              alert(data.error || 'Failed to delete invoice');
            }
          } catch (err) {
            console.error(err);
            alert(clientLang === 'vi' ? 'Lỗi kết nối khi xóa hóa đơn.' : 'Network error, failed to delete invoice.');
          }
        }
      }
    });

    if (editInvoiceForm) {
      editInvoiceForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const id = editInvoiceIdInput.value;
        const customerId = editInvoiceCustomerSelect.value;
        const amount = Number(editInvoiceAmountInput.value);
        const content = editInvoiceContentInput.value.trim();
        const clientLang = window.CRM_LANG || 'vi';

        try {
          const res = await fetch(`/api/crm/invoices/${id}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ customerId, amount, content })
          });

          if (res.ok) {
            closeInvoiceModal();
            window.location.reload();
          } else {
            const data = await res.json();
            alert((data.error || 'Failed to update invoice'));
          }
        } catch (err) {
          console.error(err);
          alert(clientLang === 'vi' ? 'Lỗi kết nối khi cập nhật hóa đơn.' : 'Network error, failed to update invoice');
        }
      });
    }
  </script>
</DashboardLayout>
