---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import { env } from 'cloudflare:workers';
import { getDb } from '@/lib/db';
import { customers, staff } from '@/lib/db/schema';
import { desc, eq, like, and, or, sql } from 'drizzle-orm';

const db = getDb(env);

// 1. Parse query parameters
const url = new URL(Astro.request.url);
const search = url.searchParams.get('search') || '';
const statusFilter = url.searchParams.get('status') || ''; // 'active', 'expired', 'none'
const staffFilter = url.searchParams.get('staffId') || '';

// 2. Build where conditions
const conditions = [];

if (search) {
  conditions.push(
    or(
      like(customers.fullName, `%${search}%`),
      like(customers.phone, `%${search}%`),
      like(customers.email, `%${search}%`),
      like(customers.idCard, `%${search}%`),
      like(customers.id, `%${search}%`)
    )
  );
}

if (staffFilter) {
  conditions.push(eq(customers.assignedStaffId, staffFilter));
}

const now = Date.now();
if (statusFilter === 'active') {
  conditions.push(sql`${customers.expiredAt} >= ${now}`);
} else if (statusFilter === 'expired') {
  conditions.push(sql`${customers.expiredAt} < ${now}`);
} else if (statusFilter === 'none') {
  conditions.push(sql`${customers.expiredAt} IS NULL`);
}

const whereClause = conditions.length > 0 ? and(...conditions) : undefined;

// Query customers joining with staff to get assigned staff name
const customerList = await db
  .select({
    id: customers.id,
    fullName: customers.fullName,
    phone: customers.phone,
    email: customers.email,
    idCard: customers.idCard,
    expiredAt: customers.expiredAt,
    address: customers.address,
    taxCode: customers.taxCode,
    assignedStaffId: customers.assignedStaffId,
    notes: customers.notes,
    staffName: staff.fullName,
  })
  .from(customers)
  .leftJoin(staff, eq(customers.assignedStaffId, staff.id))
  .where(whereClause)
  .orderBy(desc(customers.id));

// Query all staff members for the dropdown
const staffList = await db.select().from(staff).orderBy(staff.fullName);

// Calculate Stats Metrics
const allCustomers = await db.select({ expiredAt: customers.expiredAt }).from(customers);
const totalCustomers = allCustomers.length;
const activeCustomers = allCustomers.filter((c: any) => c.expiredAt && c.expiredAt >= now).length;
const expiredCustomers = allCustomers.filter((c: any) => c.expiredAt && c.expiredAt < now).length;
const inactiveCustomers = allCustomers.filter((c: any) => !c.expiredAt).length;

// Helper function to format service expiration date
function formatExpiration(timestamp: number | null) {
  if (!timestamp) {
    return { text: 'No Service', class: 'badge-inactive' };
  }

  const now = Date.now();
  const date = new Date(timestamp);
  const formatted = date.toLocaleDateString('en-GB', { timeZone: 'Asia/Ho_Chi_Minh' }); // Formats as DD/MM/YYYY

  if (timestamp < now) {
    return { text: `Expired (${formatted})`, class: 'badge-expired' };
  }

  // Calculate days remaining
  const diffDays = Math.ceil((timestamp - now) / (1000 * 60 * 60 * 24));
  return { text: `${formatted} (${diffDays}d left)`, class: 'badge-active' };
}
---

<DashboardLayout title="Customers Management">
  <style>
    .header-container {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 2rem;
    }

    /* Stats Grid */
    .stats-banner {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 1.5rem;
      margin-bottom: 2rem;
    }

    .stat-card {
      background-color: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: 16px;
      padding: 1.5rem;
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .stat-icon {
      width: 48px;
      height: 48px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .stat-icon.customer-total {
      background-color: rgba(99, 102, 241, 0.1);
      color: var(--primary);
    }

    .stat-icon.customer-active {
      background-color: rgba(16, 185, 129, 0.1);
      color: var(--success);
    }

    .stat-icon.customer-expired {
      background-color: rgba(239, 68, 68, 0.1);
      color: var(--error);
    }

    .stat-details {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }

    .stat-label {
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .stat-value {
      font-size: 1.35rem;
      font-weight: 700;
      color: var(--text-primary);
    }

    /* Filter Bar */
    .filter-bar {
      display: flex;
      gap: 1rem;
      margin-bottom: 1.5rem;
      flex-wrap: wrap;
    }

    .search-input {
      flex-grow: 1;
      min-width: 240px;
      background-color: var(--bg-card);
      border: 1px solid var(--border-color);
      color: var(--text-primary);
      padding: 0.65rem 1rem;
      border-radius: 8px;
      font-size: 0.875rem;
      outline: none;
      transition: border-color 0.2s;
    }

    .search-input:focus {
      border-color: var(--primary);
    }

    .select-filter {
      background-color: var(--bg-card);
      border: 1px solid var(--border-color);
      color: var(--text-primary);
      padding: 0.65rem 1rem;
      border-radius: 8px;
      font-size: 0.875rem;
      outline: none;
      cursor: pointer;
    }

    .btn-filter {
      background-color: var(--primary);
      border: 1px solid var(--primary);
      color: #fff;
      padding: 0.65rem 1.25rem;
      border-radius: 8px;
      font-size: 0.875rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
    }

    .btn-filter:hover {
      box-shadow: 0 4px 12px rgba(99, 102, 241, 0.25);
    }

    .btn-reset {
      background-color: transparent;
      border: 1px solid var(--border-color);
      color: var(--text-secondary);
      padding: 0.65rem 1.25rem;
      border-radius: 8px;
      font-size: 0.875rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
      text-decoration: none;
    }

    .btn-reset:hover {
      background-color: var(--bg-hover);
      color: var(--text-primary);
    }

    .card-container {
      background-color: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: 16px;
      padding: 1.5rem;
      overflow: hidden;
    }

    .table-responsive {
      overflow-x: auto;
    }

    .custom-table {
      width: 100%;
      border-collapse: collapse;
      text-align: left;
    }

    .custom-table th {
      padding: 1rem;
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      border-bottom: 1px solid var(--border-color);
    }

    .custom-table td {
      padding: 1.25rem 1rem;
      font-size: 0.875rem;
      border-bottom: 1px solid var(--border-color);
      color: var(--text-primary);
      vertical-align: middle;
    }

    .custom-table tr:last-child td {
      border-bottom: none;
    }

    .customer-info {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }

    .customer-name {
      font-weight: 600;
      color: var(--text-primary);
    }

    .customer-id {
      font-size: 0.75rem;
      color: var(--text-secondary);
      background-color: var(--bg-hover);
      padding: 0.15rem 0.4rem;
      border-radius: 4px;
      width: fit-content;
      font-family: monospace;
    }

    /* Badges */
    .badge {
      display: inline-flex;
      align-items: center;
      padding: 0.35rem 0.75rem;
      border-radius: 9999px;
      font-size: 0.75rem;
      font-weight: 600;
    }

    .badge-active {
      background-color: rgba(16, 185, 129, 0.1);
      color: var(--success);
      border: 1px solid rgba(16, 185, 129, 0.2);
    }

    .badge-expired {
      background-color: rgba(239, 68, 68, 0.1);
      color: var(--error);
      border: 1px solid rgba(239, 68, 68, 0.2);
    }

    .badge-inactive {
      background-color: rgba(107, 114, 128, 0.1);
      color: var(--text-secondary);
      border: 1px solid rgba(107, 114, 128, 0.2);
    }

    /* Actions Button */
    .btn-action {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.5rem 0.85rem;
      background-color: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--text-primary);
      cursor: pointer;
      transition: all 0.2s ease;
      text-decoration: none;
    }

    .btn-action:hover {
      background-color: var(--primary);
      border-color: var(--primary);
      color: #fff;
      box-shadow: 0 4px 12px rgba(99, 102, 241, 0.25);
    }

    .btn-action svg {
      width: 14px;
      height: 14px;
    }

    /* Mobile Responsive Card Grid */
    .mobile-card-grid {
      display: none;
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .mobile-card {
      background-color: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.25rem;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      position: relative;
    }

    .mobile-card-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 0.75rem;
    }

    .mobile-card-body {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      font-size: 0.875rem;
      color: var(--text-primary);
    }

    .mobile-card-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .mobile-card-label {
      font-size: 0.75rem;
      color: var(--text-secondary);
      font-weight: 500;
    }

    .mobile-card-value {
      font-weight: 500;
    }

    .mobile-card-footer {
      border-top: 1px solid var(--border-color);
      padding-top: 0.75rem;
      display: flex;
      justify-content: flex-end;
    }

    @media (max-width: 768px) {
      .table-responsive {
        display: none;
      }
      .mobile-card-grid {
        display: grid;
      }
      .card-container {
        padding: 0.75rem;
      }
    }

    /* Modal Styles */
    .modal-backdrop {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background-color: rgba(0, 0, 0, 0.6);
      backdrop-filter: blur(4px);
      z-index: 1000;
      justify-content: center;
      align-items: center;
    }

    .modal-content {
      background-color: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: 16px;
      padding: 2rem;
      width: 100%;
      max-width: 600px;
      box-shadow: 0 10px 25px rgba(0,0,0,0.5);
      animation: scale-up 0.2s ease-out;
      max-height: 90vh;
      overflow-y: auto;
    }

    @keyframes scale-up {
      from { transform: scale(0.95); opacity: 0; }
      to { transform: scale(1); opacity: 1; }
    }

    .modal-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1.5rem;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 0.75rem;
    }

    .modal-header h3 {
      font-size: 1.25rem;
      font-weight: 700;
      color: var(--text-primary);
      margin: 0;
    }

    .modal-close {
      background: none;
      border: none;
      color: var(--text-secondary);
      font-size: 1.5rem;
      cursor: pointer;
      padding: 0;
      line-height: 1;
    }

    .modal-close:hover {
      color: var(--text-primary);
    }

    .form-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }

    @media (max-width: 600px) {
      .form-grid {
        grid-template-columns: 1fr;
      }
    }

    .form-group {
      margin-bottom: 1.25rem;
    }

    .form-group.full-width {
      grid-column: span 2;
    }

    @media (max-width: 600px) {
      .form-group.full-width {
        grid-column: span 1;
      }
    }

    .form-group label {
      display: block;
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--text-secondary);
      text-transform: uppercase;
      margin-bottom: 0.5rem;
      letter-spacing: 0.5px;
    }

    .form-select, .form-input, .form-textarea {
      width: 100%;
      background-color: var(--bg-hover);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      color: var(--text-primary);
      padding: 0.65rem 0.85rem;
      font-size: 0.875rem;
      outline: none;
      transition: border-color 0.2s;
    }

    .form-textarea {
      resize: vertical;
      min-height: 80px;
    }

    .form-select:focus, .form-input:focus, .form-textarea:focus {
      border-color: var(--primary);
    }

    .modal-footer {
      display: flex;
      justify-content: flex-end;
      gap: 1rem;
      margin-top: 2rem;
    }

    .btn-cancel {
      background-color: transparent;
      border: 1px solid var(--border-color);
      color: var(--text-secondary);
      padding: 0.65rem 1.25rem;
      border-radius: 8px;
      font-size: 0.875rem;
      font-weight: 600;
      cursor: pointer;
    }

    .btn-cancel:hover {
      background-color: var(--bg-hover);
      color: var(--text-primary);
    }

    .btn-save {
      background-color: var(--primary);
      border: 1px solid var(--primary);
      color: #fff;
      padding: 0.65rem 1.25rem;
      border-radius: 8px;
      font-size: 0.875rem;
      font-weight: 600;
      cursor: pointer;
    }

    .btn-save:hover {
      box-shadow: 0 4px 12px rgba(99, 102, 241, 0.2);
    }
  </style>

  <div class="header-container">
    <div class="title-section">
    </div>
    <div class="action-section">
      <button id="btnNewCustomer" class="btn-save" style="display: inline-flex; align-items: center; gap: 0.5rem;">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 16px; height: 16px;">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
        </svg>
        <span>Add Customer</span>
      </button>
    </div>
  </div>

  <!-- Stats Grid -->
  <div class="stats-banner">
    <!-- Total Customers -->
    <div class="stat-card">
      <div class="stat-icon customer-total">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 24px; height: 24px;">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.109A11.386 11.386 0 0110.089 20M14.214 16.058A9.396 9.396 0 0010 15a9.396 9.396 0 00-4.214 1.058M14.214 16.058a9.306 9.306 0 01-2.224 2.898M10 15a9.38 9.38 0 00-2.625.372 9.337 9.337 0 00-4.121.952 4.125 4.125 0 007.533 2.493M10 15v-.003c0-1.113.285-2.16.786-3.07M10 15v.109A11.386 11.386 0 005.089 16.5M10 7.5a3 3 0 110-6 3 3 0 010 6zm5 3a3 3 0 110-6 3 3 0 010 6z" />
        </svg>
      </div>
      <div class="stat-details">
        <span class="stat-label">Total Customers</span>
        <span class="stat-value">{totalCustomers}</span>
        <span style="font-size: 0.75rem; color: var(--text-secondary);">Registered profiles</span>
      </div>
    </div>

    <!-- Active Service -->
    <div class="stat-card">
      <div class="stat-icon customer-active">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 24px; height: 24px;">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
      <div class="stat-details">
        <span class="stat-label">Active Services</span>
        <span class="stat-value" style="color: var(--success);">{activeCustomers}</span>
        <span style="font-size: 0.75rem; color: var(--text-secondary);">Currently active</span>
      </div>
    </div>

    <!-- Expired & No Service -->
    <div class="stat-card">
      <div class="stat-icon customer-expired">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 24px; height: 24px;">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
      <div class="stat-details">
        <span class="stat-label">Expired / Unsubscribed</span>
        <span class="stat-value" style="color: var(--error);">{expiredCustomers + inactiveCustomers}</span>
        <span style="font-size: 0.75rem; color: var(--text-secondary);">{expiredCustomers} expired &bull; {inactiveCustomers} inactive</span>
      </div>
    </div>
  </div>

  <!-- Filters -->
  <form method="GET" class="filter-bar">
    <input 
      type="text" 
      name="search" 
      placeholder="Search by name, phone, email, CCCD, or ID..." 
      value={search} 
      class="search-input" 
    />
    <select name="status" class="select-filter">
      <option value="">All Statuses</option>
      <option value="active" selected={statusFilter === 'active'}>Còn hạn (Active)</option>
      <option value="expired" selected={statusFilter === 'expired'}>Hết hạn (Expired)</option>
      <option value="none" selected={statusFilter === 'none'}>Chưa đăng ký (No Service)</option>
    </select>
    <select name="staffId" class="select-filter">
      <option value="">All Assigned Staff</option>
      {staffList.map((st: any) => (
        <option value={st.id} selected={staffFilter === st.id}>{st.fullName}</option>
      ))}
    </select>
    <button type="submit" class="btn-filter">Apply Filters</button>
    {(search || statusFilter || staffFilter) && (
      <a href="/crm/customers" class="btn-reset">Reset</a>
    )}
  </form>

  <div class="card-container">
    <!-- Desktop Table View -->
    <div class="table-responsive table-scroll-container">
      <table class="custom-table">
        <thead>
          <tr>
            <th>Customer</th>
            <th>Contact</th>
            <th>Identity Info</th>
            <th>Service Status</th>
            <th>Assigned Staff</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          {customerList.length === 0 ? (
            <tr>
              <td colspan="6" style="text-align: center; padding: 3rem; color: var(--text-secondary);">
                No customers matching the criteria.
              </td>
            </tr>
          ) : (
            customerList.map((customer: any) => {
              const serviceStatus = formatExpiration(customer.expiredAt);
              return (
                <tr>
                  <td>
                    <div class="customer-info">
                      <span class="customer-name">{customer.fullName}</span>
                      <span class="customer-id">ID: {customer.id}</span>
                    </div>
                  </td>
                  <td>
                    <div style="display: flex; flex-direction: column; gap: 0.15rem;">
                      <span>{customer.phone}</span>
                      <span style="font-size: 0.75rem; color: var(--text-secondary);">{customer.email || 'No email'}</span>
                    </div>
                  </td>
                  <td>
                    <span style="font-family: monospace;">{customer.idCard || 'N/A'}</span>
                  </td>
                  <td>
                    <span class={`badge ${serviceStatus.class}`}>{serviceStatus.text}</span>
                  </td>
                  <td>
                    <span style="color: var(--text-secondary);">{customer.staffName || 'Unassigned'}</span>
                  </td>
                  <td>
                    <div style="display: flex; gap: 0.5rem;">
                      <a href={`/crm/qr-tool?customerId=${customer.id}`} class="btn-action">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5A1.125 1.125 0 013.75 9.375v-4.5zM3.75 14.625c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5a1.125 1.125 0 01-1.125-1.125v-4.5zM13.5 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5A1.125 1.125 0 0113.5 9.375v-4.5zM6.75 6.75h.75v.75h-.75v-.75zM6.75 16.5h.75v.75h-.75v-.75zM16.5 6.75h.75v.75h-.75v-.75zM13.5 13.5h.75v.75h-.75v-.75zM16.5 16.5h.75v.75h-.75v-.75zM13.5 16.5h.75v.75h-.75v-.75zM16.5 13.5h.75v.75h-.75v-.75z" />
                        </svg>
                        QR Tool
                      </a>
                      <button class="btn-action btn-edit-customer" data-customer={JSON.stringify(customer)}>
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L6.832 19.82a4.5 4.5 0 01-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 011.13-1.897L16.863 4.487zm0 0L19.5 7.125" />
                        </svg>
                        Edit
                      </button>
                    </div>
                  </td>
                </tr>
              );
            })
          )}
        </tbody>
      </table>
    </div>

    <!-- Mobile Card View -->
    <div class="mobile-card-grid">
      {customerList.length === 0 ? (
        <div style="text-align: center; padding: 2rem; color: var(--text-secondary);">
          No customers matching the criteria.
        </div>
      ) : (
        customerList.map((customer: any) => {
          const serviceStatus = formatExpiration(customer.expiredAt);
          return (
            <div class="mobile-card">
              <div class="mobile-card-header">
                <div class="customer-info">
                  <span class="customer-name">{customer.fullName}</span>
                  <span class="customer-id">ID: {customer.id}</span>
                </div>
                <span class={`badge ${serviceStatus.class}`}>{serviceStatus.text}</span>
              </div>
              
              <div class="mobile-card-body">
                <div class="mobile-card-row">
                  <span class="mobile-card-label">Phone</span>
                  <span class="mobile-card-value">{customer.phone}</span>
                </div>
                <div class="mobile-card-row">
                  <span class="mobile-card-label">Email</span>
                  <span class="mobile-card-value" style="font-size: 0.8125rem;">{customer.email || 'No email'}</span>
                </div>
                <div class="mobile-card-row">
                  <span class="mobile-card-label">CCCD / ID Card</span>
                  <span class="mobile-card-value" style="font-family: monospace;">{customer.idCard || 'N/A'}</span>
                </div>
                <div class="mobile-card-row">
                  <span class="mobile-card-label">Assigned Staff</span>
                  <span class="mobile-card-value" style="color: var(--text-secondary);">{customer.staffName || 'Unassigned'}</span>
                </div>
              </div>
  
              <div class="mobile-card-footer" style="display: flex; gap: 0.5rem; width: 100%;">
                <a href={`/crm/qr-tool?customerId=${customer.id}`} class="btn-action" style="flex: 1; justify-content: center;">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5A1.125 1.125 0 013.75 9.375v-4.5zM3.75 14.625c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5a1.125 1.125 0 01-1.125-1.125v-4.5zM13.5 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5A1.125 1.125 0 0113.5 9.375v-4.5zM6.75 6.75h.75v.75h-.75v-.75zM6.75 16.5h.75v.75h-.75v-.75zM16.5 6.75h.75v.75h-.75v-.75zM13.5 13.5h.75v.75h-.75v-.75zM16.5 16.5h.75v.75h-.75v-.75zM13.5 16.5h.75v.75h-.75v-.75zM16.5 13.5h.75v.75h-.75v-.75z" />
                  </svg>
                  QR Tool
                </a>
                <button class="btn-action btn-edit-customer" data-customer={JSON.stringify(customer)} style="flex: 1; justify-content: center;">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L6.832 19.82a4.5 4.5 0 01-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 011.13-1.897L16.863 4.487zm0 0L19.5 7.125" />
                  </svg>
                  Edit
                </button>
              </div>
            </div>
          );
        })
      )}
    </div>
  </div>

  <!-- Add Customer Modal -->
  <div class="modal-backdrop" id="newCustomerModal">
    <div class="modal-content">
      <div class="modal-header">
        <h3>Add New Customer</h3>
        <button class="modal-close" id="modalCloseBtn">&times;</button>
      </div>
      <div class="modal-body">
        <form id="newCustomerForm">
          <div class="form-grid">
            <div class="form-group">
              <label for="cust_id">Customer ID (Optional)</label>
              <input type="text" id="cust_id" class="form-input" placeholder="e.g. AG1001 or blank for UUID" />
            </div>
            
            <div class="form-group">
              <label for="cust_fullName">Full Name *</label>
              <input type="text" id="cust_fullName" class="form-input" required placeholder="e.g. John Doe" />
            </div>

            <div class="form-group">
              <label for="cust_phone">Phone Number *</label>
              <input type="tel" id="cust_phone" class="form-input" required placeholder="e.g. 0901234567" />
            </div>

            <div class="form-group">
              <label for="cust_email">Email</label>
              <input type="email" id="cust_email" class="form-input" placeholder="e.g. john@example.com" />
            </div>

            <div class="form-group">
              <label for="cust_idCard">CCCD / ID Card</label>
              <input type="text" id="cust_idCard" class="form-input" placeholder="e.g. 037123456789" />
            </div>

            <div class="form-group">
              <label for="cust_taxCode">Tax Code</label>
              <input type="text" id="cust_taxCode" class="form-input" placeholder="e.g. 8123456789" />
            </div>

            <div class="form-group">
              <label for="cust_address">Address</label>
              <input type="text" id="cust_address" class="form-input" placeholder="e.g. 123 Main St" />
            </div>

            <div class="form-group">
              <label for="cust_expiredAt">Service Expiration</label>
              <input type="date" id="cust_expiredAt" class="form-input" />
            </div>

            <div class="form-group full-width">
              <label for="cust_assignedStaffId">Assigned Staff</label>
              <select id="cust_assignedStaffId" class="form-select">
                <option value="">-- Select Staff Member --</option>
                {staffList.map((st: any) => (
                  <option value={st.id}>{st.fullName}</option>
                ))}
              </select>
            </div>

            <div class="form-group full-width">
              <label for="cust_notes">Notes</label>
              <textarea id="cust_notes" class="form-textarea" placeholder="Add additional information..."></textarea>
            </div>
          </div>

          <div class="modal-footer">
            <button type="button" class="btn-cancel" id="modalCancelBtn">Cancel</button>
            <button type="submit" class="btn-save">Create Customer</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Edit Customer Modal -->
  <div class="modal-backdrop" id="editCustomerModal">
    <div class="modal-content">
      <div class="modal-header">
        <h3>Edit Customer Profile</h3>
        <button class="modal-close" id="editModalCloseBtn">&times;</button>
      </div>
      <div class="modal-body">
        <form id="editCustomerForm">
          <input type="hidden" id="edit_cust_id" />
          <div class="form-grid">
            <div class="form-group">
              <label for="edit_cust_fullName">Full Name *</label>
              <input type="text" id="edit_cust_fullName" class="form-input" required placeholder="e.g. John Doe" />
            </div>

            <div class="form-group">
              <label for="edit_cust_phone">Phone Number *</label>
              <input type="tel" id="edit_cust_phone" class="form-input" required placeholder="e.g. 0901234567" />
            </div>

            <div class="form-group">
              <label for="edit_cust_email">Email</label>
              <input type="email" id="edit_cust_email" class="form-input" placeholder="e.g. john@example.com" />
            </div>

            <div class="form-group">
              <label for="edit_cust_idCard">CCCD / ID Card</label>
              <input type="text" id="edit_cust_idCard" class="form-input" placeholder="e.g. 037123456789" />
            </div>

            <div class="form-group">
              <label for="edit_cust_taxCode">Tax Code</label>
              <input type="text" id="edit_cust_taxCode" class="form-input" placeholder="e.g. 8123456789" />
            </div>

            <div class="form-group">
              <label for="edit_cust_address">Address</label>
              <input type="text" id="edit_cust_address" class="form-input" placeholder="e.g. 123 Main St" />
            </div>

            <div class="form-group">
              <label for="edit_cust_expiredAt">Service Expiration</label>
              <input type="date" id="edit_cust_expiredAt" class="form-input" />
            </div>

            <div class="form-group full-width">
              <label for="edit_cust_assignedStaffId">Assigned Staff</label>
              <select id="edit_cust_assignedStaffId" class="form-select">
                <option value="">-- Select Staff Member --</option>
                {staffList.map((st: any) => (
                  <option value={st.id}>{st.fullName}</option>
                ))}
              </select>
            </div>

            <div class="form-group full-width">
              <label for="edit_cust_notes">Notes</label>
              <textarea id="edit_cust_notes" class="form-textarea" placeholder="Add additional information..."></textarea>
            </div>
          </div>

          <div class="modal-footer">
            <button type="button" class="btn-cancel" id="editModalCancelBtn">Cancel</button>
            <button type="submit" class="btn-save">Save Changes</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script is:inline>
    // New Customer Modal
    const modal = document.getElementById('newCustomerModal');
    const openBtn = document.getElementById('btnNewCustomer');
    const closeBtn = document.getElementById('modalCloseBtn');
    const cancelBtn = document.getElementById('modalCancelBtn');
    const form = document.getElementById('newCustomerForm');

    // Open Modal
    openBtn.addEventListener('click', () => {
      form.reset();
      modal.style.display = 'flex';
    });

    // Close Modal
    function closeModal() {
      modal.style.display = 'none';
    }

    closeBtn.addEventListener('click', closeModal);
    cancelBtn.addEventListener('click', closeModal);

    // Edit Customer Modal
    const editModal = document.getElementById('editCustomerModal');
    const editCloseBtn = document.getElementById('editModalCloseBtn');
    const editCancelBtn = document.getElementById('editModalCancelBtn');
    const editForm = document.getElementById('editCustomerForm');

    // Event delegation for Edit buttons
    document.addEventListener('click', (e) => {
      const editBtn = e.target.closest('.btn-edit-customer');
      if (editBtn) {
        const customerData = JSON.parse(editBtn.dataset.customer);
        
        // Pre-populate fields
        document.getElementById('edit_cust_id').value = customerData.id;
        document.getElementById('edit_cust_fullName').value = customerData.fullName || '';
        document.getElementById('edit_cust_phone').value = customerData.phone || '';
        document.getElementById('edit_cust_email').value = customerData.email || '';
        document.getElementById('edit_cust_idCard').value = customerData.idCard || '';
        document.getElementById('edit_cust_taxCode').value = customerData.taxCode || '';
        document.getElementById('edit_cust_address').value = customerData.address || '';
        document.getElementById('edit_cust_assignedStaffId').value = customerData.assignedStaffId || '';
        document.getElementById('edit_cust_notes').value = customerData.notes || '';
        
        if (customerData.expiredAt) {
          const d = new Date(customerData.expiredAt);
          const year = d.getFullYear();
          const month = String(d.getMonth() + 1).padStart(2, '0');
          const day = String(d.getDate()).padStart(2, '0');
          document.getElementById('edit_cust_expiredAt').value = `${year}-${month}-${day}`;
        } else {
          document.getElementById('edit_cust_expiredAt').value = '';
        }
        
        editModal.style.display = 'flex';
      }
    });

    function closeEditModal() {
      editModal.style.display = 'none';
    }

    editCloseBtn.addEventListener('click', closeEditModal);
    editCancelBtn.addEventListener('click', closeEditModal);

    // Global Modal Backdrop Click Closer
    window.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
      if (e.target === editModal) closeEditModal();
    });

    // Submit Create Form
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const id = document.getElementById('cust_id').value;
      const fullName = document.getElementById('cust_fullName').value;
      const phone = document.getElementById('cust_phone').value;
      const email = document.getElementById('cust_email').value;
      const idCard = document.getElementById('cust_idCard').value;
      const taxCode = document.getElementById('cust_taxCode').value;
      const address = document.getElementById('cust_address').value;
      
      const expiredAtVal = document.getElementById('cust_expiredAt').value;
      const expiredAt = expiredAtVal ? new Date(expiredAtVal).getTime() : null;

      const assignedStaffId = document.getElementById('cust_assignedStaffId').value;
      const notes = document.getElementById('cust_notes').value;

      try {
        const res = await fetch('/api/crm/customers', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            id,
            fullName,
            phone,
            email,
            idCard,
            taxCode,
            address,
            expiredAt,
            assignedStaffId,
            notes
          }),
        });

        const data = await res.json();
        if (res.ok && data.success) {
          closeModal();
          window.location.reload();
        } else {
          alert('Error creating customer: ' + (data.error || 'Unknown error'));
        }
      } catch (err) {
        console.error(err);
        alert('Network error, could not create customer.');
      }
    });

    // Submit Edit Form
    editForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const id = document.getElementById('edit_cust_id').value;
      const fullName = document.getElementById('edit_cust_fullName').value;
      const phone = document.getElementById('edit_cust_phone').value;
      const email = document.getElementById('edit_cust_email').value;
      const idCard = document.getElementById('edit_cust_idCard').value;
      const taxCode = document.getElementById('edit_cust_taxCode').value;
      const address = document.getElementById('edit_cust_address').value;
      
      const expiredAtVal = document.getElementById('edit_cust_expiredAt').value;
      const expiredAt = expiredAtVal ? new Date(expiredAtVal).getTime() : null;
      
      const assignedStaffId = document.getElementById('edit_cust_assignedStaffId').value;
      const notes = document.getElementById('edit_cust_notes').value;
      
      try {
        const res = await fetch(`/api/crm/customers/${id}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            fullName,
            phone,
            email,
            idCard,
            taxCode,
            address,
            expiredAt,
            assignedStaffId,
            notes
          }),
        });
        
        const data = await res.json();
        if (res.ok && data.success) {
          closeEditModal();
          window.location.reload();
        } else {
          alert('Error updating customer: ' + (data.error || 'Unknown error'));
        }
      } catch (err) {
        console.error(err);
        alert('Network error, could not update customer.');
      }
    });
  </script>
</DashboardLayout>
