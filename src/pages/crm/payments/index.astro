    <!-- Net Cashflow -->
    <div class="stat-card">
      <div class="stat-icon net">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 24px; height: 24px;">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0-9v9m0 0a2.25 2.25 0 002.25 2.25h.375m-2.625-2.25h-.75a.75.75 0 00-.75.75v.75m-15 0H6a.75.75 0 01.75-.75h.75m-1.5 1.5H5.625a2.25 2.25 0 01-2.25-2.25v-.375m0 0V6.75m0 12v.375c0 .621.504 1.125 1.125 1.125H6.75" />
        </svg>
      </div>
      <div class="stat-details">
        <span class="stat-label">Net Profit</span>
        <span class="stat-value {totalIn - totalOut >= 0 ? 'text-success' : 'text-error'}">
          {formatVND(totalIn - totalOut)}
        </span>
        <span class="stat-count">Total: {countIn + countOut} transactions</span>
      </div>
    </div>
  </div>

  <!-- Filters -->
  <form method="GET" class="filter-bar">
    <input 
      type="text" 
      name="search" 
      placeholder="Search by transaction ID, content, or bank..." 
      value={search} 
      class="search-input" 
    />
    <select name="type" class="select-filter">
      <option value="">All Flow Types</option>
      <option value="in" selected={typeFilter === 'in'}>Tiền vào (Income)</option>
      <option value="out" selected={typeFilter === 'out'}>Tiền ra (Expense)</option>
    </select>
    <button type="submit" class="btn-filter">Apply Filters</button>
    {(search || typeFilter) && (
      <a href="/crm/payments" class="btn-reset">Reset</a>
    )}
  </form>

  <!-- Table Card -->
  <div class="card-container">
    <div class="table-responsive">
      <table class="custom-table">
        <thead>
          <tr>
            <th>Time</th>
            <th>Flow</th>
            <th>Amount</th>
            <th>Transaction details</th>
            <th>Sender/Destination Info</th>
            <th>Relations</th>
          </tr>
        </thead>
        <tbody>
          {transactionList.length === 0 ? (
            <tr>
              <td colspan="6" style="text-align: center; padding: 3rem; color: var(--text-muted);">
                No transactions matching the criteria.
              </td>
            </tr>
          ) : (
            transactionList.map((tx: any) => (
              <tr>
                <td>
                  <div>
                    <span>{formatDate(tx.paidAt)}</span>
                  </div>
                </td>
                <td>
                  <span class={`direction-badge ${tx.type === 'in' ? 'direction-in' : 'direction-out'}`}>
                    {tx.type === 'in' ? 'Tiền vào' : 'Tiền ra'}
                  </span>
                </td>
                <td>
                  <span class={tx.type === 'in' ? 'text-success' : 'text-error'}>
                    {tx.type === 'in' ? '+' : '-'}{formatVND(tx.amount)}
                  </span>
                </td>
                <td>
                  <div>
                    <div style="display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap;">
                      <span class="mono">{tx.transactionId}</span>
                       <span class={`direction-badge ${(tx.type === 'in' && tx.category === 'revenue' && tx.customerId && tx.customerId !== 'CUST-ANONYMOUS') ? 'direction-in' : 'direction-out'}`} style="font-size: 0.7rem; padding: 0.1rem 0.4rem;">
                        {(tx.type === 'in' && tx.category === 'revenue' && tx.customerId && tx.customerId !== 'CUST-ANONYMOUS') ? 'Doanh thu' : 'Không phải doanh thu'}
                      </span>
                      {tx.type === 'in' && (!tx.customerId || tx.customerId === 'CUST-ANONYMOUS') && !hasMatchingTrigger(tx.content, classificationRules) && (
                        <span style="font-size: 0.7rem; background: rgba(245, 158, 11, 0.15); color: #d97706; border: 1px solid rgba(245, 158, 11, 0.3); padding: 0.1rem 0.4rem; border-radius: 4px; font-weight: 600; display: inline-flex; align-items: center; gap: 0.25rem;">
                          ⚠️ Chưa phân loại
                        </span>
                      )}
                      {tx.taxCategory && (
                        <span style="font-size: 0.7rem; background: var(--bg-hover); color: var(--text-primary); border: 1px solid var(--border-color); padding: 0.1rem 0.4rem; border-radius: 4px; font-weight: 500;">
                          🏷️ {tx.taxCategory}
                        </span>
                      )}
                    </div>
                    <div class="meta-subtext">{tx.content || 'No content description'}</div>
                  </div>
                </td>
                <td>
                  <div>
                    <span>{tx.bank || 'Unknown Bank'}</span>
                    <div class="meta-subtext">Acc: {tx.accountNumber || 'N/A'}</div>
                  </div>
                </td>
                <td>
                  <div style="display: flex; flex-direction: column; gap: 0.35rem;">
                    {tx.customerName ? (
                      <a href={`/crm/customers?search=${tx.customerName}`} style="color: var(--primary); font-weight: 500;">
                        👤 {tx.customerName}
                      </a>
                    ) : (
                      <span style="color: var(--text-muted); font-size: 0.75rem;">No customer link</span>
                    )}
                    {tx.orderNumber && (
                      <span style="font-size: 0.75rem; color: var(--text-secondary);">
                        📦 Order: <a href={`/crm/orders?search=${tx.orderNumber}`} style="color: var(--primary); font-weight: 500;" class="mono">{tx.orderNumber}</a>
                      </span>
                    )}
                    <div style="display: flex; gap: 0.25rem; align-items: center; margin-top: 0.25rem; flex-wrap: wrap;">
                      <button 
                        class="btn-reconcile btn-action" 
                        data-id={tx.id} 
                        data-amount={tx.amount}
                        data-content={tx.content || ''}
                        data-customer-id={tx.customerId || ''} 
                        data-category={tx.category || ''}
                        data-tax-category={tx.taxCategory || ''}
                        data-type={tx.type || ''}
                        data-order-id={tx.orderId || ''}
                        data-order-number={tx.orderNumber || ''}
                        style="font-size: 0.7rem; padding: 0.25rem 0.5rem;"
                      >
                        ✏️ Link / Edit
                      </button>

                      <button 
                        class="btn-delete-payment btn-action" 
                        data-id={tx.id}
                        style="font-size: 0.7rem; padding: 0.25rem 0.5rem; background-color: #ef4444; border-color: #ef4444; color: white;"
                      >
                        🗑️ Delete
                      </button>
                    </div>
                  </div>
                </td>
              </tr>
            ))
          )}
        </tbody>
      </table>
    </div>
  </div>

  </div><!-- End transactionsTabContent -->

  <div id="rulesTabContent" style="display: none;">
    <!-- Bank Account Settings Card -->
    <div class="card-container" style="margin-bottom: 2rem;">
      <h2 style="font-size: 1.25rem; font-weight: 700; color: var(--text-primary); margin: 0 0 0.5rem 0;">{lang === 'vi' ? 'Cấu hình Tài khoản Ngân hàng nhận tiền' : 'Bank Account Settings'}</h2>
      <p style="font-size: 0.875rem; color: var(--text-secondary); margin-bottom: 1.5rem;">
        {lang === 'vi' ? 'Cấu hình tài khoản ngân hàng nhận tiền để tạo mã VietQR tự động và đồng bộ giao dịch từ SePay.' : 'Configure the receiving bank account to generate auto-VietQR codes and sync transactions from SePay.'}
      </p>

      <form id="bankConfigForm" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem; align-items: end;">
        <div>
          <label style="display: block; font-size: 0.875rem; font-weight: 600; color: var(--text-secondary); margin-bottom: 0.5rem;">{lang === 'vi' ? 'Ngân hàng nhận' : 'Bank Brand Name'}</label>
          <select id="bankBrandName" style="width: 100%; padding: 0.625rem; border: 1px solid var(--border); border-radius: 6px; background-color: var(--card-bg); color: var(--text-primary);">
            <option value="MB" selected={defaultBank === 'MB'}>MB (MBBank)</option>
            <option value="Techcombank" selected={defaultBank === 'Techcombank'}>Techcombank</option>
            <option value="Vietcombank" selected={defaultBank === 'Vietcombank'}>Vietcombank</option>
            <option value="ACB" selected={defaultBank === 'ACB'}>ACB</option>
            <option value="VPBank" selected={defaultBank === 'VPBank'}>VPBank</option>
            <option value="BIDV" selected={defaultBank === 'BIDV'}>BIDV</option>
            <option value="VietinBank" selected={defaultBank === 'VietinBank'}>VietinBank</option>
            <option value="TPBank" selected={defaultBank === 'TPBank'}>TPBank</option>
            <option value="Sacombank" selected={defaultBank === 'Sacombank'}>Sacombank</option>
            <option value="Agribank" selected={defaultBank === 'Agribank'}>Agribank</option>
            <option value="VIB" selected={defaultBank === 'VIB'}>VIB</option>
          </select>
        </div>
        <div>
          <label style="display: block; font-size: 0.875rem; font-weight: 600; color: var(--text-secondary); margin-bottom: 0.5rem;">{lang === 'vi' ? 'Số tài khoản' : 'Account Number'}</label>
          <input type="text" id="bankAccountNumber" value={defaultAccount} placeholder={lang === 'vi' ? 'Ví dụ: 0399999999' : 'e.g. 0399999999'} required style="width: 100%; padding: 0.625rem; border: 1px solid var(--border); border-radius: 6px; background-color: var(--card-bg); color: var(--text-primary);" />
        </div>
        <div>
          <label style="display: block; font-size: 0.875rem; font-weight: 600; color: var(--text-secondary); margin-bottom: 0.5rem;">{lang === 'vi' ? 'Tên tổ chức / Cửa hàng' : 'Organization Name'}</label>
          <input type="text" id="bankOrgName" value={orgName} placeholder={lang === 'vi' ? 'Ví dụ: Pageel CRM' : 'e.g. Pageel CRM'} required style="width: 100%; padding: 0.625rem; border: 1px solid var(--border); border-radius: 6px; background-color: var(--card-bg); color: var(--text-primary);" />
        </div>
        <div>
          <button type="submit" class="btn-save" style="width: 100%; justify-content: center; height: 42px;">
            {lang === 'vi' ? 'Lưu cấu hình' : 'Save Settings'}
          </button>
        </div>
      </form>

      <!-- Utility Action for Cleaning Mismatched Bank Payments -->
      <div style="margin-top: 1.5rem; padding-top: 1.5rem; border-top: 1px dashed var(--border); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
        <div>
          <h3 style="font-size: 0.95rem; font-weight: 600; color: var(--text-primary); margin: 0;">{lang === 'vi' ? 'Dọn dẹp Giao dịch Sai số tài khoản (Data Cleanup)' : 'Cleanup Mismatched Bank Transactions'}</h3>
          <p style="font-size: 0.8rem; color: var(--text-secondary); margin-top: 0.25rem;">
            {lang === 'vi' ? `Xóa hàng loạt các giao dịch đã đồng bộ trước đây không khớp với số tài khoản được cấu hình ở trên (${defaultAccount}).` : `Bulk delete previously synced transactions that do not match the configured receiving account above (${defaultAccount}).`}
          </p>
        </div>
        <button id="btnCleanupMismatched" class="btn-action" style="background-color: #ef4444; border-color: #ef4444; color: white; padding: 0.625rem 1.25rem; border-radius: 6px; font-weight: 500; display: inline-flex; align-items: center; gap: 0.5rem; cursor: pointer;">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 16px; height: 16px;">
            <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
          </svg>
          {lang === 'vi' ? 'Dọn dẹp Giao dịch Sai' : 'Clean Mismatched Transactions'}
        </button>
      </div>
    </div>

    <div class="card-container" style="margin-bottom: 2rem;">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 1rem;">
        <div>
          <h2 style="font-size: 1.25rem; font-weight: 700; color: var(--text-primary); margin: 0;">{t('payments.rules_title', lang)}</h2>
          <p style="font-size: 0.875rem; color: var(--text-secondary); margin-top: 0.25rem;">
            {t('payments.rules_desc', lang)}
          </p>
        </div>
        <button id="btnAddRule" class="btn-save" style="display: inline-flex; align-items: center; gap: 0.5rem;">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 16px; height: 16px;">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
          </svg>
          {t('payments.add_rule', lang)}
        </button>
      </div>

      <div class="table-responsive">
        <table class="custom-table">
          <thead>
            <tr>
              <th>{t('payments.pattern_mode', lang)}</th>
              <th>{t('payments.flow', lang)}</th>
              <th>{t('payments.tax_category', lang)}</th>
              <th>{t('payments.customer_link', lang)}</th>
              <th>{t('payments.actions', lang)}</th>
            </tr>
          </thead>
          <tbody id="rulesTableBody">
            {classificationRules.length === 0 ? (
              <tr>
                <td colspan="5" style="text-align: center; padding: 3rem; color: var(--text-muted);">
                  {t('payments.no_rules', lang)}
                </td>
              </tr>
            ) : (
              classificationRules.map((rule: any, idx: number) => {
                const customer = allCustomers.find((c: any) => c.id === rule.targetCustomerId);
                return (
                  <tr data-index={idx}>
                    <td class="mono" style="font-weight: 600; color: var(--primary);">
                      {rule.matchType === 'auto_customer' ? (
                        <span style="color: var(--success); font-weight: 600; display: inline-flex; align-items: center; gap: 0.25rem;">
                          {t('payments.auto_match_cust', lang)}
                        </span>
                      ) : rule.matchType === 'auto_invoice' ? (
                        <span style="color: var(--success); font-weight: 600; display: inline-flex; align-items: center; gap: 0.25rem;">
                          {t('payments.auto_match_invoice', lang)}
                        </span>
                      ) : (
                        rule.pattern
                      )}
                    </td>
                    <td>
                      <div style="display: flex; flex-direction: column; gap: 0.25rem;">
                        <span class={`direction-badge ${rule.type === 'out' ? 'direction-out' : 'direction-in'}`}>
                          {rule.type === 'out' ? t('payments.expense', lang) : t('payments.income', lang)}
                        </span>
                        <span style="font-size: 0.75rem; color: var(--text-secondary); font-weight: 500;">
                          {rule.category === 'revenue' ? t('payments.revenue', lang) : t('payments.non_revenue', lang)}
                        </span>
                      </div>
                    </td>
                    <td>
                      <span style="font-weight: 500; font-family: monospace; background: var(--bg-hover); padding: 0.2rem 0.5rem; border-radius: 4px; border: 1px solid var(--border-color);">
                        {rule.taxCategory || 'N/A'}
                      </span>
                    </td>
                    <td>
                      {rule.matchType === 'auto_customer' ? (
                        <span style="color: var(--text-muted); font-style: italic;">{t('payments.auto_extract', lang)}</span>
                      ) : rule.matchType === 'auto_invoice' ? (
                        <span style="color: var(--text-muted); font-style: italic;">{t('payments.linked_invoice', lang)}</span>
                      ) : customer ? (
                        <div style="font-weight: 600;">{customer.fullName} <span style="font-size: 0.75rem; color: var(--text-muted); font-weight: normal;">({customer.id})</span></div>
                      ) : (
                        <span style="color: var(--text-muted); font-style: italic;">{t('payments.no_customer_link', lang)}</span>
                      )}
                    </td>
                    <td>
                      <div style="display: flex; gap: 0.5rem;">
                        <button type="button" class="btn-action btn-edit-rule" data-index={idx} data-rule={JSON.stringify(rule)}>✏️ {t('payments.edit', lang)}</button>
                        <button type="button" class="btn-action btn-delete-rule" data-index={idx} style="border-color: rgba(239, 68, 68, 0.2); color: var(--error);">🗑️ {t('payments.delete', lang)}</button>
                      </div>
                    </td>
                  </tr>
                );
              })
            )}
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Rule Edit Modal -->
  <div class="modal-backdrop" id="ruleModal">
    <div class="modal-content">
      <div class="modal-header">
        <h3 id="ruleModalTitle">{t('payments.add_rule_title', lang)}</h3>
        <button class="modal-close" id="ruleModalCloseBtn">&times;</button>
      </div>
      <div class="modal-body">
        <form id="ruleForm">
          <input type="hidden" id="ruleIndex" />
          
          <div class="form-group">
            <label for="ruleMatchType">{t('payments.match_mode', lang)} *</label>
            <select id="ruleMatchType" class="form-select" required>
              <option value="keyword">{lang === 'vi' ? 'Khớp từ khóa' : 'Match Keyword'}</option>
              <option value="auto_customer">{lang === 'vi' ? 'Tự động khớp ID Khách hàng' : 'Auto-Match Customer ID'}</option>
              <option value="auto_invoice">{lang === 'vi' ? 'Tự động khớp Mã Đơn hàng' : 'Auto-Match Order ID'}</option>
            </select>
          </div>

          <div class="form-group" id="rulePatternGroup">
            <label for="rulePattern">{t('payments.keyword_pattern', lang)} *</label>
            <input type="text" id="rulePattern" class="form-input" placeholder={lang === 'vi' ? 'Ví dụ: FB ADS, HOSTING, CLOUDFLARE...' : 'e.g. FB ADS, HOSTING, CLOUDFLARE...'} />
          </div>

          <div class="form-group">
            <label for="ruleType">{t('payments.flow', lang)} *</label>
            <select id="ruleType" class="form-select">
              <option value="in">{lang === 'vi' ? 'Tiền vào' : 'Income'}</option>
              <option value="out">{lang === 'vi' ? 'Tiền ra' : 'Expense'}</option>
            </select>
          </div>

          <div class="form-group" id="ruleCategoryGroup">
            <label for="ruleCategorySelect">{lang === 'vi' ? 'Phân loại doanh thu' : 'Classification Category'}</label>
            <select id="ruleCategorySelect" class="form-select">
              <option value="revenue">{lang === 'vi' ? 'Doanh thu' : 'Revenue'}</option>
              <option value="non_revenue">{lang === 'vi' ? 'Không phải doanh thu' : 'Non-Revenue'}</option>
            </select>
          </div>

          <div class="form-group">
            <label for="ruleTaxCategory">{t('payments.tax_category', lang)}</label>
            <input type="text" id="ruleTaxCategory" class="form-input" placeholder={lang === 'vi' ? 'Ví dụ: Marketing, Infra, Operating Expense...' : 'e.g. Marketing, Infra, Operating Expense...'} />
          </div>

          <!-- Customer Searchable Select for Rule -->
          <div class="form-group" id="ruleCustomerLinkGroup">
            <label for="ruleCustomerSearchInput">{t('payments.link_customer_opt', lang)}</label>
            <div class="searchable-select-container">
              <input type="text" id="ruleCustomerSearchInput" class="form-input" placeholder={t('payments.type_search_customer', lang)} autocomplete="off" />
              <input type="hidden" id="ruleCustomerSelect" />
              <div class="searchable-select-dropdown" id="ruleCustomerSearchDropdown" style="display: none;">
                <div class="searchable-select-option" data-value="">{t('payments.no_customer_link_opt', lang)}</div>
                {allCustomers.map((cust: any) => (
                  <div class="searchable-select-option" data-value={cust.id} data-search={`${cust.fullName.toLowerCase()} ${cust.id.toLowerCase()}`}>
                    {cust.fullName} ({cust.id})
                  </div>
                ))}
              </div>
            </div>
          </div>

          <div class="modal-footer">
            <button type="button" class="btn-cancel" id="ruleModalCancelBtn">{t('payments.cancel', lang)}</button>
            <button type="submit" class="btn-save" id="ruleModalSaveBtn">{t('payments.save_rule', lang)}</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Reconcile Modal -->
  <div class="modal-backdrop" id="reconcileModal">
    <div class="modal-content">
      <div class="modal-header">
        <h3>{t('payments.manual_reconcile', lang)}</h3>
        <button class="modal-close" id="modalCloseBtn">&times;</button>
      </div>
      <div class="modal-body">
        <div class="tx-info-box">
          <div class="tx-info-row">
            <span class="tx-info-label">{t('payments.tx_id', lang)}</span>
            <span class="tx-info-val mono" id="modalTxId">TX123456</span>
          </div>
          <div class="tx-info-row">
            <span class="tx-info-label">{t('payments.amount', lang)}</span>
            <span class="tx-info-val text-success" id="modalTxAmount">100,000 đ</span>
          </div>
          <div class="tx-info-row">
            <span class="tx-info-label">{t('payments.description', lang)}</span>
            <span class="tx-info-val" id="modalTxContent" style="font-size: 0.8rem; word-break: break-all;">Transfer info</span>
          </div>
          <div class="tx-info-row" id="modalLinkedOrderRow" style="display: none;">
            <span class="tx-info-label">{lang === 'vi' ? 'Đơn hàng liên kết' : 'Linked Order'}</span>
            <span class="tx-info-val" style="font-weight: 600;">
              <span id="modalLinkedOrderVal" class="mono"></span>
              <button type="button" id="btnConfirmUnlinkOrder" style="font-size: 0.75rem; color: var(--error); background: none; border: none; padding: 0; margin-left: 0.5rem; cursor: pointer; text-decoration: underline;">
                {lang === 'vi' ? 'Gỡ liên kết Đơn hàng' : 'Unlink Order'}
              </button>
            </span>
          </div>
        </div>

        <form id="reconcileForm">
          <input type="hidden" id="modalPaymentId" />
          
          <!-- Customer Searchable Select -->
          <div class="form-group">
            <label for="customerSearchInput">{t('payments.customer_link', lang)}</label>
            <div class="searchable-select-container">
              <input type="text" id="customerSearchInput" class="form-input" placeholder={t('payments.type_search_customer', lang)} autocomplete="off" />
              <input type="hidden" id="modalCustomerSelect" />
              <div class="searchable-select-dropdown" id="customerSearchDropdown" style="display: none;">
                <div class="searchable-select-option" data-value="">{t('payments.no_customer_link_opt', lang)}</div>
                {allCustomers.map((cust: any) => (
                  <div class="searchable-select-option" data-value={cust.id} data-search={`${cust.fullName.toLowerCase()} ${cust.id.toLowerCase()}`}>
                    {cust.fullName} ({cust.id})
                  </div>
                ))}
              </div>
            </div>
          </div>

          <!-- Order Select -->
          <!-- @para-doc [#csa-ui-payments-reconcile-modal] -->
          <div class="form-group">
            <label for="modalOrderSelect">{lang === 'vi' ? 'Liên kết Đơn hàng' : 'Link Order'}</label>
            <select id="modalOrderSelect" class="form-select">
              <option value="">{lang === 'vi' ? '-- Không liên kết đơn hàng --' : '-- No order link --'}</option>
              <option value="NEW_ORDER">{lang === 'vi' ? '-- Tạo đơn hàng mới cho giao dịch này (Late Assoc) --' : '-- Create new order (Late Assoc) --'}</option>
              {allOrders.map((ord: any) => (
                <option 
                  value={ord.id} 
                  data-customer-id={ord.customerId || ''}
                  data-amount={ord.amount}
                  data-status={ord.status}
                >
                  {ord.orderNumber} - {ord.amount.toLocaleString()} đ [{ord.status.toUpperCase()}]
                </option>
              ))}
            </select>
          </div>

          <!-- Inline New Order Fields (Late Assoc) -->
          <!-- @para-doc [#csa-us-5-inline-order-creation] -->
          <div id="newOrderFields" style="display: none; border-left: 3px solid var(--primary); padding-left: 1rem; margin-top: 1rem; margin-bottom: 1rem;">
            <div class="form-group">
              <label for="reconcileServiceSelect">{lang === 'vi' ? 'Gói dịch vụ *' : 'Service *'}</label>
              <select id="reconcileServiceSelect" class="form-select">
                <option value="">{lang === 'vi' ? '-- Chọn dịch vụ --' : '-- Select Service --'}</option>
                {allServices.map((srv: any) => (
                  <option value={srv.id} data-price={srv.price} data-name={srv.name}>
                    {srv.name} ({formatVND(srv.price)})
                  </option>
                ))}
              </select>
            </div>
            
            <div class="form-group">
              <label for="reconcileMonthsInput">{lang === 'vi' ? 'Số chu kỳ tháng (Multiplier) *' : 'Cycle Multiplier (Months) *'}</label>
              <input type="number" id="reconcileMonthsInput" class="form-input" min="1" max="60" value="1" />
            </div>

            <div class="form-group">
              <label for="reconcileOrderAmountInput">{lang === 'vi' ? 'Số tiền đơn hàng (VND)' : 'Order Amount (VND)'}</label>
              <input type="number" id="reconcileOrderAmountInput" class="form-input" placeholder="0" min="0" />
              <small style="font-size: 0.75rem; color: var(--text-secondary); margin-top: 0.25rem; display: block;">
                {lang === 'vi' ? 'Để trống để dùng giá trị tự động tính.' : 'Leave blank to use calculated price.'}
              </small>
            </div>
          </div>

          <!-- Inline Warning Alert -->
          <div id="reconcileAlert" style="display: none; background-color: #fef3c7; border: 1px solid #f59e0b; color: #d97706; padding: 0.75rem; border-radius: 8px; font-size: 0.825rem; margin-top: 1rem; margin-bottom: 1rem; font-weight: 500;">
          </div>

          <!-- Classification Category -->
          <div class="form-group" id="modalCategoryGroup">
            <label for="modalCategorySelect">{lang === 'vi' ? 'Phân loại doanh thu' : 'Classification Category'}</label>
            <select id="modalCategorySelect" class="form-select">
              <option value="revenue">{lang === 'vi' ? 'Doanh thu' : 'Revenue'}</option>
              <option value="non_revenue">{lang === 'vi' ? 'Không phải doanh thu' : 'Non-Revenue'}</option>
            </select>
          </div>

          <!-- Classification Tag -->
          <div class="form-group">
            <label for="modalTaxCategoryInput">{lang === 'vi' ? 'Tag thuế / Phân loại tùy chỉnh (Tag)' : 'Custom Classification Tag (Tag)'}</label>
            <input type="text" id="modalTaxCategoryInput" class="form-input" placeholder={lang === 'vi' ? 'Ví dụ: Marketing, Refunds, Subscriptions...' : 'e.g. Marketing, Refunds, Subscriptions...'} />
          </div>

          <div class="modal-footer">
            <button type="button" class="btn-cancel" id="modalCancelBtn">{t('payments.cancel', lang)}</button>
            <button type="submit" class="btn-save">{t('payments.save_changes', lang)}</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Advanced Sync Modal -->
  {isAdmin && (
    <div id="advancedSyncModal" class="modal-backdrop">
      <div class="modal-content" style="max-width: 420px;">
        <div class="modal-header">
          <h3>{lang === 'vi' ? 'Quét nâng cao SePay' : 'Advanced SePay Sync'}</h3>
          <button id="advancedSyncClose" class="modal-close">&times;</button>
        </div>
        <div class="modal-body">
          <div class="form-group">
            <label for="advSyncDateMin">{lang === 'vi' ? 'Quét từ ngày' : 'Sync From Date'}</label>
            <input type="date" id="advSyncDateMin" class="form-input" />
          </div>
          <div class="form-group">
            <label for="advSyncLimit">{lang === 'vi' ? 'Giới hạn số lượng giao dịch' : 'Transaction Limit'}</label>
            <input type="number" id="advSyncLimit" class="form-input" min="1" max="1000" value={sepaySyncLimit} />
            <small style="font-size: 0.75rem; color: var(--text-secondary); margin-top: 0.25rem; display: block;">
              {lang === 'vi' ? 'Tối đa 1000 giao dịch để tránh tràn bộ nhớ.' : 'Maximum 1000 transactions to prevent memory overflow.'}
            </small>
          </div>
        </div>
        <div class="modal-footer">
          <button id="btnCancelAdvSync" class="btn-cancel">{lang === 'vi' ? 'Hủy' : 'Cancel'}</button>
          <button id="btnSubmitAdvSync" class="btn-save" style="background-color: var(--primary); border-color: var(--primary);">
            <span class="spinner" id="advSyncSpinner" style="display: none;"></span>
            {lang === 'vi' ? 'Đồng bộ' : 'Sync Now'}
          </button>
        </div>
      </div>
    </div>
  )}

  <!-- Client script for modal handling -->
  <script is:inline define:vars={{ allOrders, classificationRules, lang, allServices, sepaySyncLimit }}>
    const modal = document.getElementById('reconcileModal');
    const closeBtn = document.getElementById('modalCloseBtn');
    const cancelBtn = document.getElementById('modalCancelBtn');
    const form = document.getElementById('reconcileForm');
    
    const modalPaymentId = document.getElementById('modalPaymentId');
    const modalTxId = document.getElementById('modalTxId');
    const modalTxAmount = document.getElementById('modalTxAmount');
    const modalTxContent = document.getElementById('modalTxContent');
    
    const customerSelect = document.getElementById('modalCustomerSelect');
    const customerSearchInput = document.getElementById('customerSearchInput');
    const customerSearchDropdown = document.getElementById('customerSearchDropdown');
    const customerOptions = Array.from(customerSearchDropdown.querySelectorAll('.searchable-select-option'));

    const orderSelect = document.getElementById('modalOrderSelect');
    const modalCategorySelect = document.getElementById('modalCategorySelect');
    const modalTaxCategoryInput = document.getElementById('modalTaxCategoryInput');

    // Track all options of order select to filter them dynamically
    const orderOptions = Array.from(orderSelect.options);

    // Searchable Select Handling
    customerSearchInput.addEventListener('focus', () => {
      // Show dropdown and reset list
      customerSearchDropdown.style.display = 'block';
      customerOptions.forEach(opt => opt.style.display = 'block');
    });

    customerSearchInput.addEventListener('input', () => {
      const term = customerSearchInput.value.toLowerCase().trim();
      customerOptions.forEach(opt => {
        const text = opt.getAttribute('data-search') || '';
        if (text.includes(term) || opt.getAttribute('data-value') === '') {
          opt.style.display = 'block';
        } else {
          opt.style.display = 'none';
        }
      });
    });

    // Close dropdown on click outside
    document.addEventListener('click', (e) => {
      if (!e.target.closest('.searchable-select-container')) {
        customerSearchDropdown.style.display = 'none';
      }
    });

    // Option selection
    customerOptions.forEach(opt => {
      opt.addEventListener('click', () => {
        const val = opt.getAttribute('data-value');
        const text = opt.textContent.trim();
        selectCustomer(val, text);
        customerSearchDropdown.style.display = 'none';
      });
    });

    function selectCustomer(id, label) {
      customerSelect.value = id;
      customerSearchInput.value = id ? label : '';
      
      customerOptions.forEach(opt => {
        if (opt.getAttribute('data-value') === id) {
          opt.classList.add('selected');
        } else {
          opt.classList.remove('selected');
        }
      });

      filterOrders(id);
    }

    let currentTxAmount = 0;
    let selectedServicePrice = 0;

    const newOrderFields = document.getElementById('newOrderFields');
    const reconcileServiceSelect = document.getElementById('reconcileServiceSelect');
    const reconcileMonthsInput = document.getElementById('reconcileMonthsInput');
    const reconcileOrderAmountInput = document.getElementById('reconcileOrderAmountInput');
    const reconcileAlert = document.getElementById('reconcileAlert');

    const checkAmountMatch = () => {
      let orderAmount = 0;
      const orderVal = orderSelect.value;

      if (orderVal === 'NEW_ORDER') {
        const months = Number(reconcileMonthsInput.value) || 1;
        const customAmountVal = reconcileOrderAmountInput.value;
        if (customAmountVal !== '') {
          orderAmount = Number(customAmountVal) || 0;
        } else {
          orderAmount = selectedServicePrice * months;
          reconcileOrderAmountInput.placeholder = orderAmount;
        }
      } else if (orderVal !== '') {
        const selectedOption = orderSelect.options[orderSelect.selectedIndex];
        if (selectedOption) {
          orderAmount = Number(selectedOption.getAttribute('data-amount')) || 0;
        }
      }

      // Render warning alert if mismatch
      if (orderVal !== '' && orderAmount !== currentTxAmount) {
        const diff = Math.abs(orderAmount - currentTxAmount);
        const diffStr = new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(diff);
        const orderAmtStr = new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(orderAmount);
        const txAmtStr = new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(currentTxAmount);
        
        reconcileAlert.style.display = 'block';
        reconcileAlert.innerHTML = lang === 'vi' 
          ? `⚠️ <strong>Cảnh báo lệch tiền:</strong> Số tiền đơn hàng (${orderAmtStr}) lệch <strong>${diffStr}</strong> so với số tiền giao dịch (${txAmtStr}).`
          : `⚠️ <strong>Amount mismatch:</strong> Order amount (${orderAmtStr}) differs by <strong>${diffStr}</strong> from transaction amount (${txAmtStr}).`;
      } else {
        reconcileAlert.style.display = 'none';
        reconcileAlert.innerHTML = '';
      }
    };

    // Listeners for new order fields
    orderSelect.addEventListener('change', () => {
      if (orderSelect.value === 'NEW_ORDER') {
        newOrderFields.style.display = 'block';
        reconcileServiceSelect.setAttribute('required', 'true');
      } else {
        newOrderFields.style.display = 'none';
        reconcileServiceSelect.removeAttribute('required');
      }
      checkAmountMatch();
    });

    if (reconcileServiceSelect) {
      reconcileServiceSelect.addEventListener('change', () => {
        const selectedOption = reconcileServiceSelect.options[reconcileServiceSelect.selectedIndex];
        if (selectedOption && selectedOption.value) {
          selectedServicePrice = Number(selectedOption.getAttribute('data-price')) || 0;
        } else {
          selectedServicePrice = 0;
        }
        reconcileOrderAmountInput.value = ''; // clear custom price on service change
        checkAmountMatch();
      });
    }

    if (reconcileMonthsInput) {
      reconcileMonthsInput.addEventListener('input', () => {
        reconcileOrderAmountInput.value = ''; // clear custom price on months change
        checkAmountMatch();
      });
    }

    if (reconcileOrderAmountInput) {
      reconcileOrderAmountInput.addEventListener('input', checkAmountMatch);
    }

    // Open Modal
    document.querySelectorAll('.btn-reconcile').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = btn.getAttribute('data-id');
        const amount = Number(btn.getAttribute('data-amount')) || 0;
        const content = btn.getAttribute('data-content');
        const customerId = btn.getAttribute('data-customer-id');
        const category = btn.getAttribute('data-category') || 'non_revenue';
        const taxCategory = btn.getAttribute('data-tax-category') || '';
        const flowType = btn.getAttribute('data-type') || 'in';
        const orderId = btn.getAttribute('data-order-id');
        const orderNumber = btn.getAttribute('data-order-number');

        // Populate transaction info
        modalPaymentId.value = id;
        modalTxId.textContent = id;
        modalTxAmount.textContent = new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(amount);
        modalTxContent.textContent = content || 'No content description';

        // Reset state
        currentTxAmount = amount;
        selectedServicePrice = 0;
        if (newOrderFields) newOrderFields.style.display = 'none';
        if (reconcileAlert) reconcileAlert.style.display = 'none';
        if (reconcileServiceSelect) reconcileServiceSelect.value = '';
        if (reconcileMonthsInput) reconcileMonthsInput.value = '1';
        if (reconcileOrderAmountInput) {
          reconcileOrderAmountInput.value = '';
          reconcileOrderAmountInput.placeholder = '0';
        }

        // Show linked order if exists
        const modalLinkedOrderRow = document.getElementById('modalLinkedOrderRow');
        const modalLinkedOrderVal = document.getElementById('modalLinkedOrderVal');
        if (modalLinkedOrderRow && modalLinkedOrderVal) {
          if (orderId && orderNumber) {
            modalLinkedOrderVal.textContent = orderNumber;
            modalLinkedOrderRow.style.display = 'flex';
          } else {
            modalLinkedOrderRow.style.display = 'none';
          }
        }

        // Set category select behavior
        if (modalCategorySelect) {
          if (flowType === 'out') {
            modalCategorySelect.value = 'non_revenue';
            modalCategorySelect.disabled = true;
          } else {
            modalCategorySelect.value = category;
            modalCategorySelect.disabled = false;
          }
        }

        // Set tag input
        if (modalTaxCategoryInput) {
          modalTaxCategoryInput.value = taxCategory;
        }

        // Set current customer dropdown
        const matchedOpt = customerOptions.find(opt => opt.getAttribute('data-value') === customerId);
        const label = matchedOpt ? matchedOpt.textContent.trim() : '';
        selectCustomer(customerId || '', label);

        orderSelect.value = orderId || '';

        // Display modal
        modal.style.display = 'flex';
      });
    });

    function filterOrders(customerId) {
      // Clear current options except the first two (placeholder and NEW_ORDER)
      orderSelect.innerHTML = '';
      orderSelect.appendChild(orderOptions[0]);
      orderSelect.appendChild(orderOptions[1]);

      if (!customerId) {
        // If no customer selected, show all orders
        for (let i = 2; i < orderOptions.length; i++) {
          orderSelect.appendChild(orderOptions[i]);
        }
        return;
      }

      // Show only orders belonging to the selected customer
      for (let i = 2; i < orderOptions.length; i++) {
        const option = orderOptions[i];
        const optionCustId = option.getAttribute('data-customer-id');
        if (optionCustId === customerId) {
          orderSelect.appendChild(option);
        }
      }
    }

    // Close Modal functions
    function closeModal() {
      modal.style.display = 'none';
    }

    closeBtn.addEventListener('click', closeModal);
    cancelBtn.addEventListener('click', closeModal);
    window.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });

    // Confirm unlink order handler
    const btnConfirmUnlinkOrder = document.getElementById('btnConfirmUnlinkOrder');
    if (btnConfirmUnlinkOrder) {
      btnConfirmUnlinkOrder.addEventListener('click', async () => {
        const paymentId = modalPaymentId.value;
        if (!paymentId) return;

        const confirmMsg = lang === 'vi' 
          ? 'Bạn có chắc chắn muốn gỡ liên kết đơn hàng này? Đơn hàng tự động tương ứng sẽ bị XÓA hoàn toàn khỏi hệ thống.'
          : 'Are you sure you want to unlink this order? The corresponding automated order will be DELETED permanently from the database.';
        
        if (!confirm(confirmMsg)) return;

        try {
          btnConfirmUnlinkOrder.disabled = true;
          const res = await fetch('/api/crm/payments/reconcile', {
            method: 'POST',
            credentials: 'include',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ paymentId, unlinkOrder: true })
          });

          const data = await res.json();
          if (res.ok && data.success) {
            alert(lang === 'vi' ? 'Gỡ liên kết thành công!' : 'Unlinked successfully!');
            window.location.reload();
          } else {
            alert(data.error || 'Failed to unlink order');
          }
        } catch (e) {
          console.error(e);
          alert('An error occurred while unlinking order');
        } finally {
          btnConfirmUnlinkOrder.disabled = false;
        }
      });
    }

    // Submit form to API
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const paymentId = modalPaymentId.value;
      const customerId = customerSelect.value;
      const orderId = orderSelect.value;
      const category = modalCategorySelect ? modalCategorySelect.value : 'non_revenue';
      const taxCategory = modalTaxCategoryInput ? modalTaxCategoryInput.value.trim() : '';

      try {
        let res;
        if (orderId === 'NEW_ORDER') {
          const serviceId = reconcileServiceSelect.value;
          const months = Number(reconcileMonthsInput.value) || 1;
          const customPriceVal = reconcileOrderAmountInput.value;
          const customPrice = customPriceVal !== '' ? Number(customPriceVal) : undefined;

          if (!customerId) {
            alert(lang === 'vi' ? 'Vui lòng chọn khách hàng liên kết!' : 'Please select a customer to link!');
            return;
          }
          if (!serviceId) {
            alert(lang === 'vi' ? 'Vui lòng chọn dịch vụ!' : 'Please select a service!');
            return;
          }

          res = await fetch('/api/crm/payments/create-order', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              paymentId,
              customerId,
              serviceId,
              months,
              customPrice,
            }),
          });
        } else {
          res = await fetch('/api/crm/payments/reconcile', {
            method: 'POST',
            credentials: 'include',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ paymentId, customerId, orderId, category, taxCategory }),
          });
        }

        const data = await res.json();
        if (res.ok && data.success) {
          closeModal();
          window.location.reload();
        } else {
          alert('Error saving changes: ' + (data.error || 'Unknown error'));
        }
      } catch (err) {
        console.error(err);
        alert('Network error, could not save manual reconciliation.');
      }
    });

    // Handle SePay API scan button
    const btnSyncSepay = document.getElementById('btnSyncSepay');
    if (btnSyncSepay) {
      btnSyncSepay.addEventListener('click', async () => {
        const originalText = btnSyncSepay.innerHTML;
        btnSyncSepay.disabled = true;
        btnSyncSepay.innerHTML = '<span>' + (lang === 'vi' ? 'Đang quét...' : 'Scanning...') + '</span>';

        try {
          const res = await fetch('/api/payments/sync-sepay', {
            method: 'POST',
            credentials: 'include',
            headers: { 'Content-Type': 'application/json' },
          });

          const data = await res.json();
          console.log('[SePay Sync] Full response:', JSON.stringify(data, null, 2));

          if (res.ok && data.success) {
            const summary = lang === 'vi' ? [
              data.message,
              `\nChi tiết:`,
              `- SePay API trả về: ${data.debug?.rawTransactionCount ?? '?'} giao dịch`,
              `- Đã nạp mới: ${data.newReconciled}`,
              `- Trùng lặp bỏ qua: ${data.duplicates}`,
              `- Giao dịch ra bỏ qua: ${data.skippedOutgoing}`,
              data.errors?.length ? `- Lỗi: ${data.errors.join(', ')}` : '',
              `\n(Mở Console trình duyệt để xem chi tiết đầy đủ)`,
            ].filter(Boolean).join('\n') : [
              data.message,
              `\nDetails:`,
              `- SePay API returned: ${data.debug?.rawTransactionCount ?? '?'} transactions`,
              `- Newly imported: ${data.newReconciled}`,
              `- Duplicates skipped: ${data.duplicates}`,
              `- Outgoing skipped: ${data.skippedOutgoing}`,
              data.errors?.length ? `- Errors: ${data.errors.join(', ')}` : '',
              `\n(Open browser Console for full details)`,
            ].filter(Boolean).join('\n');

            alert(summary);
            if (data.newReconciled > 0) {
              window.location.reload();
            }
          } else {
            alert(lang === 'vi' ? 'Lỗi quét giao dịch: ' + (data.error || 'Không rõ lỗi') : 'Scan error: ' + (data.error || 'Unknown error'));
          }
        } catch (err) {
          console.error(err);
          alert(lang === 'vi' ? 'Lỗi kết nối mạng, không thể quét SePay.' : 'Network connection error, unable to scan SePay.');
        } finally {
          btnSyncSepay.disabled = false;
          btnSyncSepay.innerHTML = originalText;
        }
      });
    }

    // --- Advanced Sync Configuration & Modal Logic ---
    const btnSyncSepayDropdown = document.getElementById('btnSyncSepayDropdown');
    const syncSepayDropdownMenu = document.getElementById('syncSepayDropdownMenu');
    const btnAdvancedSyncOption = document.getElementById('btnAdvancedSyncOption');
    const advancedSyncModal = document.getElementById('advancedSyncModal');
    const advancedSyncClose = document.getElementById('advancedSyncClose');
    const btnCancelAdvSync = document.getElementById('btnCancelAdvSync');
    const btnSubmitAdvSync = document.getElementById('btnSubmitAdvSync');
    const advSyncSpinner = document.getElementById('advSyncSpinner');
    const advSyncDateMin = document.getElementById('advSyncDateMin');
    const advSyncLimit = document.getElementById('advSyncLimit');

    if (btnSyncSepayDropdown && syncSepayDropdownMenu) {
      btnSyncSepayDropdown.addEventListener('click', (e) => {
        e.stopPropagation();
        const isHidden = syncSepayDropdownMenu.style.display === 'none';
        syncSepayDropdownMenu.style.display = isHidden ? 'block' : 'none';
      });

      document.addEventListener('click', () => {
        syncSepayDropdownMenu.style.display = 'none';
      });
    }

    if (btnAdvancedSyncOption && advancedSyncModal) {
      btnAdvancedSyncOption.addEventListener('click', () => {
        if (advSyncDateMin && !advSyncDateMin.value) {
          const sevenDaysAgo = new Date(Date.now() - 7 * 24 * 60 * 60 * 1000);
          advSyncDateMin.value = sevenDaysAgo.toISOString().split('T')[0];
        }
        if (advSyncLimit) {
          advSyncLimit.value = sepaySyncLimit || '50';
        }
        advancedSyncModal.style.display = 'flex';
      });
    }

    function closeAdvancedSyncModal() {
      if (advancedSyncModal) advancedSyncModal.style.display = 'none';
    }

    if (advancedSyncClose) advancedSyncClose.addEventListener('click', closeAdvancedSyncModal);
    if (btnCancelAdvSync) btnCancelAdvSync.addEventListener('click', closeAdvancedSyncModal);

    window.addEventListener('click', (e) => {
      if (e.target === advancedSyncModal) closeAdvancedSyncModal();
    });

    if (btnSubmitAdvSync) {
      btnSubmitAdvSync.addEventListener('click', async () => {
        let limitVal = advSyncLimit ? parseInt(advSyncLimit.value, 10) : 50;
        if (isNaN(limitVal) || limitVal <= 0) {
          alert(lang === 'vi' ? 'Giới hạn số lượng giao dịch phải là số lớn hơn 0' : 'Limit must be a positive number');
          return;
        }
        if (limitVal > 1000) {
          limitVal = 1000;
          if (advSyncLimit) advSyncLimit.value = '1000';
        }

        const dateMinVal = advSyncDateMin ? advSyncDateMin.value.trim() : '';

        btnSubmitAdvSync.disabled = true;
        if (advSyncSpinner) advSyncSpinner.style.display = 'inline-block';

        try {
          const res = await fetch('/api/payments/sync-sepay', {
            method: 'POST',
            credentials: 'include',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              limit: limitVal,
              transaction_date_min: dateMinVal || undefined
            })
          });

          const data = await res.json();
          console.log('[Advanced SePay Sync] Full response:', JSON.stringify(data, null, 2));

          if (res.ok && data.success) {
            const summary = lang === 'vi' ? [
              data.message,
              `\nChi tiết:`,
              `- SePay API trả về: ${data.debug?.rawTransactionCount ?? '?'} giao dịch`,
              `- Đã nạp mới: ${data.newReconciled}`,
              `- Trùng lặp bỏ qua: ${data.duplicates}`,
              `- Giao dịch ra bỏ qua: ${data.skippedOutgoing}`,
              data.errors?.length ? `- Lỗi: ${data.errors.join(', ')}` : '',
              `\n(Mở Console trình duyệt để xem chi tiết đầy đủ)`,
            ].filter(Boolean).join('\n') : [
              data.message,
              `\nDetails:`,
              `- SePay API returned: ${data.debug?.rawTransactionCount ?? '?'} transactions`,
              `- Newly imported: ${data.newReconciled}`,
              `- Duplicates skipped: ${data.duplicates}`,
              `- Outgoing skipped: ${data.skippedOutgoing}`,
              data.errors?.length ? `- Errors: ${data.errors.join(', ')}` : '',
              `\n(Open browser Console for full details)`,
            ].filter(Boolean).join('\n');

            alert(summary);
            closeAdvancedSyncModal();
            if (data.newReconciled > 0) {
              window.location.reload();
            }
          } else {
            alert(lang === 'vi' ? 'Lỗi quét giao dịch nâng cao: ' + (data.error || 'Không rõ lỗi') : 'Advanced Scan error: ' + (data.error || 'Unknown error'));
          }
        } catch (err) {
          console.error(err);
          alert(lang === 'vi' ? 'Lỗi kết nối mạng, không thể quét SePay nâng cao.' : 'Network connection error, unable to scan SePay advanced.');
        } finally {
          btnSubmitAdvSync.disabled = false;
          if (advSyncSpinner) advSyncSpinner.style.display = 'none';
        }
      });
    }

    // --- Tabs Switching Logic ---
    const tabTransactionsBtn = document.getElementById('tabTransactionsBtn');
    const tabRulesBtn = document.getElementById('tabRulesBtn');
    const transactionsTabContent = document.getElementById('transactionsTabContent');
    const rulesTabContent = document.getElementById('rulesTabContent');

    function switchTab(activeTab) {
      if (activeTab === 'rules') {
        tabTransactionsBtn.classList.remove('active');
        tabTransactionsBtn.style.color = 'var(--text-secondary)';
        tabTransactionsBtn.style.borderBottom = 'none';
        
        tabRulesBtn.classList.add('active');
        tabRulesBtn.style.color = 'var(--primary)';
        tabRulesBtn.style.borderBottom = '2px solid var(--primary)';
        
        transactionsTabContent.style.display = 'none';
        rulesTabContent.style.display = 'block';
      } else {
        tabRulesBtn.classList.remove('active');
        tabRulesBtn.style.color = 'var(--text-secondary)';
        tabRulesBtn.style.borderBottom = 'none';
        
        tabTransactionsBtn.classList.add('active');
        tabTransactionsBtn.style.color = 'var(--primary)';
        tabTransactionsBtn.style.borderBottom = '2px solid var(--primary)';
        
        rulesTabContent.style.display = 'none';
        transactionsTabContent.style.display = 'block';
      }
      localStorage.setItem('payments_active_tab', activeTab);
    }

    if (tabTransactionsBtn && tabRulesBtn) {
      tabTransactionsBtn.addEventListener('click', () => switchTab('transactions'));
      tabRulesBtn.addEventListener('click', () => switchTab('rules'));

      // Restore active tab
      const savedTab = localStorage.getItem('payments_active_tab');
      if (savedTab) {
        switchTab(savedTab);
      }
    }

    // --- Classification Rules Management Logic ---
    const ruleModal = document.getElementById('ruleModal');
    const btnAddRule = document.getElementById('btnAddRule');
    const ruleModalCloseBtn = document.getElementById('ruleModalCloseBtn');
    const ruleModalCancelBtn = document.getElementById('ruleModalCancelBtn');
    const ruleForm = document.getElementById('ruleForm');
    const ruleIndexInput = document.getElementById('ruleIndex');
    const ruleMatchTypeSelect = document.getElementById('ruleMatchType');
    const rulePatternGroup = document.getElementById('rulePatternGroup');
    const ruleCustomerLinkGroup = document.getElementById('ruleCustomerLinkGroup');
    const rulePatternInput = document.getElementById('rulePattern');
    const ruleTypeSelect = document.getElementById('ruleType');
    const ruleCategorySelect = document.getElementById('ruleCategorySelect');
    const ruleTaxCategoryInput = document.getElementById('ruleTaxCategory');

    if (ruleMatchTypeSelect) {
      ruleMatchTypeSelect.addEventListener('change', () => {
        const matchType = ruleMatchTypeSelect.value;
        if (matchType === 'keyword') {
          if (rulePatternGroup) rulePatternGroup.style.display = 'block';
          if (rulePatternInput) rulePatternInput.required = true;
          if (ruleCustomerLinkGroup) ruleCustomerLinkGroup.style.display = 'block';
        } else {
          if (rulePatternGroup) rulePatternGroup.style.display = 'none';
          if (rulePatternInput) {
            rulePatternInput.required = false;
            rulePatternInput.value = '';
          }
          if (ruleCustomerLinkGroup) ruleCustomerLinkGroup.style.display = 'none';
          selectRuleCustomer('', '');
        }
      });
    }

    if (ruleTypeSelect && ruleCategorySelect) {
      ruleTypeSelect.addEventListener('change', () => {
        if (ruleTypeSelect.value === 'out') {
          ruleCategorySelect.value = 'non_revenue';
          ruleCategorySelect.disabled = true;
        } else {
          ruleCategorySelect.disabled = false;
        }
      });
    }

    const ruleCustomerSelect = document.getElementById('ruleCustomerSelect');
    const ruleCustomerSearchInput = document.getElementById('ruleCustomerSearchInput');
    const ruleCustomerSearchDropdown = document.getElementById('ruleCustomerSearchDropdown');
    
    let ruleCustomerOptions = [];
    if (ruleCustomerSearchDropdown) {
      ruleCustomerOptions = Array.from(ruleCustomerSearchDropdown.querySelectorAll('.searchable-select-option'));
    }

    let currentRules = [...classificationRules];

    // Rule Customer Searchable Select
    if (ruleCustomerSearchInput) {
      ruleCustomerSearchInput.addEventListener('focus', () => {
        ruleCustomerSearchDropdown.style.display = 'block';
        ruleCustomerOptions.forEach(opt => opt.style.display = 'block');
      });

      ruleCustomerSearchInput.addEventListener('input', () => {
        const term = ruleCustomerSearchInput.value.toLowerCase().trim();
        ruleCustomerOptions.forEach(opt => {
          const text = opt.getAttribute('data-search') || '';
          if (text.includes(term) || opt.getAttribute('data-value') === '') {
            opt.style.display = 'block';
          } else {
            opt.style.display = 'none';
          }
        });
      });
    }

    document.addEventListener('click', (e) => {
      if (ruleCustomerSearchDropdown && !e.target.closest('#ruleModal .searchable-select-container')) {
        ruleCustomerSearchDropdown.style.display = 'none';
      }
    });

    ruleCustomerOptions.forEach(opt => {
      opt.addEventListener('click', () => {
        const val = opt.getAttribute('data-value');
        const text = opt.textContent.trim();
        selectRuleCustomer(val, text);
        ruleCustomerSearchDropdown.style.display = 'none';
      });
    });

    function selectRuleCustomer(id, label) {
      if (ruleCustomerSelect) ruleCustomerSelect.value = id;
      if (ruleCustomerSearchInput) ruleCustomerSearchInput.value = id ? label : '';
      
      ruleCustomerOptions.forEach(opt => {
        if (opt.getAttribute('data-value') === id) {
          opt.classList.add('selected');
        } else {
          opt.classList.remove('selected');
        }
      });
    }

    // Modal helpers
    function openRuleModal(index = -1, ruleData = null) {
      if (!ruleForm) return;
      ruleForm.reset();
      if (ruleIndexInput) ruleIndexInput.value = index;
      selectRuleCustomer('', '');

      const flowType = (ruleData && ruleData.type) || 'in';
      const category = (ruleData && ruleData.category) || 'non_revenue';
      const matchType = (ruleData && ruleData.matchType) || 'keyword';

      if (ruleMatchTypeSelect) {
        ruleMatchTypeSelect.value = matchType;
      }

      // Hide or show keyword/customer inputs depending on match mode
      if (matchType === 'keyword') {
        if (rulePatternGroup) rulePatternGroup.style.display = 'block';
        if (rulePatternInput) {
          rulePatternInput.required = true;
          rulePatternInput.value = (ruleData && ruleData.pattern) || '';
        }
        if (ruleCustomerLinkGroup) ruleCustomerLinkGroup.style.display = 'block';
      } else {
        if (rulePatternGroup) rulePatternGroup.style.display = 'none';
        if (rulePatternInput) {
          rulePatternInput.required = false;
          rulePatternInput.value = '';
        }
        if (ruleCustomerLinkGroup) ruleCustomerLinkGroup.style.display = 'none';
      }

      if (index !== -1 && ruleData) {
        const titleEl = document.getElementById('ruleModalTitle');
        if (titleEl) titleEl.textContent = lang === 'vi' ? 'Sửa luật phân loại' : 'Edit Classification Rule';
        if (ruleTypeSelect) ruleTypeSelect.value = flowType;
        if (ruleTaxCategoryInput) ruleTaxCategoryInput.value = ruleData.taxCategory || '';
        
        if (matchType === 'keyword' && ruleData.targetCustomerId) {
          const matchedOpt = ruleCustomerOptions.find(opt => opt.getAttribute('data-value') === ruleData.targetCustomerId);
          const label = matchedOpt ? matchedOpt.textContent.trim() : '';
          selectRuleCustomer(ruleData.targetCustomerId, label);
        }
      } else {
        const titleEl = document.getElementById('ruleModalTitle');
        if (titleEl) titleEl.textContent = lang === 'vi' ? 'Thêm luật phân loại' : 'Add Classification Rule';
      }

      if (ruleCategorySelect) {
        if (flowType === 'out') {
          ruleCategorySelect.value = 'non_revenue';
          ruleCategorySelect.disabled = true;
        } else {
          ruleCategorySelect.value = category;
          ruleCategorySelect.disabled = false;
        }
      }

      if (ruleModal) ruleModal.style.display = 'flex';
    }

    function closeRuleModal() {
      if (ruleModal) ruleModal.style.display = 'none';
    }

    if (btnAddRule) btnAddRule.addEventListener('click', () => openRuleModal(-1));
    if (ruleModalCloseBtn) ruleModalCloseBtn.addEventListener('click', closeRuleModal);
    if (ruleModalCancelBtn) ruleModalCancelBtn.addEventListener('click', closeRuleModal);

    // Edit Rule Trigger
    document.querySelectorAll('.btn-edit-rule').forEach(btn => {
      btn.addEventListener('click', () => {
        const idx = parseInt(btn.getAttribute('data-index') || '-1', 10);
        const ruleData = JSON.parse(btn.getAttribute('data-rule') || '{}');
        openRuleModal(idx, ruleData);
      });
    });

    // Delete Rule Trigger
    document.querySelectorAll('.btn-delete-rule').forEach(btn => {
      btn.addEventListener('click', async () => {
        const idx = parseInt(btn.getAttribute('data-index') || '-1', 10);
        if (idx === -1) return;
        
        if (confirm('Are you sure you want to delete this rule?')) {
          currentRules.splice(idx, 1);
          await saveRulesToServer(currentRules);
        }
      });
    });

    // Submit Rule Form
    if (ruleForm) {
      ruleForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const idx = parseInt(ruleIndexInput.value || '-1', 10);
        const matchType = ruleMatchTypeSelect ? ruleMatchTypeSelect.value : 'keyword';
        const newRule = {
          matchType: matchType,
          pattern: matchType === 'keyword' ? rulePatternInput.value.trim() : '',
          type: ruleTypeSelect.value,
          category: ruleTypeSelect.value === 'out' ? 'non_revenue' : (ruleCategorySelect ? ruleCategorySelect.value : 'non_revenue'),
          taxCategory: ruleTaxCategoryInput.value.trim() || null,
          targetCustomerId: matchType === 'keyword' ? (ruleCustomerSelect ? ruleCustomerSelect.value : null) : null
        };

        if (matchType === 'keyword' && !newRule.pattern) {
          alert('Pattern keyword is required');
          return;
        }

        if (idx === -1) {
          currentRules.push(newRule);
        } else {
          currentRules[idx] = newRule;
        }

        await saveRulesToServer(currentRules);
      });
    }

    // --- Bank Settings Configuration Form Logic ---
    const bankConfigForm = document.getElementById('bankConfigForm');
    const bankBrandName = document.getElementById('bankBrandName');
    const bankAccountNumber = document.getElementById('bankAccountNumber');
    const bankOrgName = document.getElementById('bankOrgName');

    if (bankConfigForm) {
      bankConfigForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        try {
          // 1. Save defaultBank
          const res1 = await fetch('/api/crm/config', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ key: 'defaultBank', value: bankBrandName.value }),
          });

          // 2. Save defaultAccount
          const res2 = await fetch('/api/crm/config', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ key: 'defaultAccount', value: bankAccountNumber.value }),
          });

          // 3. Save orgName
          const res3 = await fetch('/api/crm/config', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ key: 'orgName', value: bankOrgName.value }),
          });

          if (res1.ok && res2.ok && res3.ok) {
            alert(lang === 'vi' ? 'Cấu hình tài khoản ngân hàng đã được cập nhật thành công!' : 'Bank account settings updated successfully!');
            window.location.reload();
          } else {
            alert(lang === 'vi' ? 'Có lỗi xảy ra khi lưu cấu hình.' : 'An error occurred while saving configurations.');
          }
        } catch (err) {
          console.error(err);
          alert(lang === 'vi' ? 'Lỗi kết nối mạng, không thể lưu cấu hình.' : 'Network connection error, unable to save configuration.');
        }
      });
    }

    // --- Single Payment Deletion Logic ---
    document.querySelectorAll('.btn-delete-payment').forEach(btn => {
      btn.addEventListener('click', async () => {
        const paymentId = btn.getAttribute('data-id');
        if (!paymentId) return;

        if (confirm(lang === 'vi' ? 'Bạn có chắc chắn muốn xóa giao dịch này không? Thao tác này không thể hoàn tác.' : 'Are you sure you want to delete this transaction? This action cannot be undone.')) {
          try {
            const res = await fetch(`/api/crm/payments/reconcile?id=${paymentId}`, {
              method: 'DELETE',
              credentials: 'include',
            });
            const data = await res.json();
            if (res.ok && data.success) {
              alert(lang === 'vi' ? 'Giao dịch đã được xóa thành công!' : 'Transaction deleted successfully!');
              window.location.reload();
            } else {
              alert(lang === 'vi' ? 'Lỗi khi xóa giao dịch: ' + (data.error || 'Không rõ lỗi') : 'Error deleting transaction: ' + (data.error || 'Unknown error'));
            }
          } catch (err) {
            console.error(err);
            alert(lang === 'vi' ? 'Lỗi kết nối mạng, không thể xóa giao dịch.' : 'Network connection error, unable to delete transaction.');
          }
        }
      });
    });

    // --- Bulk Cleanup Mismatched Payments Logic ---
    const btnCleanupMismatched = document.getElementById('btnCleanupMismatched');
    if (btnCleanupMismatched) {
      btnCleanupMismatched.addEventListener('click', async () => {
        if (confirm(lang === 'vi' ? 'Bạn có chắc chắn muốn xóa tất cả giao dịch đồng bộ từ số tài khoản khác với cấu hình hiện tại không?' : 'Are you sure you want to delete all transactions synced from account numbers other than the current configuration?')) {
          try {
            btnCleanupMismatched.disabled = true;
            btnCleanupMismatched.textContent = lang === 'vi' ? 'Đang dọn dẹp...' : 'Cleaning up...';
            
            const res = await fetch('/api/crm/payments/cleanup', {
              method: 'POST',
            });
            const data = await res.json();
            
            if (res.ok && data.success) {
              alert(lang === 'vi' ? `Đã dọn dẹp thành công ${data.count} giao dịch sai số tài khoản!` : `Successfully cleaned up ${data.count} mismatched account number transactions!`);
              window.location.reload();
            } else {
              const errMsg = data.error === 'Default bank account is not configured'
                ? (lang === 'vi' ? 'Chưa cấu hình tài khoản ngân hàng nhận tiền mặc định.' : 'Default receiving bank account is not configured.')
                : (data.error || (lang === 'vi' ? 'Lỗi không xác định' : 'Unknown error'));
              alert((lang === 'vi' ? 'Lỗi dọn dẹp giao dịch: ' : 'Cleanup error: ') + errMsg);
            }
          } catch (err) {
            console.error(err);
            alert(lang === 'vi' ? 'Lỗi kết nối mạng, không thể dọn dẹp giao dịch.' : 'Network connection error, unable to clean up transactions.');
          } finally {
            btnCleanupMismatched.disabled = false;
            btnCleanupMismatched.textContent = lang === 'vi' ? 'Dọn dẹp Giao dịch Sai' : 'Clean Mismatched Transactions';
          }
        }
      });
    }

    async function saveRulesToServer(rules) {
      try {
        const res = await fetch('/api/crm/payments/rules', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ rules }),
        });

        const data = await res.json();
        if (res.ok && data.success) {
          closeRuleModal();
          if (data.updatedCount !== undefined && data.updatedCount > 0) {
            alert(lang === 'vi' ? `Đã lưu cấu hình trigger và tự động cập nhật phân loại cho ${data.updatedCount} giao dịch hiện có!` : `Saved trigger configurations and auto-updated classification for ${data.updatedCount} existing transactions!`);
          }
          window.location.reload();
        } else {
          alert((lang === 'vi' ? 'Lỗi khi lưu cấu hình luật: ' : 'Error saving rules: ') + (data.error || (lang === 'vi' ? 'Lỗi không xác định' : 'Unknown error')));
        }
      } catch (err) {
        console.error(err);
        alert(lang === 'vi' ? 'Lỗi kết nối mạng, không thể lưu cấu hình luật.' : 'Network error, could not save rules.');
      }
    }


  </script>
</DashboardLayout>
