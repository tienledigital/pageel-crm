---
// @para-doc [user-manual/04-payments.md]
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import { env } from 'cloudflare:workers';
import { getDb } from '@/lib/db';
import { payments, customers, config, services, orders } from '@/lib/db/schema';
import { desc, eq, like, and, or, sql } from 'drizzle-orm';
import { t } from '@/lib/i18n';

const db = getDb(env);
const lang = Astro.locals.lang || 'vi';
const user = Astro.locals.user;
const isAdmin = user?.role === 'admin';

// Fetch all customers for manual link dropdown
const allCustomers = await db
  .select({
    id: customers.id,
    fullName: customers.fullName,
  })
  .from(customers)
  .orderBy(customers.fullName);

// Fetch all pending/partially_paid orders to allow linking
const allOrders = await db
  .select({
    id: orders.id,
    orderNumber: orders.orderNumber,
    amount: orders.amount,
    customerId: orders.customerId,
    status: orders.status,
  })
  .from(orders)
  .where(or(eq(orders.status, 'pending'), eq(orders.status, 'partially_paid')));

// Fetch active services
const allServices = await db
  .select()
  .from(services)
  .where(eq(services.status, 'active'))
  .orderBy(services.name);

// 1. Parse query parameters for filters
const url = new URL(Astro.request.url);
const search = url.searchParams.get('search') || '';
const typeFilter = url.searchParams.get('type') || ''; // 'in', 'out' or '' (all)

// 2. Build where conditions
const conditions = [];

if (search) {
  conditions.push(
    or(
      like(payments.transactionId, `%${search}%`),
      like(payments.content, `%${search}%`),
      like(payments.bank, `%${search}%`)
    )
  );
}

if (typeFilter === 'in' || typeFilter === 'out') {
  conditions.push(eq(payments.type, typeFilter));
}

const whereClause = conditions.length > 0 ? and(...conditions) : undefined;

// 3. Query transactions list joining with customer and order to enrich context
const transactionList = await db
  .select({
    id: payments.id,
    amount: payments.amount,
    transactionId: payments.transactionId,
    paymentMethod: payments.paymentMethod,
    bank: payments.bank,
    accountNumber: payments.accountNumber,
    type: payments.type,
    category: payments.category,
    taxCategory: payments.taxCategory,
    content: payments.content,
    paidAt: payments.paidAt,
    customerName: customers.fullName,
    customerId: customers.id,
    orderId: payments.orderId,
    orderNumber: orders.orderNumber,
  })
  .from(payments)
  .leftJoin(customers, eq(payments.customerId, customers.id))
  .leftJoin(orders, eq(payments.orderId, orders.id))
  .where(whereClause)
  .orderBy(desc(payments.paidAt));

// 4. Calculate total revenue metrics (total in vs total out) based on all payments
const statsQuery = await db
  .select({
    totalRevenue: sql<number>`SUM(CASE WHEN ${payments.type} = 'in' AND ${payments.category} = 'revenue' AND ${payments.customerId} IS NOT NULL AND ${payments.customerId} != 'CUST-ANONYMOUS' THEN ${payments.amount} ELSE 0 END)`,
    countRevenue: sql<number>`SUM(CASE WHEN ${payments.type} = 'in' AND ${payments.category} = 'revenue' AND ${payments.customerId} IS NOT NULL AND ${payments.customerId} != 'CUST-ANONYMOUS' THEN 1 ELSE 0 END)`,
    totalExpenses: sql<number>`SUM(CASE WHEN ${payments.type} = 'out' THEN ${payments.amount} ELSE 0 END)`,
    countExpenses: sql<number>`SUM(CASE WHEN ${payments.type} = 'out' THEN 1 ELSE 0 END)`,
  })
  .from(payments);

const stats = statsQuery[0] || { totalRevenue: 0, countRevenue: 0, totalExpenses: 0, countExpenses: 0 };
const totalIn = Number(stats.totalRevenue || 0);
const countIn = Number(stats.countRevenue || 0);
const totalOut = Number(stats.totalExpenses || 0);
const countOut = Number(stats.countExpenses || 0);

// Format money to VND representation
function formatVND(amount: number) {
  return new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(amount);
}

// Format date safely
function formatDate(timestamp: any) {
  if (!timestamp) return 'N/A';
  try {
    const date = new Date(Number(timestamp));
    if (isNaN(date.getTime())) {
      return 'N/A';
    }
    return date.toLocaleString('vi-VN', {
      timeZone: 'Asia/Ho_Chi_Minh',
      year: 'numeric',
      month: '2-digit',
      day: '2-digit',
      hour: '2-digit',
      minute: '2-digit',
    });
  } catch (e) {
    return 'N/A';
  }
}

// Query custom payment classification rules
const rulesRecord = await db.select().from(config).where(eq(config.key, 'payment_classification_rules')).limit(1);
let classificationRules = [];
try {
  classificationRules = rulesRecord.length > 0 && rulesRecord[0].value 
    ? JSON.parse(rulesRecord[0].value) 
    : [];
  if (!Array.isArray(classificationRules)) {
    classificationRules = [];
  }
} catch (e) {
  console.error('[Classification Rules Parse Error]:', e);
  classificationRules = [];
}

const defaultBankConfig = await db.select().from(config).where(eq(config.key, 'defaultBank')).limit(1);
const defaultAccountConfig = await db.select().from(config).where(eq(config.key, 'defaultAccount')).limit(1);
const orgNameConfig = await db.select().from(config).where(eq(config.key, 'orgName')).limit(1);
const sepaySyncLimitConfig = await db.select().from(config).where(eq(config.key, 'sepaySyncLimit')).limit(1);

const defaultBank = defaultBankConfig[0]?.value || 'MB';
const defaultAccount = defaultAccountConfig[0]?.value || '0000000000';
const orgName = orgNameConfig[0]?.value || 'Pageel';
const sepaySyncLimit = sepaySyncLimitConfig[0]?.value || '50';

// Query all customer IDs and invoice numbers for trigger match checks
const allCustomerIds = new Set(
  (await db.select({ id: customers.id }).from(customers))
    .map((c: any) => c.id?.toLowerCase() || '')
    .filter(Boolean)
);
const allOrderNumbers = new Set(
  (await db.select({ orderNumber: orders.orderNumber }).from(orders))
    .map((o: any) => o.orderNumber?.toLowerCase() || '')
    .filter(Boolean)
);

// Helper to check if a transaction matches any trigger rule
function hasMatchingTrigger(txContent: string | null, rules: any[]): boolean {
  if (!txContent) return false;
  const contentLower = txContent.toLowerCase();

  for (const rule of rules) {
    if (rule.matchType === 'auto_customer') {
      const tokens = txContent.match(/[a-zA-Z0-9]+/g);
      if (tokens) {
        for (const token of tokens) {
          const cleaned = token.trim().toLowerCase();
          if (cleaned.length >= 2) {
            if (allCustomerIds.has(cleaned)) return true;
            const numMatch = cleaned.match(/^[a-zA-Z]+(\d+)$/);
            if (numMatch && allCustomerIds.has(numMatch[1])) return true;
          }
        }
      }
    } else if (rule.matchType === 'auto_invoice') {
      const tokens = txContent.match(/[a-zA-Z0-9-]+/g);
      if (tokens) {
        for (const token of tokens) {
          const cleaned = token.trim().toLowerCase();
          if (cleaned.length >= 3 && allOrderNumbers.has(cleaned)) return true;
        }
      }
    } else if (rule.pattern && contentLower.includes(rule.pattern.toLowerCase())) {
      return true;
    }
  }
  return false;
}
---

<DashboardLayout title="Payments & Reconciliation">
  <style>
    .header-container {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 2rem;
