    .select-filter {
      background-color: var(--bg-card);
      border: 1px solid var(--border-color);
      color: var(--text-primary);
      padding: 0.65rem 1rem;
      border-radius: 8px;
      font-size: 0.875rem;
      outline: none;
      cursor: pointer;
    }

    .btn-filter {
      background-color: var(--primary);
      border: 1px solid var(--primary);
      color: #fff;
      padding: 0.65rem 1.25rem;
      border-radius: 8px;
      font-size: 0.875rem;
      font-weight: 600;
      cursor: pointer;
