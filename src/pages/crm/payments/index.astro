      background-color: rgba(16, 185, 129, 0.1);
      color: var(--success);
    }

    .stat-icon.expense {
      background-color: rgba(239, 68, 68, 0.1);
      color: var(--error);
    }

    .stat-icon.net {
      background-color: rgba(99, 102, 241, 0.1);
      color: var(--primary);
    }

    .stat-details {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }

    .stat-label {
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .stat-value {
      font-size: 1.35rem;
      font-weight: 700;
      color: var(--text-primary);
    }

    .stat-count {
      font-size: 0.75rem;
      color: var(--text-muted);
    }

    /* Filter Bar */
    .filter-bar {
