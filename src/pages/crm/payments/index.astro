                      </span>
                    </td>
                    <td>
                      {rule.matchType === 'auto_customer' ? (
                        <span style="color: var(--text-muted); font-style: italic;">Auto-extracted from content</span>
                      ) : rule.matchType === 'auto_invoice' ? (
                        <span style="color: var(--text-muted); font-style: italic;">Linked via matched Invoice</span>
                      ) : customer ? (
                        <div style="font-weight: 600;">{customer.fullName} <span style="font-size: 0.75rem; color: var(--text-muted); font-weight: normal;">({customer.id})</span></div>
                      ) : (
                        <span style="color: var(--text-muted); font-style: italic;">No Customer Link</span>
                      )}
                    </td>
                    <td>
                      <div style="display: flex; gap: 0.5rem;">
                        <button type="button" class="btn-action btn-edit-rule" data-index={idx} data-rule={JSON.stringify(rule)}>✏️ Edit</button>
                        <button type="button" class="btn-action btn-delete-rule" data-index={idx} style="border-color: rgba(239, 68, 68, 0.2); color: var(--error);">🗑️ Delete</button>
                      </div>
                    </td>
                  </tr>
                );
              })
            )}
