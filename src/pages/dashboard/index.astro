---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import { env } from 'cloudflare:workers';
import { getDb } from '@/lib/db';
import { users, syncLogs, customers, payments } from '@/lib/db/schema';
import { desc, eq } from 'drizzle-orm';

// Initialize database client to query analytics metrics
const db = getDb(env);

// Count users to display as an overview metric
const userCountResult = await db.select().from(users);
const totalUsers = userCountResult.length;

// Count customers to display as an overview metric
const customersResult = await db.select().from(customers);
const totalCustomers = customersResult.length;

// Fetch the 5 most recent sync/backup logs
const recentLogs = await db
  .select()
  .from(syncLogs)
  .orderBy(desc(syncLogs.runAt))
  .limit(5);

// Find the last backup log specifically
const lastBackup = recentLogs.find((log: any) => log.action === 'github_backup');
const lastBackupStatusText = lastBackup 
  ? (lastBackup.status === 'success' ? 'Thành công' : 'Thất bại') 
  : 'Chưa thực hiện';
const lastBackupStatusClass = lastBackup 
  ? (lastBackup.status === 'success' ? 'text-success' : 'text-danger') 
  : '';

// Calculate sync success rate safely
const syncLogsResult = await db.select().from(syncLogs);
const totalSyncs = syncLogsResult.length;
const successSyncs = syncLogsResult.filter((log: any) => log.status === 'success').length;
const syncSuccessRate = totalSyncs > 0 ? (successSyncs / totalSyncs) * 100 : 100.0;
const syncSuccessRateText = `${syncSuccessRate.toFixed(1)}%`;

// Fetch 5 most recent payment synchronizations
const recentPayments = await db
  .select({
    id: payments.id,
    amount: payments.amount,
    content: payments.content,
    paidAt: payments.paidAt,
    customerName: customers.fullName,
    customerId: customers.id,
    bank: payments.bank,
  })
  .from(payments)
  .leftJoin(customers, eq(payments.customerId, customers.id))
  .orderBy(desc(payments.paidAt))
  .limit(5);
---

<DashboardLayout title="System Overview">
  <style>
    /* Metric Cards Grid */
    .metrics-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 1.5rem;
      margin-bottom: 2.5rem;
    }

    .metric-card {
      background-color: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: 16px;
      padding: 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      position: relative;
      overflow: hidden;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .metric-card:hover {
      transform: translateY(-2px);
      border-color: var(--primary);
      box-shadow: 0 10px 20px rgba(99, 102, 241, 0.05);
    }

    /* Glow effect on hover */
    .metric-card::after {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: radial-gradient(circle at top right, var(--primary-glow) 0%, transparent 60%);
      opacity: 0;
      transition: opacity 0.3s ease;
      pointer-events: none;
    }

    .metric-card:hover::after {
      opacity: 1;
    }

    .metric-label {
      font-size: 0.875rem;
      color: var(--text-secondary);
      font-weight: 500;
    }

    .metric-value {
      font-size: 2.25rem;
      font-weight: 700;
      letter-spacing: -1px;
      color: var(--text-primary);
    }

    .metric-change {
      font-size: 0.75rem;
      display: flex;
      align-items: center;
      gap: 0.25rem;
      font-weight: 600;
    }

    .change-up {
      color: var(--success);
    }

    /* Info Panels */
    .dashboard-panels {
      display: grid;
      grid-template-columns: 2fr 1fr;
      gap: 1.5rem;
    }

    @media (max-width: 1024px) {
      .dashboard-panels {
        grid-template-columns: 1fr;
      }
    }

    .panel {
      background-color: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: 16px;
      padding: 1.75rem;
    }

    .panel-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1.5rem;
    }

    .panel-title {
      font-size: 1.125rem;
      font-weight: 600;
    }

    /* Table styles */
    .data-table-container {
      overflow-x: auto;
    }

    .data-table {
      width: 100%;
      border-collapse: collapse;
      text-align: left;
    }

    .data-table th {
      padding: 0.75rem 1rem;
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      border-bottom: 1px solid var(--border-color);
    }

    .data-table td {
      padding: 1rem;
      font-size: 0.875rem;
      border-bottom: 1px solid var(--border-color);
      color: var(--text-primary);
    }

    .data-table tr:last-child td {
      border-bottom: none;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      padding: 0.25rem 0.6rem;
      border-radius: 9999px;
      font-size: 0.75rem;
      font-weight: 600;
    }

    .badge-success {
      background-color: rgba(16, 185, 129, 0.1);
      color: var(--success);
    }

    .badge-danger {
      background-color: rgba(239, 68, 68, 0.1);
      color: var(--danger, #ef4444);
    }

    /* Buttons */
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      padding: 0.75rem 1.5rem;
      border-radius: 10px;
      font-weight: 600;
      font-size: 0.875rem;
      cursor: pointer;
      transition: all 0.2s ease;
      border: none;
    }

    .btn-primary {
      background-color: var(--primary);
      color: #fff;
    }
    .btn-primary:hover {
      background-color: var(--primary-hover, #4f46e5);
      transform: translateY(-1px);
    }

    .btn-secondary {
      background-color: var(--bg-card);
      border: 1px solid var(--border-color);
      color: var(--text-primary);
    }
    .btn-secondary:hover {
      background-color: var(--bg-hover);
      transform: translateY(-1px);
    }

    .btn-icon {
      width: 18px;
      height: 18px;
    }

    /* Controls Grid */
    .controls-grid {
      display: grid;
      grid-template-columns: 1.2fr 0.8fr;
      gap: 2rem;
    }

    @media (max-width: 768px) {
      .controls-grid {
        grid-template-columns: 1fr;
      }
    }

    .control-section {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .control-section h3 {
      font-size: 1rem;
      font-weight: 600;
      color: var(--text-primary);
      margin: 0;
    }

    .section-desc {
      font-size: 0.8125rem;
      color: var(--text-secondary);
      line-height: 1.4;
      margin: 0;
    }

    /* Forms */
    .export-form {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .form-row {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(110px, 1fr));
      gap: 0.75rem;
    }

    .form-group {
      display: flex;
      flex-direction: column;
      gap: 0.375rem;
    }

    .form-group label {
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--text-secondary);
      text-transform: uppercase;
    }

    .form-group input, .form-group select {
      background-color: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 0.5rem 0.75rem;
      color: var(--text-primary);
      font-size: 0.875rem;
      outline: none;
      transition: border-color 0.2s ease;
    }

    .form-group input:focus, .form-group select:focus {
      border-color: var(--primary);
    }

    /* Backup Status */
    .backup-status-banner {
      background-color: var(--bg-hover);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 0.75rem 1rem;
      font-size: 0.875rem;
      color: var(--text-secondary);
    }

    .text-success {
      color: var(--success);
    }

    .text-danger {
      color: var(--danger, #ef4444);
    }
    
    .text-primary {
      color: var(--primary);
    }

    /* Rotation animation for sync spinner */
    @keyframes spin {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }

    .spinning {
      animation: spin 1s linear infinite;
    }
  </style>

  <div class="metrics-grid">
    <!-- Active Customers -->
    <div class="metric-card">
      <span class="metric-label">Total Customers</span>
      <span class="metric-value">{totalCustomers}</span>
      <span class="metric-change change-up">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" style="width: 12px; height: 12px;">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" />
        </svg>
        Active
      </span>
    </div>

    <!-- Active Users -->
    <div class="metric-card">
      <span class="metric-label">System Users</span>
      <span class="metric-value">{totalUsers}</span>
      <span class="metric-change change-up">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" style="width: 12px; height: 12px;">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" />
        </svg>
        Active
      </span>
    </div>

    <!-- Sync Success Rate -->
    <div class="metric-card">
      <span class="metric-label">Sync Success Rate</span>
      <span class="metric-value">{syncSuccessRateText}</span>
      <span class="metric-change change-up">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" style="width: 12px; height: 12px;">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" />
        </svg>
        All webhooks healthy
      </span>
    </div>
  </div>

  <div class="dashboard-panels">
    <!-- Left Column -->
    <div style="display: flex; flex-direction: column; gap: 1.5rem;">
      <!-- Panel: Recent Customer Synced -->
      <div class="panel">
        <div class="panel-header">
          <h2 class="panel-title">Recent Synchronizations</h2>
        </div>
        <div class="data-table-container table-scroll-container">
          <table class="data-table">
            <thead>
              <tr>
                <th>Customer</th>
                <th>Status</th>
                <th>Source</th>
                <th>Timestamp</th>
              </tr>
            </thead>
            <tbody>
              {recentPayments.length === 0 ? (
                <tr>
                  <td colspan="4" style="text-align: center; color: var(--text-secondary); padding: 1.5rem;">Không có giao dịch đồng bộ nào gần đây</td>
                </tr>
              ) : (
                recentPayments.map((p: any) => (
                  <tr>
                    <td>
                      <strong>{p.customerId || 'N/A'}</strong> - {p.customerName || 'Ẩn danh'}
                    </td>
                    <td>
                      <span class="badge badge-success">Completed</span>
                    </td>
                    <td>
                      {p.bank || 'Sepay Webhook'}
                    </td>
                    <td style="white-space: nowrap;">
                      {new Date(p.paidAt).toLocaleString('vi-VN', { timeZone: 'Asia/Ho_Chi_Minh', hour: '2-digit', minute: '2-digit', day: '2-digit', month: '2-digit' })}
                    </td>
                  </tr>
                ))
              )}
            </tbody>
          </table>
        </div>
      </div>

      <!-- Panel: Reports & Backup Control -->
      <div class="panel">
        <div class="panel-header">
          <h2 class="panel-title">Reports & Backup Controls</h2>
        </div>
        
        <div class="controls-grid">
          <!-- Section 1: Excel S1a-HKD Export -->
          <div class="control-section">
            <h3>Báo cáo S1a-HKD (Doanh thu)</h3>
            <p class="section-desc">Xuất báo cáo thuế S1a-HKD dạng Excel hoặc ZIP nén theo tháng, quý hoặc năm.</p>
            
            <form id="export-form" class="export-form">
              <div class="form-row">
                <div class="form-group">
                  <label for="export-year">Năm</label>
                  <input type="number" id="export-year" name="year" value={new Date().getFullYear()} min="2020" max="2100" required />
                </div>
                <div class="form-group">
                  <label for="export-type">Loại xuất</label>
                  <select id="export-type" name="type">
                    <option value="month">Theo tháng</option>
                    <option value="quarter">Theo quý</option>
                    <option value="year">Cả năm (ZIP)</option>
                  </select>
                </div>
                <div class="form-group" id="group-month">
                  <label for="export-month">Tháng</label>
                  <select id="export-month" name="month">
                    {Array.from({ length: 12 }, (_, i) => (
                      <option value={i + 1} selected={i === new Date().getMonth()}>Tháng {i + 1}</option>
                    ))}
                  </select>
                </div>
                <div class="form-group" id="group-quarter" style="display: none;">
                  <label for="export-quarter">Quý</label>
                  <select id="export-quarter" name="quarter">
                    <option value="1">Quý 1</option>
                    <option value="2">Quý 2</option>
                    <option value="3">Quý 3</option>
                    <option value="4">Quý 4</option>
                  </select>
                </div>
              </div>
              <div style="display: flex; gap: 0.5rem; margin-top: 0.5rem;">
                <button type="submit" class="btn btn-primary" style="flex: 1; padding: 0.625rem 1rem; font-size: 0.8125rem;">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="btn-icon">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
                  </svg>
                  Tải báo cáo
                </button>
                <button type="button" id="btn-preview-report" class="btn btn-secondary" style="flex: 1; padding: 0.625rem 1rem; font-size: 0.8125rem;">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="btn-icon">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                  Xem trước
                </button>
              </div>
            </form>

            <!-- Preview section container -->
            <div id="preview-section" style="display: none; margin-top: 1.5rem; border-top: 1px solid var(--border-color); padding-top: 1.25rem;">
              <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.75rem;">
                <h4 style="margin: 0; font-size: 0.875rem; font-weight: 600; color: var(--text-primary);">Dữ liệu Xem trước</h4>
                <span class="badge badge-success" id="preview-summary" style="font-size: 0.7rem;">0 dòng - 0 đ</span>
              </div>
              <div class="data-table-container table-scroll-container" style="max-height: 250px; overflow-y: auto; border: 1px solid var(--border-color); border-radius: 8px;">
                <table class="data-table" style="font-size: 0.75rem; width: 100%;">
                  <thead style="position: sticky; top: 0; background-color: var(--bg-card); z-index: 1;">
                    <tr>
                      <th>Ngày</th>
                      <th>Khách hàng</th>
                      <th>Nội dung</th>
                      <th style="text-align: right;">Doanh thu</th>
                    </tr>
                  </thead>
                  <tbody id="preview-table-body">
                    <!-- Dynamic preview rows -->
                  </tbody>
                </table>
              </div>
            </div>
          </div>

          <!-- Section 2: Git Backup Trigger -->
          <div class="control-section">
            <h3>Sao lưu GitHub</h3>
            <p class="section-desc">Sao lưu toàn bộ cơ sở dữ liệu CRM (Customers, Invoices, Payments) lên GitHub Backup Repository.</p>
            
            <div class="backup-status-banner">
              <span>Trạng thái gần nhất: </span>
              <strong id="backup-status-text" class={lastBackupStatusClass}>{lastBackupStatusText}</strong>
            </div>
            
            <div style="display: flex; gap: 0.5rem; margin-top: 0.5rem;">
              <button id="btn-test-connection" class="btn btn-secondary" style="flex: 1; padding: 0.625rem 1rem; font-size: 0.8125rem;">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="btn-icon" id="test-connection-icon">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span>Kiểm tra kết nối</span>
              </button>
              
              <button id="btn-backup-now" class="btn btn-primary" style="flex: 1; padding: 0.625rem 1rem; font-size: 0.8125rem;">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="btn-icon" id="backup-btn-icon">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99" />
                </svg>
                <span>Sao lưu ngay</span>
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Right Column -->
    <div style="display: flex; flex-direction: column; gap: 1.5rem;">
      <!-- Panel: System Info -->
      <div class="panel">
        <div class="panel-header">
          <h2 class="panel-title">System Status</h2>
        </div>
        <div style="display: flex; flex-direction: column; gap: 1rem;">
          <div style="display: flex; justify-content: space-between; font-size: 0.875rem;">
            <span style="color: var(--text-secondary);">Database</span>
            <span style="font-weight: 600; color: var(--success);">Cloudflare D1 (Online)</span>
          </div>
          <div style="display: flex; justify-content: space-between; font-size: 0.875rem;">
            <span style="color: var(--text-secondary);">Storage</span>
            <span style="font-weight: 600; color: var(--success);">Cloudflare KV (Online)</span>
          </div>
          <div style="display: flex; justify-content: space-between; font-size: 0.875rem;">
            <span style="color: var(--text-secondary);">Runtime Environment</span>
            <span style="font-weight: 600; color: var(--primary);">Cloudflare Pages</span>
          </div>
        </div>
      </div>

      <!-- Panel: Recent Backup Logs -->
      <div class="panel">
        <div class="panel-header">
          <h2 class="panel-title">Recent Backup Logs</h2>
        </div>
        <div class="data-table-container table-scroll-container">
          <table class="data-table">
            <thead>
              <tr>
                <th>Time</th>
                <th>Status</th>
                <th>Details</th>
              </tr>
            </thead>
            <tbody>
              {recentLogs.length === 0 ? (
                <tr>
                  <td colspan="3" style="text-align: center; color: var(--text-secondary); padding: 1.5rem;">No logs found</td>
                </tr>
              ) : (
                recentLogs.map((log: any) => (
                  <tr>
                    <td style="white-space: nowrap;">
                      {new Date(log.runAt || Date.now()).toLocaleTimeString('vi-VN', { timeZone: 'Asia/Ho_Chi_Minh', hour: '2-digit', minute: '2-digit', second: '2-digit' })}
                    </td>
                    <td>
                      <span class={`badge ${log.status === 'success' ? 'badge-success' : 'badge-danger'}`}>
                        {log.status === 'success' ? 'success' : 'failed'}
                      </span>
                    </td>
                    <td style="max-width: 120px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title={log.message || ''}>
                      {log.message || 'N/A'}
                    </td>
                  </tr>
                ))
              )}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</DashboardLayout>

<script>
  function escapeHtml(unsafe: any): string {
    if (unsafe === null || unsafe === undefined) return '';
    return String(unsafe)
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#039;");
  }

  // Handle toggle export inputs based on selection type
  const exportType = document.getElementById('export-type') as HTMLSelectElement;
  const groupMonth = document.getElementById('group-month');
  const groupQuarter = document.getElementById('group-quarter');

  if (exportType && groupMonth && groupQuarter) {
    exportType.addEventListener('change', (e) => {
      const val = (e.target as HTMLSelectElement).value;
      if (val === 'month') {
        groupMonth.style.display = 'flex';
        groupQuarter.style.display = 'none';
      } else if (val === 'quarter') {
        groupMonth.style.display = 'none';
        groupQuarter.style.display = 'flex';
      } else {
        groupMonth.style.display = 'none';
        groupQuarter.style.display = 'none';
      }
    });
  }

  // Handle export form submission
  const exportForm = document.getElementById('export-form') as HTMLFormElement;
  if (exportForm) {
    exportForm.addEventListener('submit', (e) => {
      e.preventDefault();
      const year = (document.getElementById('export-year') as HTMLInputElement).value;
      const type = (document.getElementById('export-type') as HTMLSelectElement).value;
      
      let url = `/api/export/s1a?year=${year}`;
      if (type === 'month') {
        const month = (document.getElementById('export-month') as HTMLSelectElement).value;
        url += `&month=${month}`;
      } else if (type === 'quarter') {
        const quarter = (document.getElementById('export-quarter') as HTMLSelectElement).value;
        url += `&quarter=${quarter}`;
      }

      // Trigger file download
      window.location.href = url;
    });
  }

  // Handle report preview trigger
  const btnPreview = document.getElementById('btn-preview-report');
  const previewSection = document.getElementById('preview-section');
  const previewSummary = document.getElementById('preview-summary');
  const previewTableBody = document.getElementById('preview-table-body');

  if (btnPreview && previewSection && previewSummary && previewTableBody) {
    btnPreview.addEventListener('click', async () => {
      const year = (document.getElementById('export-year') as HTMLInputElement).value;
      const type = (document.getElementById('export-type') as HTMLSelectElement).value;
      
      let url = `/api/export/s1a-preview?year=${year}`;
      if (type === 'month') {
        const month = (document.getElementById('export-month') as HTMLSelectElement).value;
        url += `&month=${month}`;
      } else if (type === 'quarter') {
        const quarter = (document.getElementById('export-quarter') as HTMLSelectElement).value;
        url += `&quarter=${quarter}`;
      }

      btnPreview.setAttribute('disabled', 'true');
      const originalText = btnPreview.innerHTML;
      btnPreview.innerHTML = 'Đang tải...';

      try {
        const res = await fetch(url);
        if (!res.ok) throw new Error('Không thể tải dữ liệu xem trước.');
        const data = await res.json();
        
        if (data.success) {
          previewSummary.textContent = `${data.totalCount} dòng - ${new Intl.NumberFormat('vi-VN').format(data.totalAmount)} đ`;
          
          if (data.payments.length === 0) {
            previewTableBody.innerHTML = `
              <tr>
                <td colspan="4" style="text-align: center; color: var(--text-secondary); padding: 1.5rem;">Không có giao dịch phù hợp (phải có thông tin Khách hàng)</td>
              </tr>
            `;
          } else {
            previewTableBody.innerHTML = data.payments.map((p: any) => {
              const dateStr = new Date(p.paidAt).toLocaleDateString('vi-VN', { timeZone: 'Asia/Ho_Chi_Minh' });
              const customerName = p.customer ? p.customer.fullName : 'Chưa gán';
              const customerId = p.customer ? p.customer.id : 'N/A';
              const amountStr = new Intl.NumberFormat('vi-VN').format(p.amount) + ' đ';
              return `
                <tr>
                  <td style="white-space: nowrap;">${escapeHtml(dateStr)}</td>
                  <td><strong>${escapeHtml(customerId)}</strong> - ${escapeHtml(customerName)}</td>
                  <td>${escapeHtml(p.content)}</td>
                  <td style="text-align: right; font-weight: 600; color: var(--text-primary);">${escapeHtml(amountStr)}</td>
                </tr>
              `;
            }).join('');
          }
          previewSection.style.display = 'block';
        } else {
          throw new Error(data.error || 'Lỗi không xác định.');
        }
      } catch (err: any) {
        alert(`Lỗi xem trước: ${err.message}`);
      } finally {
        btnPreview.removeAttribute('disabled');
        btnPreview.innerHTML = originalText;
      }
    });
  }

  // Handle test connection trigger
  const btnTestConnection = document.getElementById('btn-test-connection');
  const iconTestConnection = document.getElementById('test-connection-icon');

  if (btnTestConnection) {
    btnTestConnection.addEventListener('click', async () => {
      if (btnTestConnection.hasAttribute('disabled')) return;

      btnTestConnection.setAttribute('disabled', 'true');
      if (iconTestConnection) iconTestConnection.classList.add('spinning');
      
      const originalText = btnTestConnection.innerHTML;
      btnTestConnection.innerHTML = 'Đang kiểm tra...';

      try {
        const res = await fetch('/api/backup/test-connection', {
          method: 'POST',
        });

        const data = await res.json();
        if (res.ok && data.success) {
          alert(`Kết nối thành công!\nRepository: ${data.repo}\nTrạng thái: ${data.private ? 'Riêng tư (Private)' : 'Công khai (Public)'}`);
        } else {
          throw new Error(data.error || 'Connection check failed');
        }
      } catch (err: any) {
        alert(`Lỗi kiểm tra kết nối: ${err.message}`);
      } finally {
        btnTestConnection.removeAttribute('disabled');
        btnTestConnection.innerHTML = originalText;
        if (iconTestConnection) iconTestConnection.classList.remove('spinning');
      }
    });
  }

  // Handle backup manual trigger
  const btnBackup = document.getElementById('btn-backup-now');
  const iconBackup = document.getElementById('backup-btn-icon');
  const statusText = document.getElementById('backup-status-text');

  if (btnBackup) {
    btnBackup.addEventListener('click', async () => {
      if (btnBackup.hasAttribute('disabled')) return;

      btnBackup.setAttribute('disabled', 'true');
      if (iconBackup) iconBackup.classList.add('spinning');
      if (statusText) {
        statusText.textContent = 'Đang sao lưu...';
        statusText.className = 'text-primary';
      }

      try {
        const res = await fetch('/api/backup', {
          method: 'POST',
        });

        const data = await res.json();
        if (res.ok && data.success) {
          if (statusText) {
            statusText.textContent = 'Thành công';
            statusText.className = 'text-success';
          }
          alert(`Sao lưu thành công! Commit SHA: ${data.commitSha}`);
          // Reload page to show new log in table
          window.location.reload();
        } else {
          throw new Error(data.error || 'Backup failed');
        }
      } catch (err: any) {
        if (statusText) {
          statusText.textContent = 'Thất bại';
          statusText.className = 'text-danger';
        }
        alert(`Lỗi sao lưu: ${err.message}`);
      } finally {
        btnBackup.removeAttribute('disabled');
        if (iconBackup) iconBackup.classList.remove('spinning');
      }
    });
  }
</script>
