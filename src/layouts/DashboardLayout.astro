---
import '@/styles/design-system.css';
import { t } from '@/lib/i18n';

interface Props {
  title: string;
}

const { title } = Astro.props;
const user = Astro.locals.user;
const currentPath = Astro.url.pathname;
const lang = Astro.locals.lang || 'vi';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Pageel CRM</title>
    <meta name="description" content="Premium Cloud CRM Platform" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="crm-layout-container">
      <!-- Sidebar -->
      <aside class="crm-sidebar">
        <div class="crm-logo-section">
          <div class="crm-logo-icon">
            <svg viewBox="0 0 24 24" fill="none" style="width: 20px; height: 20px;">
              <path d="M9.315 7.584C12.195 3.883 16.695 1.5 21.75 1.5a.75.75 0 01.75.75c0 5.056-2.383 9.555-6.084 12.436h.001c-1.228 1.65-2.82 3.043-4.66 4.102l-1.554.894a.75.75 0 01-1.077-.925l1.625-3.525-3.525 1.625a.75.75 0 01-.925-1.077l.894-1.554c1.059-1.84 2.453-3.432 4.102-4.66zm-5.12 11.232a.75.75 0 00-.75.75v3a.75.75 0 00.75.75h3a.75.75 0 00.75-.75v-3a.75.75 0 00-.75-.75h-3z" fill="#FF5D01" fill-rule="evenodd" clip-rule="evenodd"/>
            </svg>
          </div>
          <span class="crm-logo-text">Pageel CRM</span>
        </div>

        <ul class="crm-nav-menu">
          {user && user.role !== 'saler' && (
            <>
              <li class={`crm-nav-item ${currentPath === '/dashboard' ? 'active' : ''}`}>
                <a href="/dashboard">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21.75h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21.75h2.25m4.75-12l-3.25 3.25m0 0L9.75 9.75m3.25 3.25V16.5" />
                  </svg>
                  {t('sidebar.dashboard', lang)}
                </a>
              </li>
              <li class={`crm-nav-item ${currentPath.startsWith('/crm/customers') ? 'active' : ''}`}>
                <a href="/crm/customers">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.109A11.386 11.386 0 0110.089 20M14.214 16.058A9.396 9.396 0 0010 15a9.396 9.396 0 00-4.214 1.058M14.214 16.058a9.306 9.306 0 01-2.224 2.898M10 15a9.38 9.38 0 00-2.625.372 9.337 9.337 0 00-4.121.952 4.125 4.125 0 007.533 2.493M10 15v-.003c0-1.113.285-2.16.786-3.07M10 15v.109A11.386 11.386 0 005.089 16.5M10 7.5a3 3 0 110-6 3 3 0 010 6zm5 3a3 3 0 110-6 3 3 0 010 6z" />
                  </svg>
                  {t('sidebar.customers', lang)}
                </a>
              </li>
              <li class={`crm-nav-item ${currentPath.startsWith('/crm/orders') ? 'active' : ''}`}>
                <a href="/crm/orders">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375.375 0 11-.75 0 .375.375 0 01.75 0zm7.5 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
                  </svg>
                  {t('sidebar.orders', lang)}
                </a>
              </li>
              <li class={`crm-nav-item ${currentPath.startsWith('/crm/invoices') ? 'active' : ''}`}>
                <a href="/crm/invoices">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                  </svg>
                  {t('sidebar.invoices', lang)}
                </a>
              </li>
              <li class={`crm-nav-item ${currentPath.startsWith('/crm/payments') ? 'active' : ''}`}>
                <a href="/crm/payments">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z" />
                  </svg>
                  {t('sidebar.payments', lang)}
                </a>
              </li>
              <li class={`crm-nav-item ${currentPath.startsWith('/crm/services') ? 'active' : ''}`}>
                <a href="/crm/services">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" />
                  </svg>
                  {t('sidebar.services', lang)}
                </a>
              </li>
            </>
          )}

          <li class={`crm-nav-item ${currentPath.startsWith('/crm/qr-tool') ? 'active' : ''}`}>
            <a href="/crm/qr-tool">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5A1.125 1.125 0 013.75 9.375v-4.5zM3.75 14.625c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5a1.125 1.125 0 01-1.125-1.125v-4.5zM13.5 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5A1.125 1.125 0 0113.5 9.375v-4.5zM6.75 6.75h.75v.75h-.75v-.75zM6.75 16.5h.75v.75h-.75v-.75zM16.5 6.75h.75v.75h-.75v-.75zM13.5 13.5h.75v.75h-.75v-.75zM16.5 16.5h.75v.75h-.75v-.75zM13.5 16.5h.75v.75h-.75v-.75zM16.5 13.5h.75v.75h-.75v-.75z" />
              </svg>
              {t('sidebar.qr_tool', lang)}
            </a>
          </li>

          {user && (user.role === 'admin' || user.role === 'accountant') && (
            <li class={`crm-nav-item ${currentPath.startsWith('/crm/settings/audit') ? 'active' : ''}`}>
              <a href="/crm/settings/audit">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                {t('sidebar.audit', lang)}
              </a>
            </li>
          )}

          {user && user.role === 'admin' && (
            <li class={`crm-nav-item ${currentPath === '/crm/settings' ? 'active' : ''}`}>
              <a href="/crm/settings">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.43l-1.003.828c-.293.241-.438.613-.43.992a7.723 7.723 0 010 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.43l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.991l-1.004-.827a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.28z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                {t('sidebar.settings', lang)}
              </a>
            </li>
          )}
        </ul>

        {user && (
          <div class="crm-user-section">
            <div class="crm-user-info">
              <div class="crm-user-avatar">
                {user.username.substring(0, 2).toUpperCase()}
              </div>
              <div class="crm-user-details">
                <span class="crm-user-name">{user.username}</span>
                <span class="crm-user-role">{user.role}</span>
              </div>
            </div>
            <button id="logoutBtn" class="crm-logout-btn">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 16px; height: 16px;">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15M12 9l-3 3m0 0l3 3m-3-3h12.75" />
              </svg>
              {t('sidebar.logout', lang)}
            </button>
          </div>
        )}
      </aside>

      <!-- Main Content -->
      <main class="crm-main-content">
        <header class="crm-page-header">
          <h1 class="page-title">{title}</h1>
        </header>
        <slot />
      </main>
    </div>

    <script>
      const logoutBtn = document.getElementById('logoutBtn');
      if (logoutBtn) {
        logoutBtn.addEventListener('click', async () => {
          try {
            const res = await fetch('/api/auth/logout', { method: 'POST' });
            if (res.ok) {
              window.location.href = '/login';
            }
          } catch (e) {
            console.error('Logout error:', e);
          }
        });
      }
    </script>
  </body>
</html>
