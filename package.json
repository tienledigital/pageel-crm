{
  "name": "pageel-crm",
  "type": "module",
  "version": "0.12.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "dev:cf": "wrangler pages dev --d1 DB -- astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "generate-types": "wrangler types",
    "lint": "astro check && tsc --noEmit --incremental",
    "db:generate": "drizzle-kit generate",
    "db:push:test": "drizzle-kit push",
    "db:push:local": "wrangler d1 migrations apply DB --local",
    "db:deploy": "./scripts/deploy.sh",
    "dev:all": "npm run db:generate && npm run db:push:local && npm run dev"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.5.2",
    "@libsql/client": "^0.17.3",
    "astro": "^6.3.5",
    "better-sqlite3": "^12.10.0",
    "drizzle-orm": "^0.45.2",
    "exceljs": "^4.4.0",
    "jszip": "^3.10.1",
    "wrangler": "^4.93.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jszip": "^3.4.0",
    "@types/node": "^25.9.1",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "overrides": {
    "vite": "^7"
  }
}
